<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Watch 2.0 – IA High Tec Shop</title>
<link href="https://fonts.googleapis.com/css2?family=Sofia+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --red: #e53e3e;
    --gray-100: #f5f5f5;
    --gray-200: #e8e8e8;
    --gray-400: #aaa;
    --gray-500: #888;
    --radius: 14px;
    --font: 'Sofia Sans', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font);
    background: #fff;
    color: var(--black);
    width: 100%;
    overflow-x: hidden;
    padding-bottom: 60px;
  }

  /* ── LIVE TOP TICKER ── */
  .live-ticker {
    background: #0a0a0a;
    color: #fff;
    overflow: hidden;
    white-space: nowrap;
    position: sticky;
    top: 0;
    z-index: 200;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .live-ticker-inner {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0;
  }
  /* Left badge: TikTok live */
  .live-ticker-badge {
    flex-shrink: 0;
    background: var(--red);
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 9px 12px 9px 10px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    z-index: 1;
  }
  .live-ticker-badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: white;
    animation: blink 1s infinite;
    flex-shrink: 0;
  }
  /* TikTok logo SVG inline */
  .tiktok-icon {
    width: 14px; height: 14px;
    flex-shrink: 0;
    fill: white;
  }
  /* Scrolling track */
  .live-ticker-track-wrap {
    flex: 1;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
  }
  .live-ticker-track {
    display: inline-flex;
    gap: 0;
    animation: ticker-scroll 22s linear infinite;
    white-space: nowrap;
  }
  .live-ticker-track:hover { animation-play-state: paused; }
  .live-ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 9px 18px;
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    border-right: 1px solid rgba(255,255,255,0.1);
    white-space: nowrap;
  }
  .live-ticker-item .t-emoji { font-size: 13px; }
  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }

  /* ── HEADER ── */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--gray-200);
    background: white;
    position: sticky;
    top: 38px;
    z-index: 100;
  }
  .header-logo {
    font-weight: 800;
    font-size: 16px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .header-icons { display: flex; gap: 16px; margin-left: auto; }
  .header-icons svg { width: 22px; height: 22px; }

  /* ── LIVE BANNER (under header, black) ── */
  .live-banner {
    background: #0a0a0a;
    color: #fff;
    padding: 13px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 2px solid var(--red);
  }
  .live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); flex-shrink: 0; animation: blink 1s infinite; box-shadow: 0 0 6px var(--red); }
  .live-banner-text { flex: 1; }
  .live-banner-top { font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 3px; display: flex; align-items: center; gap: 5px; }
  .live-banner-main { font-size: 17px; font-weight: 800; line-height: 1.2; color: white; }
  .live-banner-sub { font-size: 10px; font-weight: 500; color: rgba(255,255,255,0.5); margin-top: 2px; }
  .live-badge { background: var(--red); color: white; font-size: 15px; font-weight: 800; border-radius: 10px; padding: 7px 14px; white-space: nowrap; flex-shrink: 0; box-shadow: 0 2px 12px rgba(229,62,62,0.5); }

  /* ── GALLERY SWIPE ── */
  .gallery-wrap {
    width: 100%;
    position: relative;
    background: var(--gray-100);
  }
  .gallery-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .gallery-track::-webkit-scrollbar { display: none; }
  .gallery-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    aspect-ratio: 1/1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-100);
  }
  .gallery-slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 24px;
  }
  .gallery-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 10px 0 6px;
    background: white;
  }
  .gallery-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gray-200);
    transition: background 0.2s, transform 0.2s;
    cursor: pointer;
  }
  .gallery-dot.active { background: var(--black); transform: scale(1.3); }

  .thumbs {
    display: flex;
    gap: 8px;
    padding: 8px 16px 12px;
    overflow-x: auto;
    scrollbar-width: none;
    background: white;
  }
  .thumbs::-webkit-scrollbar { display: none; }
  .thumb {
    width: 64px; height: 64px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid transparent;
    cursor: pointer;
    background: var(--gray-100);
    transition: border-color 0.15s;
  }
  .thumb.active { border-color: var(--black); }
  .thumb img { width: 100%; height: 100%; object-fit: contain; padding: 5px; }

  /* ── CONTENT ── */
  .content { padding: 16px 16px 0; }
  .brand { font-size: 11px; color: var(--gray-500); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 5px; font-weight: 500; }
  .title { font-size: 24px; font-weight: 800; line-height: 1.2; margin-bottom: 6px; }
  .title em { font-style: italic; font-weight: 300; font-size: 17px; display: block; margin-top: 2px; color: var(--gray-500); }
  .stars-row { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
  .stars { color: #f4a100; font-size: 14px; }
  .stars-count { font-size: 13px; font-weight: 600; color: var(--gray-500); }
  .stars-count a { color: var(--gray-500); text-decoration: underline; }

  /* ── COLOR BUTTONS ── */
  .color-label { font-size: 13px; color: var(--gray-500); margin-bottom: 10px; font-weight: 500; }
  .color-label strong { color: var(--black); font-weight: 700; }
  .color-options { display: flex; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; }

  .color-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 3px solid transparent;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s, transform 0.15s;
    flex-shrink: 0;
  }
  .color-btn:hover { transform: scale(1.08); }
  .color-btn.active {
    border-color: var(--black);
    box-shadow: 0 0 0 2px white inset;
  }
  .color-btn[data-color="gris"] { background: #b0aead; }
  .color-btn[data-color="noir"] { background: #1a1a1a; }
  .color-btn[data-color="orange"] { background: #e87722; }
  .color-btn.active::after {
    content: '✓';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 16px;
    font-weight: 700;
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.4);
  }
  .color-btn[data-color="gris"].active::after { color: #333; }

  /* ── QTY ── */
  .qty-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .qty-label { font-size: 13px; color: var(--gray-500); }
  .qty-ctrl { display: flex; align-items: center; border: 1.5px solid var(--gray-200); border-radius: 10px; overflow: hidden; }
  .qty-btn { width: 38px; height: 38px; background: none; border: none; font-size: 18px; font-weight: 700; cursor: pointer; font-family: var(--font); display: flex; align-items: center; justify-content: center; }
  .qty-val { width: 36px; text-align: center; font-size: 15px; font-weight: 700; font-family: var(--font); }

  /* ── OFFER CARD ── */
  .offer-card {
    background: #0a0a0a;
    border-radius: var(--radius);
    padding: 16px 14px;
    margin-bottom: 14px;
    position: relative;
    overflow: hidden;
  }
  .offer-card::before {
    content: '';
    position: absolute;
    top: -30px; right: -30px;
    width: 140px; height: 140px;
    border-radius: 50%;
    background: rgba(229,62,62,0.15);
  }
  .offer-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .offer-card-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); display: flex; align-items: center; gap: 5px; }
  .offer-card-label::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--red); animation: blink 1s infinite; }
  .offer-card-badge { background: var(--red); color: white; font-size: 14px; font-weight: 800; border-radius: 8px; padding: 5px 12px; }
  .offer-prices { display: flex; align-items: flex-end; gap: 10px; margin-bottom: 8px; }
  .offer-price-now { font-size: 36px; font-weight: 800; color: white; line-height: 1; }
  .offer-price-old { font-size: 15px; color: rgba(255,255,255,0.45); text-decoration: line-through; padding-bottom: 3px; }
  .offer-saving { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; padding: 7px 10px; margin-bottom: 10px; }
  .offer-saving-main { font-size: 13px; font-weight: 800; color: white; margin-bottom: 2px; }
  .offer-saving-sub { font-size: 10px; color: rgba(255,255,255,0.55); }
  /* TIMER COMPACT */
  .offer-timer-row { display: flex; align-items: center; gap: 8px; }
  .offer-timer-label { font-size: 10px; color: rgba(255,255,255,0.55); flex-shrink: 0; }
  .offer-timer-blocks { display: flex; align-items: center; gap: 4px; }
  .offer-timer-unit { background: rgba(255,255,255,0.1); border-radius: 6px; width: 38px; padding: 5px 3px 4px; text-align: center; }
  .offer-timer-num { font-size: 18px; font-weight: 800; color: white; line-height: 1; display: block; }
  .offer-timer-sub { display: block; font-size: 7px; font-weight: 500; color: rgba(255,255,255,0.45); letter-spacing: 0.08em; margin-top: 1px; text-transform: uppercase; }
  .offer-timer-sep { font-size: 15px; font-weight: 700; color: rgba(255,255,255,0.4); margin-bottom: 2px; }
  .offer-perks { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
  .offer-perk { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 6px; padding: 4px 8px; font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.75); white-space: nowrap; }

  .sep { height: 1px; background: var(--gray-200); margin: 14px 0; }

  /* ── BENEFITS ── */
  .benefits { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }
  .benefits li { display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 500; }
  .check-icon { width: 20px; height: 20px; border-radius: 50%; background: var(--black); flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .check-icon svg { width: 11px; height: 11px; }

  /* ── STOCK ── */
  .stock-line { display: flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 600; color: var(--red); margin-bottom: 14px; }
  .stock-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--red); flex-shrink: 0; animation: blink 1s infinite; }

  /* ── CTA ── */
  .cta-btn { display: block; width: 100%; background: var(--black); color: white; border: none; border-radius: var(--radius); padding: 17px; font-family: var(--font); font-size: 15px; font-weight: 700; letter-spacing: 0.04em; cursor: pointer; text-align: center; text-decoration: none; margin-bottom: 10px; text-transform: uppercase; }
  .secure-note { display: flex; align-items: center; justify-content: center; gap: 5px; font-size: 11px; color: var(--gray-400); margin-bottom: 12px; }
  .secure-note svg { width: 12px; height: 12px; }

  /* ── PAYMENT IMAGE ── */
  .payment-image-wrap { display: flex; justify-content: center; margin-bottom: 20px; }
  .payment-image-wrap img { height: 32px; width: auto; object-fit: contain; }

  /* ── TRUST ROW ── */
  .trust-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; border-top: 1px solid var(--gray-200); border-bottom: 1px solid var(--gray-200); margin-bottom: 28px; }
  .trust-item { padding: 14px 6px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4px; border-right: 1px solid var(--gray-200); }
  .trust-item:last-child { border-right: none; }
  .trust-icon-sm { font-size: 20px; }
  .trust-text { font-size: 9px; font-weight: 700; line-height: 1.3; }

  /* ── FEATURES ── */
  .features { padding: 0 16px; margin-bottom: 28px; }
  .feature-block { margin-bottom: 24px; }
  .feature-img { width: 100%; border-radius: var(--radius); overflow: hidden; background: var(--gray-100); aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }
  .feature-img img { width: 100%; height: 100%; object-fit: contain; padding: 20px; }
  .feature-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 5px; }
  .feature-title { font-size: 18px; font-weight: 800; line-height: 1.25; margin-bottom: 7px; }
  .feature-desc { font-size: 13px; color: var(--gray-500); line-height: 1.6; }

  /* ── STATS ── */
  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 16px; margin-bottom: 28px; }
  .stat-card { background: var(--gray-100); border-radius: var(--radius); padding: 18px 12px; text-align: center; }
  .stat-num { font-size: 30px; font-weight: 800; line-height: 1; margin-bottom: 4px; }
  .stat-label { font-size: 11px; color: var(--gray-500); }

  /* ── REVIEWS ── */
  .section-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 5px; padding: 0 16px; }
  .section-title { font-size: 20px; font-weight: 800; line-height: 1.2; margin-bottom: 16px; padding: 0 16px; }
  .section-title em { font-style: italic; font-weight: 300; }
  .reviews-scroll { display: flex; gap: 10px; overflow-x: auto; padding: 0 16px 12px; scrollbar-width: none; margin-bottom: 6px; }
  .reviews-scroll::-webkit-scrollbar { display: none; }
  .review-card { flex-shrink: 0; width: 210px; background: var(--gray-100); border-radius: var(--radius); padding: 13px; }
  .review-stars { color: #f4a100; font-size: 12px; margin-bottom: 7px; }
  .review-text { font-size: 12px; font-weight: 600; color: var(--black); line-height: 1.5; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.02em; }
  .review-author { display: flex; align-items: center; gap: 7px; }
  .review-avatar { width: 28px; height: 28px; border-radius: 50%; font-size: 11px; font-weight: 700; background: var(--gray-200); flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .review-name { font-size: 11px; font-weight: 600; }
  .review-date { font-size: 10px; color: var(--gray-500); }

  /* ── LIFESTYLE ── */
  .lifestyle-strip { display: flex; overflow-x: auto; gap: 10px; padding: 0 16px 14px; scrollbar-width: none; margin-bottom: 22px; }
  .lifestyle-strip::-webkit-scrollbar { display: none; }
  .lifestyle-img { width: 160px; height: 160px; flex-shrink: 0; border-radius: var(--radius); object-fit: contain; background: var(--gray-100); padding: 12px; }

  /* ── FAQ ── */
  .faq-section-head { padding: 0 16px; margin-bottom: 10px; }
  .faq-wrap { padding: 0 16px; margin-bottom: 32px; }
  .faq-item { border-bottom: 1px solid var(--gray-200); }
  .faq-q { width: 100%; background: none; border: none; text-align: left; padding: 15px 0; font-family: var(--font); font-size: 14px; font-weight: 700; color: var(--black); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-icon { font-size: 18px; color: var(--gray-400); flex-shrink: 0; transition: transform 0.2s; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  .faq-a { display: none; font-size: 13px; color: var(--gray-500); line-height: 1.65; padding-bottom: 15px; }
  .faq-item.open .faq-a { display: block; }

  /* ── TRUSTPILOT ── */
  .tp-wrap { padding: 0 16px; margin-bottom: 32px; }
  .tp-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
  .tp-logo { font-size: 13px; font-weight: 800; color: #00b67a; }
  .tp-score { font-size: 13px; font-weight: 700; }
  .tp-score span { color: var(--gray-500); font-weight: 400; }
  .tp-global-stars { color: #00b67a; font-size: 16px; margin-bottom: 16px; }
  .tp-card { background: var(--gray-100); border-radius: var(--radius); padding: 13px; margin-bottom: 10px; }
  .tp-card-stars { color: #00b67a; font-size: 12px; margin-bottom: 5px; }
  .tp-card-date { font-size: 10px; color: var(--gray-500); margin-bottom: 5px; }
  .tp-card-text { font-size: 13px; font-weight: 500; line-height: 1.55; margin-bottom: 7px; }
  .tp-card-name { font-size: 11px; font-weight: 700; color: var(--gray-500); }
  .tp-verified { font-size: 10px; color: var(--gray-400); margin-top: 16px; text-align: center; }

  /* ── FOOTER ── */
  .footer { background: var(--black); color: white; padding: 22px 16px; text-align: center; }
  .footer-logo { font-size: 13px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }
  .footer-links { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; margin-bottom: 12px; }
  .footer-links a { font-size: 11px; color: rgba(255,255,255,0.6); text-decoration: none; }
  .footer-badges { display: flex; justify-content: center; gap: 12px; font-size: 11px; color: rgba(255,255,255,0.5); flex-wrap: wrap; margin-bottom: 10px; }
  .footer-copy { font-size: 10px; color: rgba(255,255,255,0.35); }
</style>
</head>
<body>

<!-- LIVE TOP TICKER (tout en haut, fond noir) -->
<div class="live-ticker">
  <div class="live-ticker-inner">
    <!-- Badge TikTok Live -->
    <div class="live-ticker-badge">
