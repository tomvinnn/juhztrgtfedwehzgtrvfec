{% doc %}
  @prompt
    genere moi des badges payment securiser livraison en 5j, garantie 60j etc je te laisse faire
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-trust-badges-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
  }

  .ai-trust-badge-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.icon_text_gap }}px;
    padding: {{ block.settings.badge_padding }}px;
    background-color: {{ block.settings.badge_background }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    text-align: center;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-trust-badge-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-trust-badge-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-trust-badge-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-trust-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-trust-badge-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-trust-badge-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-badges-container-{{ ai_gen_id }}">
    {% if block.settings.show_secure_payment %}
      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <div class="ai-trust-badge-content-{{ ai_gen_id }}">
          <div class="ai-trust-badge-title-{{ ai_gen_id }}">{{ block.settings.secure_payment_title }}</div>
          {% if block.settings.secure_payment_description != blank %}
            <div class="ai-trust-badge-description-{{ ai_gen_id }}">{{ block.settings.secure_payment_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_fast_delivery %}
      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
        </div>
        <div class="ai-trust-badge-content-{{ ai_gen_id }}">
          <div class="ai-trust-badge-title-{{ ai_gen_id }}">{{ block.settings.fast_delivery_title }}</div>
          {% if block.settings.fast_delivery_description != blank %}
            <div class="ai-trust-badge-description-{{ ai_gen_id }}">{{ block.settings.fast_delivery_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_guarantee %}
      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="M9 12l2 2 4-4"></path>
          </svg>
        </div>
        <div class="ai-trust-badge-content-{{ ai_gen_id }}">
          <div class="ai-trust-badge-title-{{ ai_gen_id }}">{{ block.settings.guarantee_title }}</div>
          {% if block.settings.guarantee_description != blank %}
            <div class="ai-trust-badge-description-{{ ai_gen_id }}">{{ block.settings.guarantee_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_support %}
      <div class="ai-trust-badge-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            <line x1="9" y1="10" x2="15" y2="10"></line>
            <line x1="12" y1="7" x2="12" y2="13"></line>
          </svg>
        </div>
        <div class="ai-trust-badge-content-{{ ai_gen_id }}">
          <div class="ai-trust-badge-title-{{ ai_gen_id }}">{{ block.settings.support_title }}</div>
          {% if block.settings.support_description != blank %}
            <div class="ai-trust-badge-description-{{ ai_gen_id }}">{{ block.settings.support_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Badges de confiance",
  "settings": [
    {
      "type": "header",
      "content": "Disposition"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur bureau",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Colonnes sur bureau",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes sur mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Disposition du badge",
      "options": [
        { "value": "row", "label": "Horizontal" },
        { "value": "column", "label": "Vertical" }
      ],
      "default": "column"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacement entre badges",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Espacement extérieur",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "badge_padding",
      "label": "Espacement intérieur badge",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fond conteneur",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Fond badge",
      "default": "#f8f8f8"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrondi conteneur",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Arrondi badge",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Icône"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Taille icône",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Couleur icône",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Espacement icône-texte",
      "min": 5,
      "max": 20,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Texte"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Taille titre",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Poids titre",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Moyen" },
        { "value": "600", "label": "Semi-gras" },
        { "value": "700", "label": "Gras" }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur titre",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Taille description",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Couleur description",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Paiement sécurisé"
    },
    {
      "type": "checkbox",
      "id": "show_secure_payment",
      "label": "Afficher",
      "default": true
    },
    {
      "type": "text",
      "id": "secure_payment_title",
      "label": "Titre",
      "default": "Paiement sécurisé"
    },
    {
      "type": "text",
      "id": "secure_payment_description",
      "label": "Description",
      "default": "SSL & cryptage"
    },
    {
      "type": "header",
      "content": "Livraison rapide"
    },
    {
      "type": "checkbox",
      "id": "show_fast_delivery",
      "label": "Afficher",
      "default": true
    },
    {
      "type": "text",
      "id": "fast_delivery_title",
      "label": "Titre",
      "default": "Livraison 5 jours"
    },
    {
      "type": "text",
      "id": "fast_delivery_description",
      "label": "Description",
      "default": "Partout en France"
    },
    {
      "type": "header",
      "content": "Garantie"
    },
    {
      "type": "checkbox",
      "id": "show_guarantee",
      "label": "Afficher",
      "default": true
    },
    {
      "type": "text",
      "id": "guarantee_title",
      "label": "Titre",
      "default": "Garantie 60 jours"
    },
    {
      "type": "text",
      "id": "guarantee_description",
      "label": "Description",
      "default": "Satisfait ou remboursé"
    },
    {
      "type": "header",
      "content": "Support client"
    },
    {
      "type": "checkbox",
      "id": "show_support",
      "label": "Afficher",
      "default": true
    },
    {
      "type": "text",
      "id": "support_title",
      "label": "Titre",
      "default": "Support 7j/7"
    },
    {
      "type": "text",
      "id": "support_description",
      "label": "Description",
      "default": "Réponse rapide"
    }
  ],
  "presets": [
    {
      "name": "Badges de confiance"
    }
  ]
}
{% endschema %}