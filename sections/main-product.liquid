<script>
  // ── NAV ──
  function openNav() {
    document.getElementById('navDrawer').classList.add('open');
    document.getElementById('navOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeNav() {
    document.getElementById('navDrawer').classList.remove('open');
    document.getElementById('navOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  // ── GALLERY ──
  const galleryData = {
    gris: [
      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960', alt: 'Smart Watch Gris' },
      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715', alt: 'Smart Watch Gris détail' }
    ],
    noir: [
      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/O1CN017e2Cmp2Dtzw4Yz7qK__2207705038668-0-cib_0a846c84-0535-4e84-9d6a-76f57b54b198.webp?v=1732348989', alt: 'Smart Watch Noir' },
      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713', alt: 'Smart Watch Noir détail' }
    ],
    orange: [
      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/O1CN017e2Cmp2Dtzw4Yz7qK__2207705038668-0-cib_0a846c84-0535-4e84-9d6a-76f57b54b198.webp?v=1732348989', alt: 'Smart Watch Orange' },
      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715', alt: 'Smart Watch Orange détail' }
    ]
  };

  let currentColor = 'gris';
  let currentSlide = 0;

  function buildGallery(color) {
    const imgs = galleryData[color];
    const track = document.getElementById('galleryTrack');
    const dots = document.getElementById('galleryDots');
    const thumbs = document.getElementById('thumbs');
    track.innerHTML = '';
    imgs.forEach((img) => {
      const slide = document.createElement('div');
      slide.className = 'gallery-slide';
      const im = document.createElement('img');
      im.src = img.src; im.alt = img.alt;
      slide.appendChild(im); track.appendChild(slide);
    });
    dots.innerHTML = '';
    imgs.forEach((_, i) => {
      const dot = document.createElement('div');
      dot.className = 'gallery-dot' + (i === 0 ? ' active' : '');
      dot.onclick = () => goToSlide(i);
      dots.appendChild(dot);
    });
    thumbs.innerHTML = '';
    imgs.forEach((img, i) => {
      const div = document.createElement('div');
      div.className = 'thumb' + (i === 0 ? ' active' : '');
      div.onclick = () => goToSlide(i);
      const im = document.createElement('img');
      im.src = img.src; im.alt = img.alt;
      div.appendChild(im); thumbs.appendChild(div);
    });
    currentSlide = 0;
    track.onscroll = () => {
      const idx = Math.round(track.scrollLeft / track.offsetWidth);
      if (idx !== currentSlide) { currentSlide = idx; updateGalleryUI(); }
    };
  }

  function goToSlide(idx) {
    const track = document.getElementById('galleryTrack');
    track.scrollTo({ left: idx * track.offsetWidth, behavior: 'smooth' });
    currentSlide = idx; updateGalleryUI();
  }

  function updateGalleryUI() {
    document.querySelectorAll('.gallery-dot').forEach((d, i) => d.classList.toggle('active', i === currentSlide));
    document.querySelectorAll('.thumb').forEach((t, i) => t.classList.toggle('active', i === currentSlide));
  }

  function selectColor(color, label, btn) {
    document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('color-name-top').textContent = label;
    currentColor = color;
    buildGallery(color);
  }

  buildGallery('gris');

  // ── TIMER ──
  let total = 1 * 3600 + 30 * 60;
  function updateTimer() {
    const h = Math.floor(total / 3600);
    const m = Math.floor((total % 3600) / 60);
    const s = total % 60;
    document.getElementById('t-h').textContent = String(h).padStart(2,'0');
    document.getElementById('t-min').textContent = String(m).padStart(2,'0');
    document.getElementById('t-sec').textContent = String(s).padStart(2,'0');
    if (total > 0) total--; else total = 1 * 3600 + 30 * 60;
  }
  updateTimer(); setInterval(updateTimer, 1000);

  // ── QTY ──
  let qty = 1;
  function changeQty(d) { qty = Math.max(1, qty + d); document.getElementById('qty').textContent = qty; }

  // ── FAQ ──
  function toggleFaq(btn) { btn.parentElement.classList.toggle('open'); }
</script>
</body>
</html>