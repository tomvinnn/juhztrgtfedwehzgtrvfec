<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Watch 2.0 – IA High Tec Shop</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&family=Sofia+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
  :root {
    --black: #0a0a0a;
    --red: #e53e3e;
    --gray-100: #f5f5f5;
    --gray-200: #e8e8e8;
    --gray-400: #aaa;
    --gray-500: #888;
    --radius: 14px;
    --font: 'Sofia Sans', sans-serif;
    --font-body: 'Poppins', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font);
    background: #fff;
    color: var(--black);
    width: 100%;
    overflow-x: hidden;
    padding-bottom: 60px;
  }

  /* ══════════════════════════════════════
     LIVE BANNER — même couleurs que l'offer card (noir/rouge)
  ══════════════════════════════════════ */
  .live-banner {
    background: linear-gradient(90deg, #0d0d0d 0%, #1a0505 30%, #2a0808 60%, #1a1a1a 100%);
    color: #fff;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 200;
    overflow: hidden;
    border-bottom: 1px solid rgba(229,62,62,0.3);
  }

  .live-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -55deg,
      transparent,
      transparent 22px,
      rgba(229,62,62,0.04) 22px,
      rgba(229,62,62,0.04) 44px
    );
    pointer-events: none;
  }

  /* Lueur rouge subtile */
  .live-banner::after {
    content: '';
    position: absolute;
    top: -60px; right: 20%;
    width: 200px; height: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(229,62,62,0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  .live-banner-inner {
    display: flex;
    align-items: center;
    padding: 11px 14px;
    gap: 10px;
    position: relative;
    z-index: 1;
  }

  .live-pill {
    display: flex;
    align-items: center;
    gap: 5px;
    background: rgba(229,62,62,0.2);
    border: 1px solid rgba(229,62,62,0.4);
    border-radius: 20px;
    padding: 4px 10px 4px 7px;
    flex-shrink: 0;
  }
  .live-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #ff4444;
    flex-shrink: 0;
    animation: blinkRed 0.9s infinite;
    box-shadow: 0 0 6px #ff4444;
  }
  @keyframes blinkRed { 0%,100%{opacity:1;box-shadow:0 0 8px #ff4444;} 50%{opacity:0.3;box-shadow:none;} }

  .live-pill-text {
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ff6666;
  }

  .live-banner-center {
    flex: 1;
    text-align: center;
  }
  .live-banner-main {
    font-size: 15px;
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #fff;
  }
  .live-banner-sub {
    font-size: 10px;
    font-weight: 500;
    color: rgba(255,255,255,0.55);
    margin-top: 2px;
    letter-spacing: 0.04em;
  }

  .live-badge {
    background: linear-gradient(135deg, #e53e3e, #c0000a);
    color: #fff;
    font-size: 15px;
    font-weight: 900;
    border-radius: 8px;
    padding: 6px 12px;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 10px rgba(229,62,62,0.5);
    animation: badgePop 1.6s ease-in-out infinite;
  }
  @keyframes badgePop {
    0%,100% { transform: scale(1); }
    50%      { transform: scale(1.06); }
  }

  /* ══ HEADER ══ */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 16px;
    border-bottom: 1px solid var(--gray-200);
    background: white;
    z-index: 100;
    position: relative;
  }

  /* Menu 3 points gauche */
  .header-menu {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    cursor: pointer;
    position: relative;
  }
  .header-menu-dots {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: center;
  }
  .header-menu-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--black);
  }

  /* Drawer menu */
  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 300;
    backdrop-filter: blur(2px);
  }
  .nav-overlay.open { display: block; }
  .nav-drawer {
    position: fixed;
    top: 0; left: 0;
    width: 260px;
    height: 100%;
    background: #fff;
    z-index: 400;
    padding: 24px 20px;
    transform: translateX(-100%);
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
    box-shadow: 4px 0 24px rgba(0,0,0,0.12);
  }
  .nav-drawer.open { transform: translateX(0); }
  .nav-drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }
  .nav-drawer-logo {
    font-family: var(--font);
    font-size: 14px;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .nav-close {
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 20px;
    color: var(--gray-500);
    border: none;
    background: none;
    border-radius: 50%;
  }
  .nav-links { list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .nav-links a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 10px;
    border-radius: 10px;
    text-decoration: none;
    color: var(--black);
    font-family: var(--font);
    font-size: 15px;
    font-weight: 700;
    transition: background 0.15s;
  }
  .nav-links a:hover { background: var(--gray-100); }
  .nav-links a .nav-icon { width: 20px; height: 20px; flex-shrink: 0; color: var(--red); }
  .nav-links a .nav-icon svg { width: 20px; height: 20px; }

  /* Logo centré */
  .header-logo {
    flex: 1;
    text-align: center;
    font-weight: 900;
    font-size: 18px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--black);
    line-height: 1;
    font-family: 'Poppins', sans-serif;
  }

  /* Icônes droite — seulement panier (caddie) */
  .header-icons { display: flex; gap: 12px; flex-shrink: 0; width: 40px; justify-content: flex-end; }
  .header-icons svg { width: 24px; height: 24px; cursor: pointer; }

  /* ── GALLERY SWIPE ── */
  .gallery-wrap { width: 100%; position: relative; background: var(--gray-100); }
  .gallery-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .gallery-track::-webkit-scrollbar { display: none; }
  .gallery-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    aspect-ratio: 1/1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-100);
    overflow: hidden;
  }
  .gallery-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    padding: 0;
    display: block;
  }
  .gallery-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 10px 0 6px;
    background: white;
  }
  .gallery-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gray-200);
    transition: background 0.2s, transform 0.2s;
    cursor: pointer;
  }
  .gallery-dot.active { background: var(--black); transform: scale(1.3); }

  .thumbs {
    display: flex;
    gap: 8px;
    padding: 8px 16px 12px;
    overflow-x: auto;
    scrollbar-width: none;
    background: white;
  }
  .thumbs::-webkit-scrollbar { display: none; }
  .thumb {
    width: 64px; height: 64px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid transparent;
    cursor: pointer;
    background: var(--gray-100);
    transition: border-color 0.15s;
  }
  .thumb.active { border-color: var(--black); }
  .thumb img { width: 100%; height: 100%; object-fit: cover; padding: 0; display: block; }

  /* ── CONTENT ── */
  .content { padding: 16px 16px 0; }
  .brand { font-size: 11px; color: var(--gray-500); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 5px; font-weight: 500; }
  .title { font-size: 24px; font-weight: 800; line-height: 1.2; margin-bottom: 6px; }
  .title em { font-style: italic; font-weight: 300; font-size: 17px; display: block; margin-top: 2px; color: var(--gray-500); }
  .stars-row { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
  .stars { color: #f4a100; font-size: 14px; }
  .stars-count { font-size: 13px; font-weight: 600; color: var(--gray-500); }
  .stars-count a { color: var(--gray-500); text-decoration: underline; }

  .color-label { font-size: 13px; color: var(--gray-500); margin-bottom: 10px; font-weight: 500; }
  .color-label strong { color: var(--black); font-weight: 700; }
  .color-options { display: flex; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; }
  .color-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 3px solid transparent;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s, transform 0.15s;
    flex-shrink: 0;
  }
  .color-btn:hover { transform: scale(1.08); }
  .color-btn.active { border-color: var(--black); box-shadow: 0 0 0 2px white inset; }
  .color-btn[data-color="gris"] { background: #b0aead; }
  .color-btn[data-color="noir"] { background: #1a1a1a; }
  .color-btn[data-color="orange"] { background: #e87722; }
  .color-btn.active::after {
    content: '✓';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 16px; font-weight: 700; color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.4);
  }
  .color-btn[data-color="gris"].active::after { color: #333; }

  .qty-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .qty-label { font-size: 13px; color: var(--gray-500); }
  .qty-ctrl { display: flex; align-items: center; border: 1.5px solid var(--gray-200); border-radius: 10px; overflow: hidden; }
  .qty-btn { width: 38px; height: 38px; background: none; border: none; font-size: 18px; font-weight: 700; cursor: pointer; font-family: var(--font); display: flex; align-items: center; justify-content: center; }
  .qty-val { width: 36px; text-align: center; font-size: 15px; font-weight: 700; font-family: var(--font); }

  /* ══ BENEFITS — Font Poppins + Font Awesome ══ */
  .benefits { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }
  .benefits li {
    display: flex;
    align-items: flex-start;
    gap: 11px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 1.5;
    color: #1a1a1a;
  }
  .benefit-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .benefit-icon svg { stroke: var(--black); }

  .sep { height: 1px; background: var(--gray-200); margin: 14px 0; }

  .stock-line { display: flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 600; color: var(--red); margin-bottom: 14px; font-family: var(--font-body); }
  .stock-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--red); flex-shrink: 0; animation: blink 1s infinite; }
  @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }

  /* ══ OFFER CARD — NOIR/ROUGE AGRESSIF ══ */
  .offer-card {
    background: #0d0d0d;
    border-radius: var(--radius);
    padding: 18px 16px;
    margin-bottom: 14px;
    position: relative;
    overflow: hidden;
    border: 1px solid #1f1f1f;
    box-shadow: 0 4px 24px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.04);
  }
  .offer-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -55deg,
      transparent,
      transparent 22px,
      rgba(229,62,62,0.03) 22px,
      rgba(229,62,62,0.03) 44px
    );
    pointer-events: none;
  }
  .offer-card::after {
    content: '';
    position: absolute;
    top: -40px; right: -40px;
    width: 160px; height: 160px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(229,62,62,0.22) 0%, transparent 70%);
    pointer-events: none;
  }

  .offer-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    position: relative;
    z-index: 1;
  }
  .offer-card-label {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ff4444;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .offer-card-label::before {
    content: '';
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #ff4444;
    animation: blinkRed 0.9s infinite;
    box-shadow: 0 0 6px #ff4444;
  }
  .offer-card-badge {
    background: linear-gradient(135deg, #e53e3e, #c0000a);
    color: white;
    font-size: 15px;
    font-weight: 900;
    border-radius: 8px;
    padding: 5px 13px;
    letter-spacing: 0.04em;
    box-shadow: 0 2px 10px rgba(229,62,62,0.5);
  }

  .offer-prices {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    margin-bottom: 12px;
    position: relative;
    z-index: 1;
  }
  .offer-price-now {
    font-size: 40px;
    font-weight: 900;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .offer-price-old {
    font-size: 16px;
    color: rgba(255,255,255,0.35);
    text-decoration: line-through;
    padding-bottom: 5px;
    font-weight: 500;
  }

  .offer-saving {
    background: rgba(229,62,62,0.12);
    border: 1px solid rgba(229,62,62,0.3);
    border-radius: 10px;
    padding: 9px 12px;
    margin-bottom: 14px;
    position: relative;
    z-index: 1;
  }
  .offer-saving-main {
    font-size: 13px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 3px;
  }
  .offer-saving-sub {
    font-size: 10px;
    color: rgba(255,255,255,0.45);
    line-height: 1.4;
  }

  .offer-divider {
    height: 1px;
    background: linear-gradient(90deg, rgba(229,62,62,0.5), transparent);
    margin-bottom: 14px;
    position: relative;
    z-index: 1;
  }

  .offer-timer-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }
  .offer-timer-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    flex-shrink: 0;
  }
  .offer-timer-blocks { display: flex; align-items: center; gap: 5px; }
  .offer-timer-unit {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    width: 42px;
    padding: 6px 3px 5px;
    text-align: center;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
  }
  .offer-timer-num {
    font-size: 20px;
    font-weight: 900;
    color: #fff;
    line-height: 1;
    display: block;
    letter-spacing: -0.02em;
  }
  .offer-timer-sub {
    display: block;
    font-size: 7px;
    font-weight: 700;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.1em;
    margin-top: 2px;
    text-transform: uppercase;
  }
  .offer-timer-sep {
    font-size: 18px;
    font-weight: 900;
    color: #e53e3e;
    margin-bottom: 2px;
    animation: blinkSep 1s infinite;
  }
  @keyframes blinkSep { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .offer-shipping-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 20px;
    padding: 5px 12px;
    font-size: 11px;
    font-weight: 700;
    color: rgba(255,255,255,0.75);
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }

  .offer-cta-btn {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, #e53e3e 0%, #c0000a 100%);
    color: white;
    border: none;
    border-radius: 11px;
    padding: 15px;
    font-family: var(--font);
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.06em;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
    box-shadow: 0 4px 18px rgba(229,62,62,0.5);
    animation: ctaGlow 2s ease-in-out infinite;
  }
  @keyframes ctaGlow {
    0%,100% { box-shadow: 0 4px 18px rgba(229,62,62,0.5); }
    50%      { box-shadow: 0 4px 28px rgba(229,62,62,0.75); }
  }

  /* Paiement sécurisé + logos paiement */
  .secure-note { display: flex; align-items: center; justify-content: center; gap: 5px; font-size: 11px; color: var(--gray-400); margin-bottom: 14px; font-family: var(--font-body); }
  .secure-note svg { width: 12px; height: 12px; }

  /* Logos paiement SVG inline */
  .payment-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
    padding: 0 8px;
  }
  .pay-logo {
    height: 28px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px 8px;
    background: #f5f5f5;
    border: 1px solid #e0e0e0;
  }
  .pay-logo svg { height: 16px; width: auto; }
  .pay-logo img { height: 16px; width: auto; }

  .trust-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; border-top: 1px solid var(--gray-200); border-bottom: 1px solid var(--gray-200); margin-bottom: 28px; }
  .trust-item { padding: 14px 6px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4px; border-right: 1px solid var(--gray-200); }
  .trust-item:last-child { border-right: none; }
  .trust-icon-sm { font-size: 20px; }
  .trust-text { font-size: 9px; font-weight: 700; line-height: 1.3; }

  .features { padding: 0 16px; margin-bottom: 28px; }
  .feature-block { margin-bottom: 24px; }
  .feature-img { width: 100%; border-radius: var(--radius); overflow: hidden; background: var(--gray-100); aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }
  .feature-img img { width: 100%; height: 100%; object-fit: contain; padding: 20px; }
  .feature-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 5px; }
  .feature-title { font-size: 18px; font-weight: 800; line-height: 1.25; margin-bottom: 7px; }
  .feature-desc { font-size: 13px; color: var(--gray-500); line-height: 1.6; }

  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 16px; margin-bottom: 28px; }
  .stat-card { background: var(--gray-100); border-radius: var(--radius); padding: 18px 12px; text-align: center; }
  .stat-num { font-size: 30px; font-weight: 800; line-height: 1; margin-bottom: 4px; }
  .stat-label { font-size: 11px; color: var(--gray-500); }

  .section-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 5px; padding: 0 16px; }
  .section-title { font-size: 20px; font-weight: 800; line-height: 1.2; margin-bottom: 16px; padding: 0 16px; }
  .section-title em { font-style: italic; font-weight: 300; }
  .reviews-scroll { display: flex; gap: 10px; overflow-x: auto; padding: 0 16px 12px; scrollbar-width: none; margin-bottom: 6px; }
  .reviews-scroll::-webkit-scrollbar { display: none; }
  .review-card { flex-shrink: 0; width: 210px; background: var(--gray-100); border-radius: var(--radius); padding: 13px; }
  .review-stars { color: #f4a100; font-size: 12px; margin-bottom: 7px; }
  .review-text { font-size: 12px; font-weight: 600; color: var(--black); line-height: 1.5; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.02em; }
  .review-author { display: flex; align-items: center; gap: 7px; }
