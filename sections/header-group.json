nt-size: 11px; color: rgba(255,255,255,0.35); }\n</style>\n</head>\n<body>\n\n<!-- HEADER -->\n<div class=\"header\">\n  <div class=\"header-logo\">IA High Tec Shop</div>\n  <div class=\"header-icons\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.35-4.35\"/></svg>\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z\"/><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"/><path d=\"M16 10a4 4 0 01-8 0\"/></svg>\n  </div>\n</div>\n\n<!-- LIVE BANNER -->\n<div class=\"live-banner\">\n  <div class=\"live-dot\"></div>\n  <div class=\"live-banner-text\">\n    <div class=\"live-banner-top\">🔴 Live en cours</div>\n    <div class=\"live-banner-main\">Offre Flash Spéciale Live</div>\n    <div class=\"live-banner-sub\">Disponible ce soir uniquement · Stock limité</div>\n  </div>\n  <div class=\"live-badge\">−50%</div>\n</div>\n\n<!-- GALLERY -->\n<div class=\"gallery\">\n  <div class=\"main-img-wrap\" id=\"mainGallery\">\n    <img id=\"img-gris-0\" class=\"active\"\n      src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960\"\n      alt=\"Smart Watch 2.0 Gris\">\n    <img id=\"img-gris-1\"\n      src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715\"\n      alt=\"Smart Watch 2.0 Gris détail\">\n    <img id=\"img-noir-0\"\n      src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/O1CN017e2Cmp2Dtzw4Yz7qK__2207705038668-0-cib_0a846c84-0535-4e84-9d6a-76f57b54b198.webp?v=1732348989\"\n      alt=\"Smart Watch 2.0 Noir\">\n    <img id=\"img-noir-1\"\n      src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\"\n      alt=\"Smart Watch 2.0 Noir détail\">\n    <img id=\"img-orange-0\