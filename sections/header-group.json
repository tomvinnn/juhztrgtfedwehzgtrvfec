        "liquid": "{% if request.page_type == 'product' %}\n\n<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Smart Watch 2.0 — IA High Tec Shop</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n*{box-sizing:border-box;margin:0;padding:0;}\n:root{\n  --black:#080808;\n  --white:#fafafa;\n  --gray-50:#f5f5f5;\n  --gray-100:#ebebeb;\n  --gray-200:#d4d4d4;\n  --gray-400:#999;\n  --gray-500:#666;\n  --accent:#1a3fcc;\n  --blue:#1a3fcc;\n  --font-serif:'Cormorant Garamond',Georgia,serif;\n  --font-sans:'DM Sans',sans-serif;\n}\nhtml,body{margin:0;padding:0;width:100%;overflow-x:hidden;}\nbody{font-family:var(--font-sans);background:var(--white);color:var(--black);padding-bottom:80px;}\n\n/* Masquer les éléments du thème Shopify */\n#shopify-section-header, #shopify-section-footer, .shopify-section-header, .shopify-section-footer, header, footer:not(.custom-footer) { display: none !important; }\n\n/* ─── LIVE BANNER ─── */\n.live-bar{\n  background:var(--black);color:var(--white);\n  display:flex;align-items:center;justify-content:space-between;\n  padding:9px 16px;position:sticky;top:0;z-index:200;\n  border-bottom:1px solid #1a1a1a;\n}\n.live-left{display:flex;align-items:center;gap:8px;}\n.live-dot{width:6px;height:6px;border-radius:50%;background:#fff;animation:blink 1s infinite;}\n@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.2;}}\n.live-pill{font-size:9px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,0.5);}\n.live-text{font-size:11px;font-weight:500;color:rgba(255,255,255,0.75);}\n.live-badge{font-size:11px;font-weight:700;background:var(--accent);color:#fff;border-radius:5px;padding:3px 9px;}\n\n/* ─── DELIVERY STEPS ─── */\n.delivery-strip{background:#f8f8f8;border-bottom:1px solid var(--gray-100);padding:14px 16px;}\n.delivery-steps{display:flex;align-items:flex-start;justify-content:center;position:relative;}\n.delivery-line{position:absolute;top:18px;left:20%;right:20%;height:2px;background:var(--blue);z-index:0;}\n.d-step{display:flex;flex-direction:column;align-items:center;flex:1;position:relative;z-index:1;}\n.d-circle{width:36px;height:36px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;font-size:15px;margin-bottom:7px;}\n.d-date{font-size:11px;font-weight:700;color:var(--black);margin-bottom:2px;}\n.d-label{font-size:9px;color:var(--gray-400);font-weight:500;}\n\n/* ─── GALLERY ─── */\n.gallery{position:relative;background:#fff;}\n.gallery-track{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;}\n.gallery-track::-webkit-scrollbar{display:none;}\n.gallery-slide{flex:0 0 100%;scroll-snap-align:start;aspect-ratio:1/1;}\n.gallery-slide img{width:100%;height:100%;object-fit:cover;display:block;}\n.gallery-dots{display:flex;justify-content:center;gap:5px;padding:10px 0;}\n.g-dot{width:6px;height:6px;border-radius:50%;background:var(--gray-200);cursor:pointer;}\n.g-dot.active{background:var(--black);transform:scale(1.2);}\n.gallery-thumbs{display:flex;gap:8px;padding:0 16px 16px;overflow-x:auto;scrollbar-width:none;}\n.g-thumb{width:60px;height:60px;border-radius:8px;overflow:hidden;flex-shrink:0;border:2px solid transparent;}\n.g-thumb.active{border-color:var(--black);}\n.g-thumb img{width:100%;height:100%;object-fit:cover;}\n\n/* ─── CONTENT ─── */\n.content{padding:20px 16px;}\n.product-title{font-family:var(--font-serif);font-size:32px;font-weight:300;margin-bottom:8px;}\n.stars-row{display:flex;align-items:center;gap:8px;margin-bottom:20px;}\n.stars{color:#c8a85a;}\n.color-opts{display:flex;gap:12px;margin:15px 0;}\n.c-btn{width:40px;height:40px;border-radius:50%;border:2px solid transparent;cursor:pointer;}\n.c-btn.active{border-color:var(--black);box-shadow:0 0 0 2px #fff inset;}\n\n/* ─── OFFER CARD ─── */\n.offer-card{background:var(--black);border-radius:15px;padding:20px;margin-bottom:20px;color:#fff;}\n.price-now{font-family:var(--font-serif);font-size:48px;line-height:1;}\n.price-old{text-decoration:line-through;color:rgba(255,255,255,0.4);font-size:16px;}\n.cta-btn{\n  display:block;width:100%;background:var(--accent);color:#fff;border:none;\n  border-radius:10px;padding:18px;font-size:14px;font-weight:700;\n  text-transform:uppercase;cursor:pointer;margin-top:15px;\n}\n\n/* ─── TRUST & FEATURES ─── */\n.trust-row{display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid var(--gray-100);padding:15px 0;}\n.trust-item{text-align:center;font-size:9px;color:var(--gray-500);}\n\n/* ─── STICKY BAR ─── */\n.sticky-bar{\n  position:fixed;bottom:0;left:0;right:0;background:#fff;\n  border-top:1px solid var(--gray-100);padding:12px 16px;z-index:9999;\n  display:flex;align-items:center;justify-content:space-between;\n  transform:translateY(100%);transition:transform .3s;\n}\n.sticky-bar.visible{transform:translateY(0);}\n.sticky-btn{background:var(--accent);color:#fff;border:none;border-radius:8px;padding:12px 20px;font-weight:600;cursor:pointer;}\n\n/* ─── POPUP ─── */\n.purchase-popup{\n  position:fixed;bottom:100px;left:16px;background:#fff;padding:10px;\n  border-radius:10px;box-shadow:0 5px 15px rgba(0,0,0,0.1);display:flex;\n  align-items:center;gap:10px;transform:translateX(-150%);transition: .5s;z-index:1000;\n}\n.purchase-popup.show{transform:translateX(0);}\n.popup-img{width:40px;height:40px;border-radius:5px;}\n</style>\n</head>\n<body>\n\n<div class=\"live-bar\">\n  <div class=\"live-left\"><div class=\"live-dot\"></div><span class=\"live-pill\">Live</span><span class=\"live-text\">Offre Spectateur</span></div>\n  <div class=\"live-badge\">−50%</div>\n</div>\n\n<div class=\"delivery-strip\">\n  <div class=\"delivery-steps\">\n    <div class=\"delivery-line\"></div>\n    <div class=\"d-step\"><div class=\"d-circle\">🛒</div><div class=\"d-date\" id=\"d-date1\"></div><div class=\"d-label\">Commande</div></div>\n    <div class=\"d-step\"><div class=\"d-circle\">🚚</div><div class=\"d-date\" id=\"d-date2\"></div><div class=\"d-label\">Envoi</div></div>\n    <div class=\"d-step\"><div class=\"d-circle\">🎁</div><div class=\"d-date\" id=\"d-date3\"></div><div class=\"d-label\">Livraison</div></div>\n  </div>\n</div>\n\n<div class=\"gallery\">\n  <div class=\"gallery-track\" id=\"galleryTrack\"></div>\n  <div class=\"gallery-dots\" id=\"galleryDots\"></div>\n  <div class=\"gallery-thumbs\" id=\"galleryThumbs\"></div>\n</div>\n\n<div class=\"content\">\n  <h1 class=\"product-title\">Smart Watch 2.0</h1>\n  <div class=\"stars-row\"><span class=\"stars\">★★★★★</span><span style=\"font-size:12px;color:#666;\">(312 avis)</span></div>\n\n  <p style=\"font-size:12px;color:#666;\">Couleur : <b id=\"color-name\">Noir</b></p>\n  <div class=\"color-opts\">\n    <button class=\"c-btn active\" onclick=\"selectColor('noir','Noir',this)\" style=\"background:#1a1a1a;\"></button>\n    <button class=\"c-btn\" onclick=\"selectColor('beige','Beige',this)\" style=\"background:#d4c5a9;\"></button>\n    <button class=\"c-btn\" onclick=\"selectColor('orange','Orange',this)\" style=\"background:#e87722;\"></button>\n  </div>\n\n  <div class=\"offer-card\" id=\"offerCard\">\n    <div class=\"price-old\">129,90 €</div>\n    <div class=\"price-now\">64,90 €</div>\n    <button class=\"cta-btn\" onclick=\"addToCart()\">Commander maintenant</button>\n    <p style=\"font-size:10px;text-align:center;margin-top:10px;opacity:0.6;\">Paiement 100% Sécurisé</p>\n  </div>\n</div>\n\n<div class=\"trust-row\">\n  <div class=\"trust-item\">🛡️<br>Garantie 1 an</div>\n  <div class=\"trust-item\">↩️<br>60j d'essai</div>\n  <div class=\"trust-item\">🚚<br>Offert</div>\n  <div class=\"trust-item\">💬<br>Support 24/7</div>\n</div>\n\n<div class=\"sticky-bar\" id=\"stickyBar\">\n  <div><div style=\"font-size:18px;font-weight:700;\">64,90 €</div><div style=\"font-size:11px;text-decoration:line-through;color:#999;\">129,90 €</div></div>\n  <button class=\"sticky-btn\" onclick=\"addToCart()\">Commander</button>\n</div>\n\n<div class=\"purchase-popup\" id=\"purchasePopup\">\n  <img class=\"popup-img\" id=\"popupImg\" src=\"\">\n  <div class=\"popup-text\"><strong id=\"popupName\"></strong> <span>vient de commander</span></div>\n</div>\n\n<script>\n(function(){\n\nwindow.addToCart = function() {\n  window.location.href = \"/cart\";\n};\n\nvar gallery = {\n  \"noir\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\",alt:\"Noir 1\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_142202_2505abc6-1f9d-4225-8941-b8cd2f3aff86.png?v=1775399077\",alt:\"Noir 2\"}\n  ],\n  \"beige\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715\",alt:\"Beige 1\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151814_eff117f5-d9e6-4d53-9776-1ffff80aa2fd.png?v=1775402484\",alt:\"Beige 2\"}\n  ],\n  \"orange\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\",alt:\"Orange 1\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/Capture_d_ecran_2026-04-05_a_18.06.28.png?v=1775405214\",alt:\"Orange 2\"}\n  ]\n};\n\nfunction buildGallery(color) {\n  var imgs = gallery[color] || gallery[\"noir\"];\n  var track = document.getElementById(\"galleryTrack\");\n  var dots = document.getElementById(\"galleryDots\");\n  var thumbs = document.getElementById(\"galleryThumbs\");\n  if(!track) return;\n  track.innerHTML = \"\"; dots.innerHTML = \"\"; thumbs.innerHTML = \"\";\n  imgs.forEach(function(img, i) {\n    var slide = document.createElement(\"div\"); slide.className = \"gallery-slide\";\n    slide.innerHTML = '<img src=\"'+img.src+'\">';\n    track.appendChild(slide);\n    var dot = document.createElement(\"div\"); dot.className = \"g-dot\"+(i===0?\" active\":\"\");\n    dot.onclick = function(){ track.scrollTo({left: i * track.offsetWidth, behavior:\"smooth\"}); };\n    dots.appendChild(dot);\n    var th = document.createElement(\"div\"); th.className = \"g-thumb\"+(i===0?\" active\":\"\");\n    th.innerHTML = '<img src=\"'+img.src+'\">';\n    th.onclick = function(){ track.scrollTo({left: i * track.offsetWidth, behavior:\"smooth\"}); };\n    thumbs.appendChild(th);\n  });\n}\n\nwindow.selectColor = function(color, label, btn) {\n  document.querySelectorAll(\".c-btn\").forEach(b => b.classList.remove(\"active\"));\n  btn.classList.add(\"active\");\n  document.getElementById(\"color-name\").textContent = label;\n  buildGallery(color);\n};\n\nvar now = new Date();\ndocument.getElementById(\"d-date1\").textContent = now.getDate() + \"/\" + (now.getMonth()+1);\nvar d3 = new Date(); d3.setDate(now.getDate() + 4);\ndocument.getElementById(\"d-date3\").textContent = d3.getDate() + \"/\" + (d3.getMonth()+1);\n\nwindow.addEventListener(\"scroll\", function(){\n  var bar = document.getElementById(\"stickyBar\");\n  var card = document.getElementById(\"offerCard\");\n  if(card && bar) {\n    if(card.getBoundingClientRect().bottom < 0) bar.classList.add(\"visible\");\n    else bar.classList.remove(\"visible\");\n  }\n});\n\nvar names = [\"Thomas\", \"Marie\", \"Lucas\", \"Julie\", \"Enzo\"];\nsetInterval(function(){\n  var p = document.getElementById(\"purchasePopup\");\n  if(p) {\n    document.getElementById(\"popupName\").textContent = names[Math.floor(Math.random()*names.length)];\n    document.getElementById(\"popupImg\").src = gallery.noir[0].src;\n    p.classList.add(\"show\");\n    setTimeout(() => p.classList.remove(\"show\"), 4000);\n  }\n}, 15000);\n\nbuildGallery(\"noir\");\n})();\n</script>\n</body>\n</html>\n\n{% endif %}",
