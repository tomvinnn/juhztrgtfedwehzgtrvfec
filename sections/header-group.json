\">\n  <p class=\"section-label\" style=\"margin-bottom:4px;\">FAQ</p>\n  <h2 style=\"font-family:var(--font-serif);font-size:22px;font-weight:300;margin-bottom:16px;\">Questions fréquentes</h2>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Compatible avec mon téléphone ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Compatible iPhone (iOS 9+) et Android (5.0+).</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Quelle autonomie ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">5 à 7 jours en usage normal.</div></div>\n</div>\n\n<footer>\n  <div class=\"footer-logo\">IA High Tec Shop</div>\n  <div class=\"footer-links\">\n    <a href=\"#\">Confidentialité</a>\n    <a href=\"#\">Conditions</a>\n  </div>\n  <div class=\"footer-copy\">© 2026 IA High Tec Shop — Tous droits réservés</div>\n</footer>\n\n<div class=\"purchase-popup\" id=\"purchasePopup\">\n  <img class=\"popup-img\" id=\"popupImg\" src=\"\" alt=\"\">\n  <div class=\"popup-text\">\n    <strong id=\"popupName\"></strong>\n    <span id=\"popupText\"></span>\n  </div>\n  <div class=\"popup-dot\"></div>\n</div>\n\n<div class=\"sticky-bar\" id=\"stickyBar\">\n  <div class=\"sticky-price\">\n    <div class=\"sticky-price-now\">64,90 €</div>\n    <div class=\"sticky-price-old\">129,90 €</div>\n  </div>\n  <button class=\"sticky-btn\" onclick=\"addToCart()\">Ajouter au panier</button>\n</div>\n\n<script>\n(function(){\n\n/* LIEN DU PANIER */\nvar CART_URL = \"https://iatechshop.myshopify.com/cart\"; \n// Note : J'ai utilisé l'URL publique /cart pour être sûr que cela fonctionne pour le client. \n// Si vous voulez l'URL de l'admin spécifique, remplacez par la vôtre ci-dessous.\n\nvar gallery = {\n  \"noir\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\",alt:\"Noir 1\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_142202_2505abc6-1f9d-4225-8941-b8cd2f3aff86.png?v=1775399077\",alt:\"Noir 2\"}\n  ],\n  \"beige\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715\",alt:\"Beige 1\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151814_eff117f5-d9e6-4d53-9776-1ffff80aa2fd.png?v=1775402484\",alt:\"Beige 2\"}\n  ],\n  \"orange\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\",alt:\"Orange 1\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/Capture_d_ecran_2026-04-05_a_18.06.28.png?v=1775405214\",alt:\"Orange 2\"}\n  ]\n};\n\nfunction buildGallery(color) {\n  var imgs = gallery[color] || gallery[\"noir\"];\n  var track = document.getElementById(\"galleryTrack\");\n  var dots = document.getElementById(\"galleryDots\");\n  var thumbs = document.getElementById(\"galleryThumbs\");\n  if(!track) return;\n  track.innerHTML = \"\"; dots.innerHTML = \"\"; thumbs.innerHTML = \"\";\n  imgs.forEach(function(img, i) {\n    var slide = document.createElement(\"div\"); slide.className = \"gallery-slide\";\n    var im = document.createElement(\"img\"); im.src = img.src; im.alt = img.alt;\n    slide.appendChild(im); track.appendChild(slide);\n    var dot = document.createElement(\"div\"); dot.className = \"g-dot\" + (i===0?\" active\":\"\");\n    dot.onclick = function(){ goToSlide(i); }; dots.appendChild(dot);\n    var th = document.createElement(\"div\"); th.className = \"g-thumb\" + (i===0?\" active\":\"\");\n    th.onclick = function(){ goToSlide(i); };\n    var tim = document.createElement(\"img\"); tim.src = img.src; th.appendChild(tim); thumbs.appendChild(th);\n  });\n}\n\nfunction goToSlide(idx) {\n  var track = document.getElementById(\"galleryTrack\");\n  track.scrollTo({left: idx * track.offsetWidth, behavior:\"smooth\"});\n}\n\nwindow.selectColor = function(color, label, btn) {\n  document.querySelectorAll(\".c-btn\").forEach(function(b){b.classList.remove(\"active\");});\n  btn.classList.add(\"active\");\n  document.getElementById(\"color-name\").textContent = label;\n  buildGallery(color);\n};\n\nwindow.changeQty = function(d) {\n  var qEl = document.getElementById(\"qty\");\n  var cur = parseInt(qEl.textContent);\n  qEl.textContent = Math.max(1, cur + d);\n};\n\n/* REDIRECTION PANIER */\nwindow.addToCart = function() {\n  window.location.href = \"https://admin.shopify.com/store/iatechshop/themes/189630316810/editor?previewMode=mobile&previewPath=%2Fcart\";\n};\n\n/* Dates */\n(function(){\n  var now=new Date();\n  var d1=new Date(now);\n  var d3=new Date(now); d3.setDate(now.getDate()+4);\n  document.getElementById(\"d-date1\").textContent = d1.getDate() + \"/\" + (d1.getMonth()+1);\n  document.getElementById(\"d-date3\").textContent = d3.getDate() + \"/\" + (d3.getMonth()+1);\n})();\n\n/* Timer */\nfunction updateTimer(){\n  var now = new Date();\n  var h = 23 - now.getHours();\n  var m = 59 - now.getMinutes();\n  var s = 59 - now.getSeconds();\n  document.getElementById(\"ot-h\").textContent = String(h).padStart(2,'0');\n  document.getElementById(\"ot-m\").textContent = String(m).padStart(2,'0');\n  document.getElementById(\"ot-s\").textContent = String(s).padStart(2,'0');\n}\nsetInterval(updateTimer, 1000); updateTimer();\n\n/* FAQ */\nwindow.toggleFaq = function(btn){ btn.parentElement.classList.toggle(\"open\"); };\n\n/* Sticky bar visibility */\nwindow.addEventListener(\"scroll\", function(){\n  var oc = document.getElementById(\"offerCard\");\n  var sb = document.getElementById(\"stickyBar\");\n  if(oc && sb) sb.classList.toggle(\"visible\", oc.getBoundingClientRect().bottom < 0);\n});\n\n/* Reviews Track */\nvar trackR = document.getElementById(\"reviewsTrack\");\nif(trackR){\n  var content = '<div class=\"review-card\"><div class=\"rv-stars\">★★★★★</div><p class=\"rv-text\">Génial !</p><div class=\"rv-footer\"><div class=\"rv-avatar\">JD</div><div class=\"rv-name\">Jean D.</div></div></div>';\n  trackR.innerHTML = content.repeat(10);\n}\n\nbuildGallery(\"noir\");\n})();\n</script>\n</body>\n</html>",
