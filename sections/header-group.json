a-3e60fe7b8584.png?v=1775399323\",alt:\"Smart Watch 2.0 Noir 3\"}\n  ],\n  \"beige\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715\",alt:\"Smart Watch 2.0 Beige\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151814_eff117f5-d9e6-4d53-9776-1ffff80aa2fd.png?v=1775402484\",alt:\"Smart Watch 2.0 Beige 2\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151832_fed8dba2-5391-4fb3-8cc3-87009047c73b.png?v=1775402490\",alt:\"Smart Watch 2.0 Beige 3\"}\n  ],\n  \"orange\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\",alt:\"Smart Watch 2.0 Orange\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/Capture_d_ecran_2026-04-05_a_18.06.28.png?v=1775405214\",alt:\"Smart Watch 2.0 Orange 2\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/Capture_d_ecran_2026-04-05_a_17.30.59.png?v=1775403076\",alt:\"Smart Watch 2.0 Orange 3\"}\n  ]\n};\n\nfunction buildGallery(color) {\n  var imgs = gallery[color] || gallery[\"noir\"];\n  var track = document.getElementById(\"galleryTrack\");\n  var dots  = document.getElementById(\"galleryDots\");\n  var thumbs = document.getElementById(\"galleryThumbs\");\n  track.innerHTML = \"\"; dots.innerHTML = \"\"; thumbs.innerHTML = \"\";\n  imgs.forEach(function(img, i) {\n    var slide = document.createElement(\"div\"); slide.className = \"gallery-slide\";\n    var im = document.createElement(\"img\"); im.src = img.src; im.alt = img.alt;\n    slide.appendChild(im); track.appendChild(slide);\n    var dot = document.createElement(\"div\");\n    dot.className = \"g-dot\" + (i===0?\" active\":\"\");\n    dot.onclick = (function(idx){return function(){goToSlide(idx);};})(i);\n    dots.appendChild(dot);\n    var th = document.createElement(\"div\");\n    th.className = \"g-thumb\" + (i===0?\" active\":\"\");\n    th.onclick = (function(idx){return function(){goToSlide(idx);};})(i);\n    var tim = document.createElement(\"img\"); tim.src = img.src; tim.alt = img.alt;\n    th.appendChild(tim); thumbs.appendChild(th);\n  });\n  currentSlide = 0;\n  track.onscroll = function() {\n    var idx = Math.round(track.scrollLeft / (track.offsetWidth||1));\n    if(idx !== currentSlide){currentSlide = idx; updateGalleryUI();}\n  };\n}\nfunction goToSlide(idx) {\n  var track = document.getElementById(\"galleryTrack\");\n  track.scrollTo({left: idx * track.offsetWidth, behavior:\"smooth\"});\n  currentSlide = idx; updateGalleryUI();\n}\nfunction updateGalleryUI() {\n  document.querySelectorAll(\".g-dot\").forEach(function(d,i){d.classList.toggle(\"active\",i===currentSlide);});\n  document.querySelectorAll(\".g-thumb\").forEach(function(t,i){t.classList.toggle(\"active\",i===currentSlide);});\n}\n\nwindow.selectColor = function(color, label, btn) {\n  document.querySelectorAll(\".c-btn\").forEach(function(b){b.classList.remove(\"active\");});\n  btn.classList.add(\"active\");\n  document.getElementById(\"color-name\").textContent = label;\n  currentColor = color;\n  buildGallery(color);\n};\n\nwindow.changeQty = function(d) {\n  qty = Math.max(1, qty + d);\n  document.getElementById(\"qty\").textContent = qty;\n};\n\nwindow.addToCart = function() {\n  window.location.href = \"https://iatechshop.myshopify.com/cart\";\n};\n\n/* ── Delivery dates (today + 1 + 3~4 days) ── */\n(function(){\n  var months=[\"Jan\",\"Fév\",\"Mar\",\"Avr\",\"Mai\",\"Jun\",\"Jul\",\"Aoû\",\"Sep\",\"Oct\",\"Nov\",\"Déc\"];\n  var now=new Date();\n  function fmt(d){return d.getDate()+\" \"+months[d.getMonth()];}\n  var d1=new Date(now); // today\n  var d2=new Date(now); d2.setDate(d2.getDate()+1);\n  var d3a=new Date(now); d3a.setDate(d3a.getDate()+3);\n  var d3b=new Date(now); d3b.setDate(d3b.getDate()+4);\n  var e1=document.getElementById(\"d-date1\");\n  var e2=document.getElementById(\"d-date2\");\n  var e3=document.getElementById(\"d-date3\");\n  if(e1) e1.textContent=fmt(d1);\n  if(e2) e2.textContent=fmt(d2);\n  if(e3) e3.textContent=fmt(d3a)+\" – \"+fmt(d3b);\n})();\n\n/* ── Offer timer (countdown to midnight tonight) ── */\nfunction updateOfferTimer(){\n  var now=new Date();\n  var midnight=new Date(now); midnight.setHours(24,0,0,0);\n  var diff=Math.floor((midnight-now)/1000);\n  if(diff<0) diff=0;\n  var h=Math.floor(diff/3600);\n  var m=Math.floor((diff%3600)/60);\n  var s=diff%60;\n  var eh=document.getElementById(\"ot-h\"),em=document.getElementById(\"ot-m\"),es=document.getElementById(\"ot-s\");\n  if(eh) eh.textContent=String(h).padStart(2,\"0\");\n  if(em) em.textContent=String(m).padStart(2,\"0\");\n  if(es) es.textContent=String(s).padStart(2,\"0\");\n}\nupdateOfferTimer(); setInterval(updateOfferTimer,1000);\n\n/* FAQ */\nwindow.toggleFaq = function(btn){ btn.parentElement.classList.toggle(\"open\"); };\n\n/* Sticky */\nvar stickyBar = document.getElementById(\"stickyBar\");\nvar offerCard = document.getElementById(\"offerCard\");\nwindow.addEventListener(\"scroll\", function(){\n  if(!stickyBar||!offerCard) return;\n  stickyBar.classList.toggle(\"visible\", offerCard.getBoundingClientRect().bottom < 0);\n},{passive:true});\n\n/* Reviews */\nvar reviews = [\n  {name:\"Lucas M.\",initials:\"LM\",date:\"Il y a 1 jour\",text:\"Je n'espérais pas une telle qualité à ce prix. L'écran est net, la montre est légère.\"},\n  {name:\"Isabelle P.\",initials:\"IP\",date:\"Il y a 2 jours\",text:\"Offert à ma fille. Elle l'adore. Livraison ultra rapide. Je recommande sans hésiter.\"},\n  {name:\"Romain C.\",initials:\"RC\",date:\"Il y a 3 jours\",text:\"Le suivi du sommeil est top. Répondre aux appels depuis mon poignet, ça change la vie.\"},\n  {name:\"Mathieu F.\",initials:\"MF\",date:\"Il y a 5 jours\",text:\"Commandé mercredi soir, reçu vendredi matin. Emballage soigné, produit conforme.\"},\n  {name:\"Sophie L.\",initials:\"SL\",date:\"Il y a 1 semaine\",text:\"Portée tous les jours depuis 3 semaines. Pas un seul bug, pas une seule déception.\"},\n  {name:\"Antoine L.\",initials:\"AL\",date:\"Il y a 1 semaine\",text:\"La batterie tient 5-6 jours. Pour moi qui oublie de charger, c'est une révolution.\"},\n  {name:\"Pierre K.\",initials:\"PK\",date:\"Il y a 10 jours\",text:\"J'ai remplacé une montre deux fois plus chère. La Smart Watch fait exactement la même chose.\"},\n  {name:\"Emma D.\",initials:\"ED\",date:\"Il y a 2 semaines\",text:\"Un cadeau pour mon copain. Il m'a dit que c'était le meilleur cadeau reçu.\"},\n  {name:\"Julien B.\",initials:\"JB\",date:\"Il y a 2 semaines\",text:\"SMS et appels depuis la montre, ça change la vie au sport.\"},\n  {name:\"Marie D.\",initials:\"MD\",date:\"Il y a 3 semaines\",text:\"Cadeau parfait pour mon mari. Il l'a plus quittée. Je recommande les yeux fermés.\"}\n];\nvar track = document.getElementById(\"reviewsTrack\");\nif(track){\n  var html=\"\";\n  for(var p=0;p<2;p++){\n    reviews.forEach(function(r){\n      html+='<div class=\"review-card\"><div class=\"rv-stars\">★★★★★</div><p class=\"rv-text\">'+r.text+'</p><div class=\"rv-footer\"><div class=\"rv-avatar\">'+r.initials+'</div><div><div class=\"rv-name\">'+r.name+'</div><div class=\"rv-verified\">✓ Avis vérifié</div></div></div></div>';\n    });\n  }\n  track.innerHTML=html;\n}\n\n/* ── Purchase popup ── */\nvar popupPeople=[\n  {name:\"Jules\",color:\"orange\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151709_45180f29-8c0a-4bb0-bd68-627ab5bcef21.png?v=1775402491\",text:\"vient de commander — Orange\"},\n  {name:\"Thomas\",color:\"noir\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_142202_2505abc6-1f9d-4225-8941-b8cd2f3aff86.png?v=1775399077\",text:\"vient de commander — Noir\"},\n  {name:\"Maxime\",color:\"beige\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151814_1ec98acd-326e-4dae-a804-cc046a2ad162.png?v=1775402651\",text:\"vient de commander — Beige\"},\n  {name:\"Lucas\",color:\"orange\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151709_45180f29-8c0a-4bb0-bd68-627ab5bcef21.png?v=1775402491\",text:\"s'est offert la Smart Watch — Orange\"},\n  {name:\"Enzo\",color:\"noir\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_142202_2505abc6-1f9d-4225-8941-b8cd2f3aff86.png?v=1775399077\",text:\"vient de commander — Noir\"},\n  {name:\"Nathan\",color:\"beige\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151814_1ec98acd-326e-4dae-a804-cc046a2ad162.png?v=1775402651\",text:\"a choisi le modèle Beige\"},\n  {name:\"Hugo\",color:\"orange\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151709_45180f29-8c0a-4bb0-bd68-627ab5bcef21.png?v=1775402491\",text:\"vient de commander — Orange\"},\n  {name:\"Mathis\",color:\"noir\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_142202_2505abc6-1f9d-4225-8941-b8cd2f3aff86.png?v=1775399077\",text:\"a pris la version Noir\"},\n  {name:\"Théo\",color:\"beige\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151814_1ec98acd-326e-4dae-a804-cc046a2ad162.png?v=1775402651\",text:\"vient de commander — Beige\"},\n  {name:\"Antoine\",color:\"orange\",img:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151709_45180f29-8c0a-4bb0-bd68-627ab5bcef21.png?v=1775402491\",text:\"s'est offert la Smart Watch — Orange\"}\n];\nvar popupIdx=0;\nvar popupEl=document.getElementById(\"purchasePopup\");\nvar popupImgEl=document.getElementById(\"popupImg\");\nvar popupNameEl=document.getElementById(\"popupName\");\nvar popupTextEl=document.getElementById(\"popupText\");\nfunction showPopup(){\n  var p=popupPeople[popupIdx%popupPeople.length]; popupIdx++;\n  if(popupImgEl) popupImgEl.src=p.img;\n  if(popupNameEl) popupNameEl.textContent=p.name;\n  if(popupTextEl) popupTextEl.textContent=p.text;\n  if(popupEl){\n    popupEl.classList.add(\"show\");\n    setTimeout(function(){popupEl.classList.remove(\"show\");},4000);\n  }\n}\nsetTimeout(function(){\n  showPopup();\n  setInterval(showPopup,19000);\n},5000);\n\n/* Init */\nbuildGallery(\"noir\");\n})();\n</script>\n</body>\n</html>",
