   <span class=\"offer-timer-label\">Expire dans</span>\n      <div class=\"offer-timer-blocks\">\n        <div class=\"offer-timer-unit\">\n          <span class=\"offer-timer-num\" id=\"t-min\">05</span>\n          <span class=\"offer-timer-sub\">min</span>\n        </div>\n        <div class=\"offer-timer-sep\">:</div>\n        <div class=\"offer-timer-unit\">\n          <span class=\"offer-timer-num\" id=\"t-sec\">00</span>\n          <span class=\"offer-timer-sub\">sec</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"offer-perks\">\n      <span class=\"offer-perk\">🚚 Livraison offerte</span>\n      <span class=\"offer-perk\">↩️ 60j remboursé</span>\n      <span class=\"offer-perk\">+ 3 bracelets</span>\n    </div>\n  </div>\n\n  <div class=\"sep\"></div>\n\n  <!-- BENEFITS -->\n  <ul class=\"benefits\">\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Compact et élégant — design ultra-fin</li>\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Traque ta santé en temps réel (cœur, SpO2, sommeil)</li>\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Durable et robuste — résistante à l'eau IP67</li>\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Compatible iPhone &amp; Android</li>\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Appels &amp; SMS directement depuis le poignet</li>\n  </ul>\n\n  <!-- STOCK -->\n  <div class=\"stock-line\">\n    <div class=\"stock-dot\"></div>\n    Stock restant : 12 Smart Watch uniquement\n  </div>\n\n  <div class=\"sep\"></div>\n\n  <!-- COLOR -->\n  <p class=\"color-label\">Couleur de la montre : <strong id=\"color-name\">Gris</strong></p>\n  <div class=\"color-options\">\n    <button class=\"color-btn active\" onclick=\"selectColor('gris','Gris',this)\">Gris</button>\n    <button class=\"color-btn\" onclick=\"selectColor('noir','Noir',this)\">Noir</button>\n    <button class=\"color-btn\" onclick=\"selectColor('orange','Orange',this)\">Orange</button>\n  </div>\n\n  <!-- QTY -->\n  <div class=\"qty-row\">\n    <span class=\"qty-label\">Quantité</span>\n    <div class=\"qty-ctrl\">\n      <button class=\"qty-btn\" onclick=\"changeQty(-1)\">−</button>\n      <span class=\"qty-val\" id=\"qty\">1</span>\n      <button class=\"qty-btn\" onclick=\"changeQty(1)\">+</button>\n    </div>\n  </div>\n\n  <!-- CTA -->\n  <a href=\"#\" class=\"cta-btn\">🔒 Commander Ma Smart Watch 2.0</a>\n  <div class=\"secure-note\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0110 0v4\"/></svg>\n    Paiement 100% sécurisé · SSL\n  </div>\n  <div class=\"payment-icons\">\n    <span class=\"payment-icon\">VISA</span>\n    <span class=\"payment-icon\">MC</span>\n    <span class=\"payment-icon\">AMEX</span>\n    <span class=\"payment-icon\">PAYPAL</span>\n    <span class=\"payment-icon\">APPLE PAY</span>\n  </div>\n</div>\n\n<!-- TRUST ROW -->\n<div class=\"trust-row\">\n  <div class=\"trust-item\">\n    <div class=\"trust-icon-sm\">🛡️</div>\n    <div class=\"trust-text\">Garantie<br>12 mois</div>\n  </div>\n  <div class=\"trust-item\">\n    <div class=\"trust-icon-sm\">↩️</div>\n    <div class=\"trust-text\">Retour<br>60 jours</div>\n  </div>\n  <div class=\"trust-item\">\n    <div class=\"trust-icon-sm\">🚚</div>\n    <div class=\"trust-text\">Livraison<br>gratuite</div>\n  </div>\n  <div class=\"trust-item\">\n    <div class=\"trust-icon-sm\">💬</div>\n    <div class=\"trust-text\">Support<br>24h/24</div>\n  </div>\n</div>\n\n<!-- FEATURES -->\n<div class=\"features\">\n  <div class=\"feature-block\">\n    <div class=\"feature-img\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960\" alt=\"Suivi santé\">\n    </div>\n    <p class=\"feature-tag\">Suivi santé complet</p>\n    <h3 class=\"feature-title\">Ton corps. Sous surveillance constante.</h3>\n    <p class=\"feature-desc\">Fréquence cardiaque, saturation en oxygène (SpO2), qualité du sommeil, calories, pas — tout est mesuré en continu. La Smart Watch 2.0 t'alerte avant même que tu ne ressentes quelque chose.</p>\n  </div>\n  <div class=\"feature-block\">\n    <div class=\"feature-img\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\" alt=\"Appels SMS\">\n    </div>\n    <p class=\"feature-tag\">Connectivité totale</p>\n    <h3 class=\"feature-title\">Appels, SMS, notifs. Sans toucher ton téléphone.</h3>\n    <p class=\"feature-desc\">Réponds à tes appels et messages directement depuis ton poignet. Compatible iPhone et Android, elle te garde connecté partout, en toute discrétion.</p>\n  </div>\n  <div class=\"feature-block\">\n    <div class=\"feature-img\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\" alt=\"Design robuste\">\n    </div>\n    <p class=\"feature-tag\">Construction premium</p>\n    <h3 class=\"feature-title\">Robuste. Résistante. Faite pour durer.</h3>\n    <p class=\"feature-desc\">Résistance à l'eau IP67, verre minéral traité anti-rayures, boîtier en alliage aluminium. La Smart Watch 2.0 encaisse autant que toi.</p>\n  </div>\n</div>\n\n<!-- STATS -->\n<div class=\"stats-grid\">\n  <div class=\"stat-card\"><div class=\"stat-num\">+8 000</div><div class=\"stat-label\">clients satisfaits</div></div>\n  <div class=\"stat-card\"><div class=\"stat-num\">60j</div><div class=\"stat-label\">satisfait ou remboursé</div></div>\n  <div class=\"stat-card\"><div class=\"stat-num\">IP67</div><div class=\"stat-label\">résistance à l'eau</div></div>\n  <div class=\"stat-card\"><div class=\"stat-num\">98%</div><div class=\"stat-label\">clients satisfaits</div></div>\n</div>\n\n<!-- REVIEWS -->\n<div class=\"section-label\">Ils en parlent mieux que nous…</div>\n<div class=\"section-title\">Vos avis parlent <em>d'eux-mêmes.</em></div>\n<div class=\"reviews-scroll\">\n  <div class=\"review-card\">\n    <div class=\"review-stars\">★★★★★</div>\n    <div class=\"review-text\">La qualité est au rendez-vous. Je m'attendais pas à ça pour ce prix.</div>\n    <div class=\"review-author\"><div class=\"review-avatar\">TM</div><div><div class=\"review-name\">Thomas M.</div><div class=\"review-date\">Il y a 2 jours</div></div></div>\n  </div>\n  <div class=\"review-card\">\n    <div class=\"review-stars\">★★★★★</div>\n    <div class=\"review-text\">Reçu en 3 jours, livraison soignée. La montre est vraiment belle en vrai.</div>\n    <div class=\"review-author\"><div class=\"review-avatar\">SL</div><div><div class=\"review-name\">Sophie L.</div><div class=\"review-date\">Il y a 4 jours</div></div></div>\n  </div>\n  <div class=\"review-card\">\n    <div class=\"review-stars\">★★★★★</div>\n    <div class=\"review-text\">Le suivi du sommeil est bluffant. Je la porte même la nuit tellement elle est légère.</div>\n    <div class=\"review-author\"><div class=\"review-avatar\">KR</div><div><div class=\"review-name\">Kevin R.</div><div class=\"review-date\">Il y a 1 semaine</div></div></div>\n  </div>\n  <div class=\"review-card\">\n    <div class=\"review-stars\">★★★★★</div>\n    <div class=\"review-text\">J'ai acheté pour mon mari, il l'a plus quittée depuis. Cadeau parfait.</div>\n    <div class=\"review-author\"><div class=\"review-avatar\">MD</div><div><div class=\"review-name\">Marie D.</div><div class=\"review-date\">Il y a 10 jours</div></div></div>\n  </div>\n  <div class=\"review-card\">\n    <div class=\"review-stars\">★★★★★</div>\n    <div class=\"review-text\">Appels et SMS directement depuis la montre, ça change la vie au sport.</div>\n    <div class=\"review-author\"><div class=\"review-avatar\">JB</div><div><div class=\"review-name\">Julien B.</div><div class=\"review-date\">Il y a 2 semaines</div></div></div>\n  </div>\n</div>\n\n<!-- LIFESTYLE -->\n<div class=\"lifestyle-strip\">\n  <img class=\"lifestyle-img\" src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960\" alt=\"\">\n  <img class=\"lifestyle-img\" src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\" alt=\"\">\n  <img class=\"lifestyle-img\" src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\" alt=\"\">\n</div>\n\n<!-- 2e CTA -->\n<div style=\"padding: 0 24px; margin-bottom: 40px;\">\n  <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;\">\n    <div>\n      <div style=\"font-size:32px;font-weight:800;\">64,90 €</div>\n      <div style=\"font-size:14px;color:var(--gray-400);text-decoration:line-through;\">129,90 €</div>\n    </div>\n    <div style=\"text-align:right;\">\n      <div style=\"font-size:12px;color:var(--gray-500);margin-bottom:4px;\">★★★★★ 312 avis</div>\n      <div style=\"font-size:12px;color:var(--red);font-weight:700;\">Stock : 12 restantes</div>\n    </div>\n  </div>\n  <a href=\"#\" class=\"cta-btn\">🔒 Commander Ma Smart Watch 2.0</a>\n  <div class=\"secure-note\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0110 0v4\"/></svg>\n    Paiement 100% sécurisé · Livraison offerte\n  </div>\n</div>\n\n<!-- FAQ -->\n<div style=\"padding: 0 24px; margin-bottom: 14px;\">\n  <p class=\"feature-tag\" style=\"margin-bottom:6px;\">Questions fréquentes</p>\n  <h2 style=\"font-size:26px;font-weight:800;line-height:1.2;margin-bottom:22px;\">Tout ce que vous devez savoir <em style=\"font-weight:300;font-style:italic;\">avant de commander</em></h2>\n</div>\n<div class=\"faq-wrap\" id=\"avis-clients\">\n  <div class=\"faq-item\">\n    <button class=\"faq-q\" onclick=\"toggleFaq(this)\">La Smart Watch 2.0 est-elle compatible avec mon téléphone ?<span class=\"faq-icon\">+</span></button>\n    <div class=\"faq-a\">Oui. Compatible avec tous les iPhone (iOS 9+) et smartphones Android (5.0+). Connexion Bluetooth stable, synchronisation en quelques secondes via l'application gratuite.</div>\n  </div>\n  <div class=\"faq-item\">\n    <button class=\"faq-q\" onclick=\"toggleFaq(this)\">Est-ce que je peux vraiment passer des appels depuis la montre ?<span class=\"faq-icon\">+</span></button>\n    <div class=\"faq-a\">Absolument. Microphone et haut-parleur intégrés. Quand ton téléphone est à portée Bluetooth, tu peux décrocher, parler et raccrocher directement depuis ton poignet.</div>\n  </div>\n  <div class=\"faq-item\">\n    <button class=\"faq-q\" onclick=\"toggleFaq(this)\">Quelle est l'autonomie de la batterie ?<span class=\"faq-icon\">+</span></button>\n    <div class=\"faq-a\">Entre 5 et 7 jours en utilisation normale. Avec le suivi santé actif en continu, comptez 3 à 4 jours. Recharge complète en moins de 2 heures via le chargeur magnétique inclus.</div>\n  </div>\n  <div class=\"faq-item\">\n    <button class=\"faq-q\" onclick=\"toggleFaq(this)\">Elle résiste à l'eau ? Je peux la porter sous la douche ?<span class=\"faq-icon\">+</span></button>\n    <div class=\"faq-a\">Oui, certifiée IP67 — supporte une immersion jusqu'à 1 mètre pendant 30 minutes. Sous la douche et par temps de pluie, aucun problème. On déconseille en revanche la piscine ou la mer.</div>\n  </div>\n  <div class=\"faq-item\">\n    <button class=\"faq-q\" onclick=\"toggleFaq(this)\">Quelle est la politique de retour ?<span class=\"faq-icon\">+</span></button>\n    <div class=\"faq-a\">60 jours pour la retourner sans aucune justification. Remboursement 100% intégral frais de livraison inclus. En cas de produit défectueux à réception : remplacement immédiat sans retour préalable.</div>\n  </div>\n  <div class=\"faq-item\">\n    <button class=\"faq-q\" onclick=\"toggleFaq(this)\">Le prix −50% va-t-il remonter après le live ?<span class=\"faq-icon\">+</span></button>\n    <div class=\"faq-a\">Oui. Le prix de <strong>64,90 €</strong> (au lieu de 129,90 €) est exclusivement réservé aux spectateurs du live. Une fois le timer écoulé, la remise ne peut plus être appliquée rétroactivement.</div>\n  </div>\n</div>\n\n<!-- TRUSTPILOT -->\n<div class=\"tp-wrap\">\n  <div class=\"tp-header\">\n    <div class=\"tp-logo\">Trustpilot</div>\n    <div class=\"tp-score\">4,8 <span>/ 5</span></div>\n  </div>\n  <div class=\"tp-global-stars\">★★★★★</div>\n  <p style=\"font-size:12px;color:var(--gray-500);margin-bottom:22px;\">Basé sur <a href=\"#\" style=\"color:var(--gray-500);\">312 avis vérifiés</a></p>\n  <div class=\"tp-card\">\n    <div class=\"tp-card-stars\">★★★★★</div>\n    <div class=\"tp-card-date\">Il y a 1 jour</div>\n    <div class=\"tp-card-text\">Je n'espérais pas une telle qualité à ce prix. Dès que je l'ai sortie du colis j'ai été bluffé. L'écran est net, la montre est légère et les fonctions de santé fonctionnent vraiment.</div>\n    <div class=\"tp-card-name\">Lucas M.</div>\n  </div>\n  <div class=\"tp-card\">\n    <div class=\"tp-card-stars\">★★★★★</div>\n    <div class=\"tp-card-date\">Il y a 2 jours</div>\n    <div class=\"tp-card-text\">Offert à ma fille pour son anniversaire. Elle l'adore. La couleur orange est magnifique et la livraison a été ultra rapide. Je recommande sans hésiter.</div>\n    <div class=\"tp-card-name\">Isabelle P.</div>\n  </div>\n  <div class=\"tp-card\">\n    <div class=\"tp-card-stars\">★★★★★</div>\n    <div class=\"tp-card-date\">Il y a 3 jours</div>\n    <div class=\"tp-card-text\">Le suivi du sommeil est top. Et pouvoir répondre aux appels depuis mon poignet à la salle de sport, ça change vraiment la vie. Aucun regret.</div>\n    <div class=\"tp-card-name\">Romain C.</div>\n  </div>\n  <div class=\"tp-card\">\n    <div class=\"tp-card-stars\">★★★★★</div>\n    <div class=\"tp-card-date\">Il y a 5 jours</div>\n    <div class=\"tp-card-text\">Commandé un mercredi soir, reçu le vendredi matin. Emballage soigné, produit conforme aux photos. La montre est solide, le bracelet est confortable. Très satisfait.</div>\n    <div class=\"tp-card-name\">Mathieu F.</div>\n  </div>\n  <div class=\"tp-card\">\n    <div class=\"tp-card-stars\">★★★★★</div>\n    <div class=\"tp-card-date\">Il y a 1 semaine</div>\n    <div class=\"tp-card-text\">Ça fait un mois que je la porte tous les jours. Pas une seule fois elle a eu un bug. Le jour où j'ai reçu le colis je me suis dit pourquoi j'ai pas fait ça avant.</div>\n    <div class=\"tp-card-name\">Antoine L.</div>\n  </div>\n  <div class=\"tp-card\">\n    <div class=\"tp-card-stars\">★★★★★</div>\n    <div class=\"tp-card-date\">Il y a 2 semaines</div>\n    <div class=\"tp-card-text\">J'ai remplacé une montre deux fois plus chère. La Smart Watch 2.0 fait exactement la même chose. SAV au top, ils ont répondu à mon message en 20 minutes.</div>\n    <div class=\"tp-card-name\">Pierre-Antoine K.</div>\n  </div>\n  <p class=\"tp-verified\">Avis collectés et vérifiés par Trustpilot</p>\n</div>\n\n<!-- FOOTER -->\n<div class=\"footer\">\n  <div class=\"footer-logo\">IA High Tec Shop</div>\n  <div class=\"footer-links\">\n    <a href=\"#\">Confidentialité</a>\n    <a href=\"#\">Remboursement</a>\n    <a href=\"#\">CGV</a>\n    <a href=\"#\">Livraison</a>\n    <a href=\"#\">Contact</a>\n  </div>\n  <div class=\"footer-badges\">\n    <span>🔒 Paiement sécurisé</span>\n    <span>↩️ 60j remboursé</span>\n    <span>🇫🇷 Support FR</span>\n  </div>\n  <div class=\"footer-copy\">© 2026 IA High Tec Shop — Tous droits réservés</div>\n</div>\n\n<script>\n  const gallery = {\n    gris: [\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960', alt: 'Smart Watch 2.0 Gris' },\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715', alt: 'Smart Watch 2.0 Gris détail' }\n    ],\n    noir: [\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/O1CN017e2Cmp2Dtzw4Yz7qK__2207705038668-0-cib_0a846c84-0535-4e84-9d6a-76f57b54b198.webp?v=1732348989', alt: 'Smart Watch 2.0 Noir' },\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713', alt: 'Smart Watch 2.0 Noir détail' }\n    ],\n    orange: [\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/O1CN017e2Cmp2Dtzw4Yz7qK__2207705038668-0-cib_0a846c84-0535-4e84-9d6a-76f57b54b198.webp?v=1732348989', alt: 'Smart Watch 2.0 Orange' },\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715', alt: 'Smart Watch 2.0 Orange détail' }\n    ]\n  };\n\n  let currentColor = 'gris';\n  let currentIdx = 0;\n\n  function renderGallery(color, idx) {\n    const imgs = gallery[color];\n    document.querySelectorAll('.main-img-wrap img').forEach(i => i.classList.remove('active'));\n    document.getElementById('img-' + color + '-' + idx).classList.add('active');\n    const thumbsEl = document.getElementById('thumbs');\n    thumbsEl.innerHTML = '';\n    imgs.forEach((img, i) => {\n      const div = document.createElement('div');\n      div.className = 'thumb' + (i === idx ? ' active' : '');\n      div.onclick = () => selectThumb(color, i);\n      const im = document.createElement('img');\n      im.src = img.src;\n      im.alt = img.alt;\n      div.appendChild(im);\n      thumbsEl.appendChild(div);\n    });\n    currentColor = color;\n    currentIdx = idx;\n  }\n\n  function selectThumb(color, idx) { renderGallery(color, idx); }\n\n  function selectColor(color, label, btn) {\n    document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('active'));\n    btn.classList.add('active');\n    document.getElementById('color-name').textContent = label;\n    renderGallery(color, 0);\n  }\n\n  let total = 5 * 60;\n  function updateTimer() {\n    const m = Math.floor(total / 60);\n    const s = total % 60;\n    document.getElementById('t-min').textContent = String(m).padStart(2,'0');\n    document.getElementById('t-sec').textContent = String(s).padStart(2,'0');\n    if (total > 0) total--; else total = 5 * 60;\n  }\n  updateTimer();\n  setInterval(updateTimer, 1000);\n\n  let qty = 1;\n  function changeQty(d) {\n    qty = Math.max(1, qty + d);\n    document.getElementById('qty').textContent = qty;\n  }\n\n  function toggleFaq(btn) {\n    btn.parentElement.classList.toggle('open');\n  }\n</script>\n</body>\n</html>",
