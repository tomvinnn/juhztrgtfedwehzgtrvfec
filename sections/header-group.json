        "liquid": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Smart Watch 2.0 – IA High Tec Shop</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&family=Sofia+Sans:wght@300;400;500;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\n<style>\n  :root {\n    --black: #0a0a0a;\n    --red: #e53e3e;\n    --gray-100: #f5f5f5;\n    --gray-200: #e8e8e8;\n    --gray-400: #aaa;\n    --gray-500: #888;\n    --radius: 14px;\n    --font: 'Sofia Sans', sans-serif;\n    --font-body: 'Poppins', sans-serif;\n  }\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: var(--font);\n    background: #fff;\n    color: var(--black);\n    width: 100%;\n    overflow-x: hidden;\n    padding-bottom: 60px;\n  }\n\n  /* ══════════════════════════════════════\n     LIVE BANNER — même couleurs que l'offer card (noir/rouge)\n  ══════════════════════════════════════ */\n  .live-banner {\n    background: linear-gradient(90deg, #0d0d0d 0%, #1a0505 30%, #2a0808 60%, #1a1a1a 100%);\n    color: #fff;\n    padding: 0;\n    position: sticky;\n    top: 0;\n    z-index: 200;\n    overflow: hidden;\n    border-bottom: 1px solid rgba(229,62,62,0.3);\n  }\n\n  .live-banner::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: repeating-linear-gradient(\n      -55deg,\n      transparent,\n      transparent 22px,\n      rgba(229,62,62,0.04) 22px,\n      rgba(229,62,62,0.04) 44px\n    );\n    pointer-events: none;\n  }\n\n  /* Lueur rouge subtile */\n  .live-banner::after {\n    content: '';\n    position: absolute;\n    top: -60px; right: 20%;\n    width: 200px; height: 120px;\n    border-radius: 50%;\n    background: radial-gradient(circle, rgba(229,62,62,0.18) 0%, transparent 70%);\n    pointer-events: none;\n  }\n\n  .live-banner-inner {\n    display: flex;\n    align-items: center;\n    padding: 11px 14px;\n    gap: 10px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .live-pill {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    background: rgba(229,62,62,0.2);\n    border: 1px solid rgba(229,62,62,0.4);\n    border-radius: 20px;\n    padding: 4px 10px 4px 7px;\n    flex-shrink: 0;\n  }\n  .live-dot {\n    width: 8px; height: 8px;\n    border-radius: 50%;\n    background: #ff4444;\n    flex-shrink: 0;\n    animation: blinkRed 0.9s infinite;\n    box-shadow: 0 0 6px #ff4444;\n  }\n  @keyframes blinkRed { 0%,100%{opacity:1;box-shadow:0 0 8px #ff4444;} 50%{opacity:0.3;box-shadow:none;} }\n\n  .live-pill-text {\n    font-size: 10px;\n    font-weight: 900;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: #ff6666;\n  }\n\n  .live-banner-center {\n    flex: 1;\n    text-align: center;\n  }\n  .live-banner-main {\n    font-size: 15px;\n    font-weight: 900;\n    line-height: 1.15;\n    letter-spacing: 0.01em;\n    text-transform: uppercase;\n    color: #fff;\n  }\n  .live-banner-sub {\n    font-size: 10px;\n    font-weight: 500;\n    color: rgba(255,255,255,0.55);\n    margin-top: 2px;\n    letter-spacing: 0.04em;\n  }\n\n  .live-badge {\n    background: linear-gradient(135deg, #e53e3e, #c0000a);\n    color: #fff;\n    font-size: 15px;\n    font-weight: 900;\n    border-radius: 8px;\n    padding: 6px 12px;\n    white-space: nowrap;\n    flex-shrink: 0;\n    letter-spacing: 0.02em;\n    box-shadow: 0 2px 10px rgba(229,62,62,0.5);\n    animation: badgePop 1.6s ease-in-out infinite;\n  }\n  @keyframes badgePop {\n    0%,100% { transform: scale(1); }\n    50%      { transform: scale(1.06); }\n  }\n\n  /* ══ HEADER ══ */\n  .header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 13px 16px;\n    border-bottom: 1px solid var(--gray-200);\n    background: white;\n    z-index: 100;\n    position: relative;\n  }\n\n  /* Menu 3 points gauche */\n  .header-menu {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    width: 40px;\n    height: 40px;\n    flex-shrink: 0;\n    cursor: pointer;\n    position: relative;\n  }\n  .header-menu-dots {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n    align-items: center;\n  }\n  .header-menu-dot {\n    width: 4px;\n    height: 4px;\n    border-radius: 50%;\n    background: var(--black);\n  }\n\n  /* Drawer menu */\n  .nav-overlay {\n    display: none;\n    position: fixed;\n    inset: 0;\n    background: rgba(0,0,0,0.5);\n    z-index: 300;\n    backdrop-filter: blur(2px);\n  }\n  .nav-overlay.open { display: block; }\n  .nav-drawer {\n    position: fixed;\n    top: 0; left: 0;\n    width: 260px;\n    height: 100%;\n    background: #fff;\n    z-index: 400;\n    padding: 24px 20px;\n    transform: translateX(-100%);\n    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);\n    box-shadow: 4px 0 24px rgba(0,0,0,0.12);\n  }\n  .nav-drawer.open { transform: translateX(0); }\n  .nav-drawer-head {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 28px;\n  }\n  .nav-drawer-logo {\n    font-family: var(--font);\n    font-size: 14px;\n    font-weight: 900;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n  }\n  .nav-close {\n    width: 32px; height: 32px;\n    display: flex; align-items: center; justify-content: center;\n    cursor: pointer;\n    font-size: 20px;\n    color: var(--gray-500);\n    border: none;\n    background: none;\n    border-radius: 50%;\n  }\n  .nav-links { list-style: none; display: flex; flex-direction: column; gap: 4px; }\n  .nav-links a {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    padding: 12px 10px;\n    border-radius: 10px;\n    text-decoration: none;\n    color: var(--black);\n    font-family: var(--font);\n    font-size: 15px;\n    font-weight: 700;\n    transition: background 0.15s;\n  }\n  .nav-links a:hover { background: var(--gray-100); }\n  .nav-links a i { width: 20px; text-align: center; color: var(--red); font-size: 14px; }\n\n  /* Logo centré */\n  .header-logo {\n    flex: 1;\n    text-align: center;\n    font-weight: 900;\n    font-size: 18px;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    color: var(--black);\n    line-height: 1;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  /* Icônes droite — seulement panier (caddie) */\n  .header-icons { display: flex; gap: 12px; flex-shrink: 0; width: 40px; justify-content: flex-end; }\n  .header-icons svg { width: 24px; height: 24px; cursor: pointer; }\n\n  /* ── GALLERY SWIPE ── */\n  .gallery-wrap { width: 100%; position: relative; background: var(--gray-100); }\n  .gallery-track {\n    display: flex;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    scrollbar-width: none;\n  }\n  .gallery-track::-webkit-scrollbar { display: none; }\n  .gallery-slide {\n    flex: 0 0 100%;\n    scroll-snap-align: start;\n    aspect-ratio: 1/1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: var(--gray-100);\n    overflow: hidden;\n  }\n  .gallery-slide img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center;\n    padding: 0;\n    display: block;\n  }\n  .gallery-dots {\n    display: flex;\n    justify-content: center;\n    gap: 6px;\n    padding: 10px 0 6px;\n    background: white;\n  }\n  .gallery-dot {\n    width: 6px; height: 6px;\n    border-radius: 50%;\n    background: var(--gray-200);\n    transition: background 0.2s, transform 0.2s;\n    cursor: pointer;\n  }\n  .gallery-dot.active { background: var(--black); transform: scale(1.3); }\n\n  .thumbs {\n    display: flex;\n    gap: 8px;\n    padding: 8px 16px 12px;\n    overflow-x: auto;\n    scrollbar-width: none;\n    background: white;\n  }\n  .thumbs::-webkit-scrollbar { display: none; }\n  .thumb {\n    width: 64px; height: 64px;\n    border-radius: 10px;\n    overflow: hidden;\n    flex-shrink: 0;\n    border: 2px solid transparent;\n    cursor: pointer;\n    background: var(--gray-100);\n    transition: border-color 0.15s;\n  }\n  .thumb.active { border-color: var(--black); }\n  .thumb img { width: 100%; height: 100%; object-fit: cover; padding: 0; display: block; }\n\n  /* ── CONTENT ── */\n  .content { padding: 16px 16px 0; }\n  .brand { font-size: 11px; color: var(--gray-500); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 5px; font-weight: 500; }\n  .title { font-size: 24px; font-weight: 800; line-height: 1.2; margin-bottom: 6px; }\n  .title em { font-style: italic; font-weight: 300; font-size: 17px; display: block; margin-top: 2px; color: var(--gray-500); }\n  .stars-row { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }\n  .stars { color: #f4a100; font-size: 14px; }\n  .stars-count { font-size: 13px; font-weight: 600; color: var(--gray-500); }\n  .stars-count a { color: var(--gray-500); text-decoration: underline; }\n\n  .color-label { font-size: 13px; color: var(--gray-500); margin-bottom: 10px; font-weight: 500; }\n  .color-label strong { color: var(--black); font-weight: 700; }\n  .color-options { display: flex; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; }\n  .color-btn {\n    width: 44px; height: 44px;\n    border-radius: 50%;\n    border: 3px solid transparent;\n    cursor: pointer;\n    position: relative;\n    transition: border-color 0.2s, transform 0.15s;\n    flex-shrink: 0;\n  }\n  .color-btn:hover { transform: scale(1.08); }\n  .color-btn.active { border-color: var(--black); box-shadow: 0 0 0 2px white inset; }\n  .color-btn[data-color=\"gris\"] { background: #b0aead; }\n  .color-btn[data-color=\"noir\"] { background: #1a1a1a; }\n  .color-btn[data-color=\"orange\"] { background: #e87722; }\n  .color-btn.active::after {\n    content: '✓';\n    position: absolute;\n    top: 50%; left: 50%;\n    transform: translate(-50%, -50%);\n    font-size: 16px; font-weight: 700; color: white;\n    text-shadow: 0 1px 2px rgba(0,0,0,0.4);\n  }\n  .color-btn[data-color=\"gris\"].active::after { color: #333; }\n\n  .qty-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }\n  .qty-label { font-size: 13px; color: var(--gray-500); }\n  .qty-ctrl { display: flex; align-items: center; border: 1.5px solid var(--gray-200); border-radius: 10px; overflow: hidden; }\n  .qty-btn { width: 38px; height: 38px; background: none; border: none; font-size: 18px; font-weight: 700; cursor: pointer; font-family: var(--font); display: flex; align-items: center; justify-content: center; }\n  .qty-val { width: 36px; text-align: center; font-size: 15px; font-weight: 700; font-family: var(--font); }\n\n  /* ══ BENEFITS — Font Poppins + Font Awesome ══ */\n  .benefits { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }\n  .benefits li {\n    display: flex;\n    align-items: flex-start;\n    gap: 11px;\n    font-family: var(--font-body);\n    font-size: 13px;\n    font-weight: 500;\n    line-height: 1.5;\n    color: #1a1a1a;\n  }\n  .benefit-icon {\n    flex-shrink: 0;\n    width: 28px;\n    height: 28px;\n    border-radius: 8px;\n    background: #f5f5f5;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-top: 1px;\n  }\n  .benefit-icon i {\n    font-size: 13px;\n    color: var(--black);\n  }\n\n  .sep { height: 1px; background: var(--gray-200); margin: 14px 0; }\n\n  .stock-line { display: flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 600; color: var(--red); margin-bottom: 14px; font-family: var(--font-body); }\n  .stock-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--red); flex-shrink: 0; animation: blink 1s infinite; }\n  @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0;} }\n\n  /* ══ OFFER CARD — NOIR/ROUGE AGRESSIF ══ */\n  .offer-card {\n    background: #0d0d0d;\n    border-radius: var(--radius);\n    padding: 18px 16px;\n    margin-bottom: 14px;\n    position: relative;\n    overflow: hidden;\n    border: 1px solid #1f1f1f;\n    box-shadow: 0 4px 24px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.04);\n  }\n  .offer-card::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: repeating-linear-gradient(\n      -55deg,\n      transparent,\n      transparent 22px,\n      rgba(229,62,62,0.03) 22px,\n      rgba(229,62,62,0.03) 44px\n    );\n    pointer-events: none;\n  }\n  .offer-card::after {\n    content: '';\n    position: absolute;\n    top: -40px; right: -40px;\n    width: 160px; height: 160px;\n    border-radius: 50%;\n    background: radial-gradient(circle, rgba(229,62,62,0.22) 0%, transparent 70%);\n    pointer-events: none;\n  }\n\n  .offer-card-top {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 14px;\n    position: relative;\n    z-index: 1;\n  }\n  .offer-card-label {\n    font-size: 10px;\n    font-weight: 800;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: #ff4444;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .offer-card-label::before {\n    content: '';\n    width: 7px; height: 7px;\n    border-radius: 50%;\n    background: #ff4444;\n    animation: blinkRed 0.9s infinite;\n    box-shadow: 0 0 6px #ff4444;\n  }\n  .offer-card-badge {\n    background: linear-gradient(135deg, #e53e3e, #c0000a);\n    color: white;\n    font-size: 15px;\n    font-weight: 900;\n    border-radius: 8px;\n    padding: 5px 13px;\n    letter-spacing: 0.04em;\n    box-shadow: 0 2px 10px rgba(229,62,62,0.5);\n  }\n\n  .offer-prices {\n    display: flex;\n    align-items: flex-end;\n    gap: 12px;\n    margin-bottom: 12px;\n    position: relative;\n    z-index: 1;\n  }\n  .offer-price-now {\n    font-size: 40px;\n    font-weight: 900;\n    color: #fff;\n    line-height: 1;\n    letter-spacing: -0.01em;\n  }\n  .offer-price-old {\n    font-size: 16px;\n    color: rgba(255,255,255,0.35);\n    text-decoration: line-through;\n    padding-bottom: 5px;\n    font-weight: 500;\n  }\n\n  .offer-saving {\n    background: rgba(229,62,62,0.12);\n    border: 1px solid rgba(229,62,62,0.3);\n    border-radius: 10px;\n    padding: 9px 12px;\n    margin-bottom: 14px;\n    position: relative;\n    z-index: 1;\n  }\n  .offer-saving-main {\n    font-size: 13px;\n    font-weight: 800;\n    color: #fff;\n    margin-bottom: 3px;\n  }\n  .offer-saving-sub {\n    font-size: 10px;\n    color: rgba(255,255,255,0.45);\n    line-height: 1.4;\n  }\n\n  .offer-divider {\n    height: 1px;\n    background: linear-gradient(90deg, rgba(229,62,62,0.5), transparent);\n    margin-bottom: 14px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .offer-timer-row {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-bottom: 16px;\n    position: relative;\n    z-index: 1;\n  }\n  .offer-timer-label {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.45);\n    flex-shrink: 0;\n  }\n  .offer-timer-blocks { display: flex; align-items: center; gap: 5px; }\n  .offer-timer-unit {\n    background: #1a1a1a;\n    border: 1px solid #2a2a2a;\n    border-radius: 8px;\n    width: 42px;\n    padding: 6px 3px 5px;\n    text-align: center;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);\n  }\n  .offer-timer-num {\n    font-size: 20px;\n    font-weight: 900;\n    color: #fff;\n    line-height: 1;\n    display: block;\n    letter-spacing: -0.02em;\n  }\n  .offer-timer-sub {\n    display: block;\n    font-size: 7px;\n    font-weight: 700;\n    color: rgba(255,255,255,0.35);\n    letter-spacing: 0.1em;\n    margin-top: 2px;\n    text-transform: uppercase;\n  }\n  .offer-timer-sep {\n    font-size: 18px;\n    font-weight: 900;\n    color: #e53e3e;\n    margin-bottom: 2px;\n    animation: blinkSep 1s infinite;\n  }\n  @keyframes blinkSep { 0%,100%{opacity:1} 50%{opacity:0.3} }\n\n  .offer-shipping-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 5px;\n    background: rgba(255,255,255,0.06);\n    border: 1px solid rgba(255,255,255,0.12);\n    border-radius: 20px;\n    padding: 5px 12px;\n    font-size: 11px;\n    font-weight: 700;\n    color: rgba(255,255,255,0.75);\n    margin-bottom: 16px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .offer-cta-btn {\n    display: block;\n    width: 100%;\n    background: linear-gradient(135deg, #e53e3e 0%, #c0000a 100%);\n    color: white;\n    border: none;\n    border-radius: 11px;\n    padding: 15px;\n    font-family: var(--font);\n    font-size: 14px;\n    font-weight: 800;\n    letter-spacing: 0.06em;\n    cursor: pointer;\n    text-align: center;\n    text-decoration: none;\n    text-transform: uppercase;\n    position: relative;\n    z-index: 1;\n    box-shadow: 0 4px 18px rgba(229,62,62,0.5);\n    animation: ctaGlow 2s ease-in-out infinite;\n  }\n  @keyframes ctaGlow {\n    0%,100% { box-shadow: 0 4px 18px rgba(229,62,62,0.5); }\n    50%      { box-shadow: 0 4px 28px rgba(229,62,62,0.75); }\n  }\n\n  /* Paiement sécurisé + logos paiement */\n  .secure-note { display: flex; align-items: center; justify-content: center; gap: 5px; font-size: 11px; color: var(--gray-400); margin-bottom: 14px; font-family: var(--font-body); }\n  .secure-note svg { width: 12px; height: 12px; }\n\n  /* Logos paiement SVG inline */\n  .payment-logos {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    flex-wrap: wrap;\n    margin-bottom: 20px;\n    padding: 0 8px;\n  }\n  .pay-logo {\n    height: 28px;\n    border-radius: 6px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 4px 8px;\n    background: #f5f5f5;\n    border: 1px solid #e0e0e0;\n  }\n  .pay-logo svg { height: 16px; width: auto; }\n  .pay-logo img { height: 16px; width: auto; }\n\n  .trust-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; border-top: 1px solid var(--gray-200); border-bottom: 1px solid var(--gray-200); margin-bottom: 28px; }\n  .trust-item { padding: 14px 6px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4px; border-right: 1px solid var(--gray-200); }\n  .trust-item:last-child { border-right: none; }\n  .trust-icon-sm { font-size: 20px; }\n  .trust-text { font-size: 9px; font-weight: 700; line-height: 1.3; }\n\n  .features { padding: 0 16px; margin-bottom: 28px; }\n  .feature-block { margin-bottom: 24px; }\n  .feature-img { width: 100%; border-radius: var(--radius); overflow: hidden; background: var(--gray-100); aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }\n  .feature-img img { width: 100%; height: 100%; object-fit: contain; padding: 20px; }\n  .feature-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 5px; }\n  .feature-title { font-size: 18px; font-weight: 800; line-height: 1.25; margin-bottom: 7px; }\n  .feature-desc { font-size: 13px; color: var(--gray-500); line-height: 1.6; }\n\n  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 16px; margin-bottom: 28px; }\n  .stat-card { background: var(--gray-100); border-radius: var(--radius); padding: 18px 12px; text-align: center; }\n  .stat-num { font-size: 30px; font-weight: 800; line-height: 1; margin-bottom: 4px; }\n  .stat-label { font-size: 11px; color: var(--gray-500); }\n\n  .section-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 5px; padding: 0 16px; }\n  .section-title { font-size: 20px; font-weight: 800; line-height: 1.2; margin-bottom: 16px; padding: 0 16px; }\n  .section-title em { font-style: italic; font-weight: 300; }\n  .reviews-scroll { display: flex; gap: 10px; overflow-x: auto; padding: 0 16px 12px; scrollbar-width: none; margin-bottom: 6px; }\n  .reviews-scroll::-webkit-scrollbar { display: none; }\n  .review-card { flex-shrink: 0; width: 210px; background: var(--gray-100); border-radius: var(--radius); padding: 13px; }\n  .review-stars { color: #f4a100; font-size: 12px; margin-bottom: 7px; }\n  .review-text { font-size: 12px; font-weight: 600; color: var(--black); line-height: 1.5; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.02em; }\n  .review-author { display: flex; align-items: center; gap: 7px; }\n  .review-avatar { width: 28px; height: 28px; border-radius: 50%; font-size: 11px; font-weight: 700; background: var(--gray-200); flex-shrink: 0; display: flex; align-items: center; justify-content: center; }\n  .review-name { font-size: 11px; font-weight: 600; }\n  .review-date { font-size: 10px; color: var(--gray-500); }\n\n  .lifestyle-strip { display: flex; overflow-x: auto; gap: 10px; padding: 0 16px 14px; scrollbar-width: none; margin-bottom: 22px; }\n  .lifestyle-strip::-webkit-scrollbar { display: none; }\n  .lifestyle-img { width: 160px; height: 160px; flex-shrink: 0; border-radius: var(--radius); object-fit: cover; background: var(--gray-100); }\n\n  .faq-section-head { padding: 0 16px; margin-bottom: 10px; }\n  .faq-wrap { padding: 0 16px; margin-bottom: 32px; }\n  .faq-item { border-bottom: 1px solid var(--gray-200); }\n  .faq-q { width: 100%; background: none; border: none; text-align: left; padding: 15px 0; font-family: var(--font); font-size: 14px; font-weight: 700; color: var(--black); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }\n  .faq-icon { font-size: 18px; color: var(--gray-400); flex-shrink: 0; transition: transform 0.2s; }\n  .faq-item.open .faq-icon { transform: rotate(45deg); }\n  .faq-a { display: none; font-size: 13px; color: var(--gray-500); line-height: 1.65; padding-bottom: 15px; }\n  .faq-item.open .faq-a { display: block; }\n\n  .tp-wrap { padding: 0 16px; margin-bottom: 32px; }\n  .tp-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }\n  .tp-logo { font-size: 13px; font-weight: 800; color: #00b67a; }\n  .tp-score { font-size: 13px; font-weight: 700; }\n  .tp-score span { color: var(--gray-500); font-weight: 400; }\n  .tp-global-stars { color: #00b67a; font-size: 16px; margin-bottom: 16px; }\n  .tp-card { background: var(--gray-100); border-radius: var(--radius); padding: 13px; margin-bottom: 10px; }\n  .tp-card-stars { color: #00b67a; font-size: 12px; margin-bottom: 5px; }\n  .tp-card-date { font-size: 10px; color: var(--gray-500); margin-bottom: 5px; }\n  .tp-card-text { font-size: 13px; font-weight: 500; line-height: 1.55; margin-bottom: 7px; }\n  .tp-card-name { font-size: 11px; font-weight: 700; color: var(--gray-500); }\n  .tp-verified { font-size: 10px; color: var(--gray-400); margin-top: 16px; text-align: center; }\n\n  /* 2e CTA bas */\n  .cta-btn { display: block; width: 100%; background: var(--black); color: white; border: none; border-radius: var(--radius); padding: 17px; font-family: var(--font); font-size: 15px; font-weight: 700; letter-spacing: 0.04em; cursor: pointer; text-align: center; text-decoration: none; margin-bottom: 10px; text-transform: uppercase; }\n\n  .footer { background: var(--black); color: white; padding: 22px 16px; text-align: center; }\n  .footer-logo { font-size: 13px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }\n  .footer-links { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; margin-bottom: 12px; }\n  .footer-links a { font-size: 11px; color: rgba(255,255,255,0.6); text-decoration: none; }\n  .footer-badges { display: flex; justify-content: center; gap: 12px; font-size: 11px; color: rgba(255,255,255,0.5); flex-wrap: wrap; margin-bottom: 10px; }\n  .footer-copy { font-size: 10px; color: rgba(255,255,255,0.35); }\n</style>\n</head>\n<body>\n\n<!-- ══ NAV OVERLAY + DRAWER ══ -->\n<div class=\"nav-overlay\" id=\"navOverlay\" onclick=\"closeNav()\"></div>\n<div class=\"nav-drawer\" id=\"navDrawer\">\n  <div class=\"nav-drawer-head\">\n    <div class=\"nav-drawer-logo\">IA High Tec</div>\n    <button class=\"nav-close\" onclick=\"closeNav()\">✕</button>\n  </div>\n  <ul class=\"nav-links\">\n    <li><a href=\"#\"><i class=\"fa-solid fa-house\"></i> Accueil</a></li>\n    <li><a href=\"#\"><i class=\"fa-solid fa-star\"></i> Meilleures ventes</a></li>\n    <li><a href=\"#avis-clients\"><i class=\"fa-solid fa-comment-dots\"></i> Avis clients</a></li>\n    <li><a href=\"#\"><i class=\"fa-solid fa-tag\"></i> Promotions</a></li>\n    <li><a href=\"#\"><i class=\"fa-solid fa-envelope\"></i> Contact</a></li>\n  </ul>\n</div>\n\n<!-- ══ LIVE BANNER ══ -->\n<div class=\"live-banner\">\n  <div class=\"live-banner-inner\">\n    <div class=\"live-pill\">\n      <div class=\"live-dot\"></div>\n      <span class=\"live-pill-text\">Live</span>\n    </div>\n    <div class=\"live-banner-center\">\n      <div class=\"live-banner-main\">⚡ Offre Flash Spéciale Live</div>\n      <div class=\"live-banner-sub\">Ce soir uniquement · Stock limité</div>\n    </div>\n    <div class=\"live-badge\">−50%</div>\n  </div>\n</div>\n\n<!-- ══ HEADER ══ -->\n<div class=\"header\">\n  <!-- 3 points menu gauche -->\n  <div class=\"header-menu\" onclick=\"openNav()\">\n    <div class=\"header-menu-dots\">\n      <div class=\"header-menu-dot\"></div>\n      <div class=\"header-menu-dot\"></div>\n      <div class=\"header-menu-dot\"></div>\n    </div>\n  </div>\n\n  <div class=\"header-logo\">IA High Tec Shop</div>\n\n  <!-- Panier caddie uniquement -->\n  <div class=\"header-icons\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n      <circle cx=\"9\" cy=\"21\" r=\"1\"/><circle cx=\"20\" cy=\"21\" r=\"1\"/>\n      <path d=\"M1 1h4l2.68 13.39a2 2 0 001.99 1.61h9.72a2 2 0 001.98-1.68L23 6H6\"/>\n    </svg>\n  </div>\n</div>\n\n<!-- GALLERY SWIPE -->\n<div class=\"gallery-wrap\">\n  <div class=\"gallery-track\" id=\"galleryTrack\"></div>\n  <div class=\"gallery-dots\" id=\"galleryDots\"></div>\n  <div class=\"thumbs\" id=\"thumbs\"></div>\n</div>\n\n<!-- CONTENT -->\n<div class=\"content\">\n  <p class=\"brand\">IA High Tec Shop</p>\n  <h1 class=\"title\">Smart Watch 2.0<em>Compact, élégante, et intelligente</em></h1>\n  <div class=\"stars-row\">\n    <span class=\"stars\">★★★★★</span>\n    <span class=\"stars-count\"><a href=\"#avis-clients\">312 avis</a></span>\n  </div>\n\n  <div class=\"sep\" style=\"margin-top:2px;margin-bottom:12px;\"></div>\n  <p class=\"color-label\">Couleur : <strong id=\"color-name-top\">Gris</strong></p>\n  <div class=\"color-options\">\n    <button class=\"color-btn active\" data-color=\"gris\" onclick=\"selectColor('gris','Gris',this)\" title=\"Gris\"></button>\n    <button class=\"color-btn\" data-color=\"noir\" onclick=\"selectColor('noir','Noir',this)\" title=\"Noir\"></button>\n    <button class=\"color-btn\" data-color=\"orange\" onclick=\"selectColor('orange','Orange',this)\" title=\"Orange\"></button>\n  </div>\n  <div class=\"qty-row\">\n    <span class=\"qty-label\">Quantité</span>\n    <div class=\"qty-ctrl\">\n      <button class=\"qty-btn\" onclick=\"changeQty(-1)\">−</button>\n      <span class=\"qty-val\" id=\"qty\">1</span>\n      <button class=\"qty-btn\" onclick=\"changeQty(1)\">+</button>\n    </div>\n  </div>\n  <div class=\"sep\" style=\"margin-top:2px;\"></div>\n\n  <!-- ══ BENEFITS — Poppins + Font Awesome ══ -->\n  <ul class=\"benefits\">\n    <li>\n      <div class=\"benefit-icon\"><i class=\"fa-brands fa-bluetooth-b\"></i></div>\n      <span>Compatible iPhone &amp; Android avec connexion Bluetooth rapide et stable</span>\n    </li>\n    <li>\n      <div class=\"benefit-icon\"><i class=\"fa-solid fa-heart-pulse\"></i></div>\n      <span>Suivi santé complet : fréquence cardiaque, oxygène (SpO2) et analyse du sommeil</span>\n    </li>\n    <li>\n      <div class=\"benefit-icon\"><i class=\"fa-solid fa-person-running\"></i></div>\n      <span>Suivi sportif avancé : calories, distance, objectifs et multiples modes d'entraînement</span>\n    </li>\n    <li>\n      <div class=\"benefit-icon\"><i class=\"fa-solid fa-battery-full\"></i></div>\n      <span>Grande autonomie jusqu'à 5 jours + recharge rapide pour rester actif sans interruption</span>\n    </li>\n    <li>\n      <div class=\"benefit-icon\"><i class=\"fa-solid fa-phone\"></i></div>\n      <span>Appels, SMS et notifications réseaux sociaux directement au poignet</span>\n    </li>\n  </ul>\n\n  <div class=\"stock-line\"><div class=\"stock-dot\"></div>Stock restant : 12 Smart Watch uniquement</div>\n  <div class=\"sep\"></div>\n\n  <!-- ══ OFFER CARD ══ -->\n  <div class=\"offer-card\">\n    <div class=\"offer-card-top\">\n      <div class=\"offer-card-label\">Offre Flash Live</div>\n      <div class=\"offer-card-badge\">−50%</div>\n    </div>\n    <div class=\"offer-prices\">\n      <span class=\"offer-price-now\">64,90 €</span>\n      <span class=\"offer-price-old\">129,90 €</span>\n    </div>\n    <div class=\"offer-saving\">\n      <div class=\"offer-saving-main\">💰 Tu économises 65,00 € ce soir</div>\n      <div class=\"offer-saving-sub\">Prix normal : 129,90 € — Offre Live uniquement, non renouvelable</div>\n    </div>\n    <div class=\"offer-divider\"></div>\n    <div class=\"offer-timer-row\">\n      <span class=\"offer-timer-label\">Expire dans</span>\n      <div class=\"offer-timer-blocks\">\n        <div class=\"offer-timer-unit\"><span class=\"offer-timer-num\" id=\"t-h\">01</span><span class=\"offer-timer-sub\">h</span></div>\n        <div class=\"offer-timer-sep\">:</div>\n        <div class=\"offer-timer-unit\"><span class=\"offer-timer-num\" id=\"t-min\">30</span><span class=\"offer-timer-sub\">min</span></div>\n        <div class=\"offer-timer-sep\">:</div>\n        <div class=\"offer-timer-unit\"><span class=\"offer-timer-num\" id=\"t-sec\">00</span><span class=\"offer-timer-sub\">sec</span></div>\n      </div>\n    </div>\n    <div class=\"offer-shipping-pill\">🚚 Livraison offerte</div>\n    <a href=\"#\" class=\"offer-cta-btn\">🔒 Commander Ma Smart Watch 2.0</a>\n  </div>\n\n  <div class=\"sep\"></div>\n\n  <!-- Paiement sécurisé + logos -->\n  <div class=\"secure-note\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0110 0v4\"/></svg>\n    Paiement 100% sécurisé · SSL\n  </div>\n\n  <!-- Logos paiement SVG propres -->\n  <div class=\"payment-logos\">\n    <!-- Visa -->\n    <div class=\"pay-logo\">\n      <svg viewBox=\"0 0 50 16\" xmlns=\"http://www.w3.org/2000/svg\">\n        <text x=\"0\" y=\"13\" font-family=\"Arial\" font-size=\"14\" font-weight=\"900\" fill=\"#1A1F71\" letter-spacing=\"-0.5\">VISA</text>\n      </svg>\n    </div>\n    <!-- Mastercard -->\n    <div class=\"pay-logo\">\n      <svg viewBox=\"0 0 38 24\" xmlns=\"http://www.w3.org/2000/svg\">\n        <circle cx=\"15\" cy=\"12\" r=\"10\" fill=\"#EB001B\"/>\n        <circle cx=\"23\" cy=\"12\" r=\"10\" fill=\"#F79E1B\"/>\n        <path d=\"M19 5.3a10 10 0 010 13.4A10 10 0 0119 5.3z\" fill=\"#FF5F00\"/>\n      </svg>\n    </div>\n    <!-- Apple Pay -->\n    <div class=\"pay-logo\">\n      <svg viewBox=\"0 0 60 24\" xmlns=\"http://www.w3.org/2000/svg\">\n        <text x=\"0\" y=\"17\" font-family=\"Arial\" font-size=\"12\" font-weight=\"700\" fill=\"#000\"> Pay</text>\n        <path d=\"M7 4.5C8 3.3 8.5 1.8 8.3.5 7.1.6 5.7 1.4 4.7 2.6c-.9 1.1-1.5 2.6-1.3 4 1.3.1 2.7-.7 3.6-2.1z\" fill=\"#000\" transform=\"translate(0,3)\"/>\n        <path d=\"M8.3 4.7c-2 0-3.7 1.2-4.6 1.2S1.5 4.7 0 4.7C0 9.3 3 14 5.4 14c.9 0 1.8-.6 2.5-.6s1.5.6 2.6.6c2.5 0 4-4.3 4-4.3C12.2 8.7 8.3 7.4 8.3 4.7z\" fill=\"#000\" transform=\"translate(0,3)\"/>\n      </svg>\n    </div>\n    <!-- PayPal -->\n    <div class=\"pay-logo\">\n      <svg viewBox=\"0 0 60 20\" xmlns=\"http://www.w3.org/2000/svg\">\n        <text x=\"0\" y=\"15\" font-family=\"Arial\" font-size=\"12\" font-weight=\"700\" fill=\"#003087\">Pay</text>\n        <text x=\"22\" y=\"15\" font-family=\"Arial\" font-size=\"12\" font-weight=\"700\" fill=\"#009CDE\">Pal</text>\n      </svg>\n    </div>\n    <!-- American Express -->\n    <div class=\"pay-logo\" style=\"background:#007BC1;border-color:#007BC1;\">\n      <svg viewBox=\"0 0 60 20\" xmlns=\"http://www.w3.org/2000/svg\">\n        <text x=\"1\" y=\"14\" font-family=\"Arial\" font-size=\"8\" font-weight=\"700\" fill=\"#fff\" letter-spacing=\"0.5\">AMEX</text>\n      </svg>\n    </div>\n    <!-- CB -->\n    <div class=\"pay-logo\">\n      <svg viewBox=\"0 0 34 20\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect x=\"0\" y=\"0\" width=\"34\" height=\"20\" rx=\"3\" fill=\"#1A1F71\"/>\n        <text x=\"4\" y=\"14\" font-family=\"Arial\" font-size=\"9\" font-weight=\"900\" fill=\"#fff\">CB</text>\n      </svg>\n    </div>\n  </div>\n</div>\n\n<!-- TRUST ROW -->\n<div class=\"trust-row\">\n  <div class=\"trust-item\"><div class=\"trust-icon-sm\">🛡️</div><div class=\"trust-text\">Garantie<br>12 mois</div></div>\n  <div class=\"trust-item\"><div class=\"trust-icon-sm\">↩️</div><div class=\"trust-text\">Retour<br>60 jours</div></div>\n  <div class=\"trust-item\"><div class=\"trust-icon-sm\">🚚</div><div class=\"trust-text\">Livraison<br>gratuite</div></div>\n  <div class=\"trust-item\"><div class=\"trust-icon-sm\">💬</div><div class=\"trust-text\">Support<br>24h/24</div></div>\n</div>\n\n<!-- FEATURES -->\n<div class=\"features\">\n  <div class=\"feature-block\">\n    <div class=\"feature-img\"><img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960\" alt=\"Suivi santé\"></div>\n    <p class=\"feature-tag\">Suivi santé complet</p>\n    <h3 class=\"feature-title\">Ton corps. Sous surveillance constante.</h3>\n    <p class=\"feature-desc\">Fréquence cardiaque, saturation en oxygène (SpO2), qualité du sommeil, calories, pas — tout est mesuré en continu.</p>\n  </div>\n  <div class=\"feature-block\">\n    <div class=\"feature-img\"><img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\" alt=\"Appels SMS\"></div>\n    <p class=\"feature-tag\">Connectivité totale</p>\n    <h3 class=\"feature-title\">Appels, SMS, notifs. Sans toucher ton téléphone.</h3>\n    <p class=\"feature-desc\">Compatible iPhone et Android, elle te garde connecté partout, en toute discrétion.</p>\n  </div>\n  <div class=\"feature-block\">\n    <div class=\"feature-img\"><img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\" alt=\"Design robuste\"></div>\n    <p class=\"feature-tag\">Construction premium</p>\n    <h3 class=\"feature-title\">Robuste. Résistante. Faite pour durer.</h3>\n    <p class=\"feature-desc\">Résistance à l'eau IP67, verre minéral anti-rayures, boîtier en alliage aluminium.</p>\n  </div>\n</div>\n\n<!-- STATS -->\n<div class=\"stats-grid\">\n  <div class=\"stat-card\"><div class=\"stat-num\">+8 000</div><div class=\"stat-label\">clients satisfaits</div></div>\n  <div class=\"stat-card\"><div class=\"stat-num\">60j</div><div class=\"stat-label\">satisfait ou remboursé</div></div>\n  <div class=\"stat-card\"><div class=\"stat-num\">IP67</div><div class=\"stat-label\">résistance à l'eau</div></div>\n  <div class=\"stat-card\"><div class=\"stat-num\">98%</div><div class=\"stat-label\">clients satisfaits</div></div>\n</div>\n\n<!-- REVIEWS -->\n<div class=\"section-label\">Ils en parlent mieux que nous…</div>\n<div class=\"section-title\">Vos avis parlent <em>d'eux-mêmes.</em></div>\n<div class=\"reviews-scroll\">\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">La qualité est au rendez-vous. Je m'attendais pas à ça pour ce prix.</div><div class=\"review-author\"><div class=\"review-avatar\">TM</div><div><div class=\"review-name\">Thomas M.</div><div class=\"review-date\">Il y a 2 jours</div></div></div></div>\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">Reçu en 3 jours, livraison soignée. La montre est vraiment belle en vrai.</div><div class=\"review-author\"><div class=\"review-avatar\">SL</div><div><div class=\"review-name\">Sophie L.</div><div class=\"review-date\">Il y a 4 jours</div></div></div></div>\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">Le suivi du sommeil est bluffant. Je la porte même la nuit tellement elle est légère.</div><div class=\"review-author\"><div class=\"review-avatar\">KR</div><div><div class=\"review-name\">Kevin R.</div><div class=\"review-date\">Il y a 1 semaine</div></div></div></div>\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">J'ai acheté pour mon mari, il l'a plus quittée depuis. Cadeau parfait.</div><div class=\"review-author\"><div class=\"review-avatar\">MD</div><div><div class=\"review-name\">Marie D.</div><div class=\"review-date\">Il y a 10 jours</div></div></div></div>\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">Appels et SMS directement depuis la montre, ça change la vie au sport.</div><div class=\"review-author\"><div class=\"review-avatar\">JB</div><div><div class=\"review-name\">Julien B.</div><div class=\"review-date\">Il y a 2 semaines</div></div></div></div>\n</div>\n\n<!-- LIFESTYLE -->\n<div class=\"lifestyle-strip\">\n  <img class=\"lifestyle-img\" src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960\" alt=\"\">\n  <img class=\"lifestyle-img\" src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\" alt=\"\">\n  <img class=\"lifestyle-img\" src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\" alt=\"\">\n</div>\n\n<!-- 2e CTA -->\n<div style=\"padding:0 16px;margin-bottom:32px;\">\n  <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;\">\n    <div>\n      <div style=\"font-size:28px;font-weight:800;\">64,90 €</div>\n      <div style=\"font-size:13px;color:var(--gray-400);text-decoration:line-through;\">129,90 €</div>\n    </div>\n    <div style=\"text-align:right;\">\n      <div style=\"font-size:11px;color:var(--gray-500);margin-bottom:4px;\">★★★★★ 312 avis</div>\n      <div style=\"font-size:11px;color:var(--red);font-weight:700;\">Stock : 12 restantes</div>\n    </div>\n  </div>\n  <a href=\"#\" class=\"cta-btn\">🔒 Commander Ma Smart Watch 2.0</a>\n  <div class=\"secure-note\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0110 0v4\"/></svg>\n    Paiement 100% sécurisé · Livraison offerte\n  </div>\n</div>\n\n<!-- FAQ -->\n<div class=\"faq-section-head\">\n  <p class=\"feature-tag\" style=\"margin-bottom:5px;\">Questions fréquentes</p>\n  <h2 style=\"font-size:20px;font-weight:800;line-height:1.2;\">Tout ce que vous devez savoir <em style=\"font-weight:300;font-style:italic;\">avant de commander</em></h2>\n</div>\n<div class=\"faq-wrap\" id=\"avis-clients\">\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">La Smart Watch 2.0 est-elle compatible avec mon téléphone ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Oui. Compatible avec tous les iPhone (iOS 9+) et smartphones Android (5.0+). Connexion Bluetooth stable, synchronisation en quelques secondes via l'application gratuite.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Est-ce que je peux vraiment passer des appels depuis la montre ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Absolument. Microphone et haut-parleur intégrés. Quand ton téléphone est à portée Bluetooth, tu peux décrocher, parler et raccrocher directement depuis ton poignet.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Quelle est l'autonomie de la batterie ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Entre 5 et 7 jours en utilisation normale. Avec le suivi santé actif en continu, comptez 3 à 4 jours. Recharge complète en moins de 2 heures via le chargeur magnétique inclus.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Elle résiste à l'eau ? Je peux la porter sous la douche ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Oui, certifiée IP67 — supporte une immersion jusqu'à 1 mètre pendant 30 minutes. Sous la douche et par temps de pluie, aucun problème. On déconseille en revanche la piscine ou la mer.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Quelle est la politique de retour ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">60 jours pour la retourner sans aucune justification. Remboursement 100% intégral frais de livraison inclus. En cas de produit défectueux à réception : remplacement immédiat sans retour préalable.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Le prix −50% va-t-il remonter après le live ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Oui. Le prix de <strong>64,90 €</strong> (au lieu de 129,90 €) est exclusivement réservé aux spectateurs du live. Une fois le timer écoulé, la remise ne peut plus être appliquée rétroactivement.</div></div>\n</div>\n\n<!-- TRUSTPILOT -->\n<div class=\"tp-wrap\">\n  <div class=\"tp-header\"><div class=\"tp-logo\">Trustpilot</div><div class=\"tp-score\">4,8 <span>/ 5</span></div></div>\n  <div class=\"tp-global-stars\">★★★★★</div>\n  <p style=\"font-size:11px;color:var(--gray-500);margin-bottom:18px;\">Basé sur <a href=\"#\" style=\"color:var(--gray-500);\">312 avis vérifiés</a></p>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 1 jour</div><div class=\"tp-card-text\">Je n'espérais pas une telle qualité à ce prix. Dès que je l'ai sortie du colis j'ai été bluffé. L'écran est net, la montre est légère et les fonctions de santé fonctionnent vraiment.</div><div class=\"tp-card-name\">Lucas M.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 2 jours</div><div class=\"tp-card-text\">Offert à ma fille pour son anniversaire. Elle l'adore. La couleur orange est magnifique et la livraison a été ultra rapide. Je recommande sans hésiter.</div><div class=\"tp-card-name\">Isabelle P.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 3 jours</div><div class=\"tp-card-text\">Le suivi du sommeil est top. Et pouvoir répondre aux appels depuis mon poignet à la salle de sport, ça change vraiment la vie. Aucun regret.</div><div class=\"tp-card-name\">Romain C.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 5 jours</div><div class=\"tp-card-text\">Commandé un mercredi soir, reçu le vendredi matin. Emballage soigné, produit conforme aux photos. La montre est solide, le bracelet est confortable. Très satisfait.</div><div class=\"tp-card-name\">Mathieu F.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 1 semaine</div><div class=\"tp-card-text\">Ça fait un mois que je la porte tous les jours. Pas une seule fois elle a eu un bug.</div><div class=\"tp-card-name\">Antoine L.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 2 semaines</div><div class=\"tp-card-text\">J'ai remplacé une montre deux fois plus chère. La Smart Watch 2.0 fait exactement la même chose. SAV au top, ils ont répondu à mon message en 20 minutes.</div><div class=\"tp-card-name\">Pierre-Antoine K.</div></div>\n  <p class=\"tp-verified\">Avis collectés et vérifiés par Trustpilot</p>\n</div>\n\n<!-- FOOTER -->\n<div class=\"footer\">\n  <div class=\"footer-logo\">IA High Tec Shop</div>\n  <div class=\"footer-links\">\n    <a href=\"#\">Confidentialité</a><a href=\"#\">Remboursement</a><a href=\"#\">CGV</a><a href=\"#\">Livraison</a><a href=\"#\">Contact</a>\n  </div>\n  <div class=\"footer-badges\">\n    <span>🔒 Paiement sécurisé</span><span>↩️ 60j remboursé</span><span>🇫🇷 Support FR</span>\n  </div>\n  <div class=\"footer-copy\">© 2026 IA High Tec Shop — Tous droits réservés</div>\n</div>\n\n<script>\n  // ── NAV ──\n  function openNav() {\n    document.getElementById('navDrawer').classList.add('open');\n    document.getElementById('navOverlay').classList.add('open');\n    document.body.style.overflow = 'hidden';\n  }\n  function closeNav() {\n    document.getElementById('navDrawer').classList.remove('open');\n    document.getElementById('navOverlay').classList.remove('open');\n    document.body.style.overflow = '';\n  }\n\n  // ── GALLERY ──\n  const galleryData = {\n    gris: [\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960', alt: 'Smart Watch Gris' },\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715', alt: 'Smart Watch Gris détail' }\n    ],\n    noir: [\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/O1CN017e2Cmp2Dtzw4Yz7qK__2207705038668-0-cib_0a846c84-0535-4e84-9d6a-76f57b54b198.webp?v=1732348989', alt: 'Smart Watch Noir' },\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713', alt: 'Smart Watch Noir détail' }\n    ],\n    orange: [\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/O1CN017e2Cmp2Dtzw4Yz7qK__2207705038668-0-cib_0a846c84-0535-4e84-9d6a-76f57b54b198.webp?v=1732348989', alt: 'Smart Watch Orange' },\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715', alt: 'Smart Watch Orange détail' }\n    ]\n  };\n\n  let currentColor = 'gris';\n  let currentSlide = 0;\n\n  function buildGallery(color) {\n    const imgs = galleryData[color];\n    const track = document.getElementById('galleryTrack');\n    const dots = document.getElementById('galleryDots');\n    const thumbs = document.getElementById('thumbs');\n    track.innerHTML = '';\n    imgs.forEach((img) => {\n      const slide = document.createElement('div');\n      slide.className = 'gallery-slide';\n      const im = document.createElement('img');\n      im.src = img.src; im.alt = img.alt;\n      slide.appendChild(im); track.appendChild(slide);\n    });\n    dots.innerHTML = '';\n    imgs.forEach((_, i) => {\n      const dot = document.createElement('div');\n      dot.className = 'gallery-dot' + (i === 0 ? ' active' : '');\n      dot.onclick = () => goToSlide(i);\n      dots.appendChild(dot);\n    });\n    thumbs.innerHTML = '';\n    imgs.forEach((img, i) => {\n      const div = document.createElement('div');\n      div.className = 'thumb' + (i === 0 ? ' active' : '');\n      div.onclick = () => goToSlide(i);\n      const im = document.createElement('img');\n      im.src = img.src; im.alt = img.alt;\n      div.appendChild(im); thumbs.appendChild(div);\n    });\n    currentSlide = 0;\n    track.onscroll = () => {\n      const idx = Math.round(track.scrollLeft / track.offsetWidth);\n      if (idx !== currentSlide) { currentSlide = idx; updateGalleryUI(); }\n    };\n  }\n\n  function goToSlide(idx) {\n    const track = document.getElementById('galleryTrack');\n    track.scrollTo({ left: idx * track.offsetWidth, behavior: 'smooth' });\n    currentSlide = idx; updateGalleryUI();\n  }\n\n  function updateGalleryUI() {\n    document.querySelectorAll('.gallery-dot').forEach((d, i) => d.classList.toggle('active', i === currentSlide));\n    document.querySelectorAll('.thumb').forEach((t, i) => t.classList.toggle('active', i === currentSlide));\n  }\n\n  function selectColor(color, label, btn) {\n    document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('active'));\n    btn.classList.add('active');\n    document.getElementById('color-name-top').textContent = label;\n    currentColor = color;\n    buildGallery(color);\n  }\n\n  buildGallery('gris');\n\n  // ── TIMER ──\n  let total = 1 * 3600 + 30 * 60;\n  function updateTimer() {\n    const h = Math.floor(total / 3600);\n    const m = Math.floor((total % 3600) / 60);\n    const s = total % 60;\n    document.getElementById('t-h').textContent = String(h).padStart(2,'0');\n    document.getElementById('t-min').textContent = String(m).padStart(2,'0');\n    document.getElementById('t-sec').textContent = String(s).padStart(2,'0');\n    if (total > 0) total--; else total = 1 * 3600 + 30 * 60;\n  }\n  updateTimer(); setInterval(updateTimer, 1000);\n\n  // ── QTY ──\n  let qty = 1;\n  function changeQty(d) { qty = Math.max(1, qty + d); document.getElementById('qty').textContent = qty; }\n\n  // ── FAQ ──\n  function toggleFaq(btn) { btn.parentElement.classList.toggle('open'); }\n</script>\n</body>\n</html>",
