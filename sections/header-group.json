    "custom_liquid_DGXqtD": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "{% if request.page_type == 'cart' %}\n\n<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Mon Panier — IA High Tec Shop</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n*{box-sizing:border-box;margin:0;padding:0;}\n:root{\n  --black:#080808;\n  --white:#fafafa;\n  --gray-50:#f5f5f5;\n  --gray-100:#ebebeb;\n  --gray-200:#d4d4d4;\n  --gray-400:#999;\n  --gray-500:#666;\n  --accent:#1a3fcc;\n  --green:#22c55e;\n  --font-serif:'Cormorant Garamond',Georgia,serif;\n  --font-sans:'DM Sans',sans-serif;\n}\nhtml,body{margin:0;padding:0;width:100%;overflow-x:hidden;}\nbody{font-family:var(--font-sans);background:var(--white);color:var(--black);padding-bottom:120px;}\n\n/* ── ANIMATIONS ── */\n@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.2;}}\n@keyframes progress{0%{width:100%;}100%{width:0%;}}\n@keyframes fadeUp{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}\n\n/* ── FREE SHIPPING BANNER ── */\n.shipping-banner{\n  background:var(--black);color:#fff;\n  padding:0 16px;\n  position:sticky;top:0;z-index:200;\n  border-bottom:1px solid #1a1a1a;\n}\n.shipping-inner{\n  display:flex;flex-direction:column;gap:0;\n  padding:10px 0 0;\n}\n.shipping-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}\n.shipping-left{display:flex;align-items:center;gap:7px;}\n.shipping-icon{font-size:14px;}\n.shipping-text{font-size:11px;font-weight:500;color:rgba(255,255,255,.85);line-height:1.35;}\n.shipping-text b{color:#fff;font-weight:700;}\n.shipping-timer{display:flex;align-items:center;gap:5px;flex-shrink:0;}\n.timer-label{font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);}\n.timer-blocks{display:flex;align-items:center;gap:3px;}\n.t-unit{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.12);border-radius:4px;min-width:26px;padding:3px 2px;text-align:center;}\n.t-num{font-family:var(--font-serif);font-size:13px;font-weight:400;color:#fff;line-height:1;display:block;}\n.t-sub{display:block;font-size:5px;letter-spacing:.1em;color:rgba(255,255,255,.3);text-transform:uppercase;margin-top:1px;}\n.t-sep{font-size:11px;color:rgba(255,255,255,.3);padding-bottom:3px;}\n.progress-bar{height:2px;background:rgba(255,255,255,.1);border-radius:1px;overflow:hidden;margin-bottom:0;}\n.progress-fill{\n  height:100%;background:var(--accent);border-radius:1px;\n  width:100%;\n  transition:width 1s linear;\n}\n\n/* Unlocked state */\n.shipping-banner.unlocked .shipping-text{color:rgba(255,255,255,.85);}\n.shipping-banner.unlocked .progress-fill{background:var(--green);}\n\n/* ── HEADER NAV ── */\n.cart-header{\n  display:flex;align-items:center;justify-content:space-between;\n  padding:14px 16px;border-bottom:1px solid var(--gray-100);\n}\n.back-btn{display:flex;align-items:center;gap:5px;font-size:11px;font-weight:500;color:var(--gray-400);text-decoration:none;background:none;border:none;cursor:pointer;font-family:var(--font-sans);}\n.back-btn svg{width:14px;height:14px;}\n.cart-title{font-family:var(--font-serif);font-size:20px;font-weight:300;letter-spacing:-.01em;}\n.cart-count{font-size:11px;color:var(--gray-400);font-weight:500;}\n\n/* ── URGENCY STRIP ── */\n.urgency-strip{\n  background:rgba(26,63,204,.06);border-bottom:1px solid rgba(26,63,204,.1);\n  padding:9px 16px;display:flex;align-items:center;gap:7px;\n}\n.u-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;animation:blink 1s infinite;}\n.urgency-text{font-size:11px;font-weight:500;color:var(--accent);line-height:1.4;}\n\n/* ── CART ITEMS ── */\n.cart-items{padding:0 16px;margin-top:4px;}\n.cart-item{\n  display:flex;gap:12px;padding:16px 0;\n  border-bottom:1px solid var(--gray-100);\n  animation:fadeUp .3s ease;\n}\n.item-img{\n  width:80px;height:80px;border-radius:10px;overflow:hidden;\n  background:var(--gray-50);flex-shrink:0;border:1px solid var(--gray-100);\n}\n.item-img img{width:100%;height:100%;object-fit:cover;display:block;}\n.item-info{flex:1;min-width:0;}\n.item-brand{font-size:9px;letter-spacing:.12em;text-transform:uppercase;color:var(--gray-400);margin-bottom:3px;font-weight:500;}\n.item-name{font-family:var(--font-serif);font-size:17px;font-weight:300;line-height:1.2;margin-bottom:3px;}\n.item-variant{font-size:11px;color:var(--gray-400);margin-bottom:8px;}\n.item-bottom{display:flex;align-items:center;justify-content:space-between;}\n.item-price-wrap{}\n.item-price{font-family:var(--font-serif);font-size:20px;font-weight:400;line-height:1;}\n.item-price-old{font-size:11px;color:var(--gray-400);text-decoration:line-through;margin-top:1px;}\n.item-qty{display:flex;align-items:center;border:1px solid var(--gray-200);border-radius:7px;overflow:hidden;}\n.qty-btn{width:30px;height:30px;background:none;border:none;font-size:15px;cursor:pointer;font-family:var(--font-sans);color:var(--black);display:flex;align-items:center;justify-content:center;transition:background .15s;}\n.qty-btn:hover{background:var(--gray-50);}\n.qty-val{width:28px;text-align:center;font-size:12px;font-weight:600;}\n.item-remove{\n  background:none;border:none;cursor:pointer;\n  color:var(--gray-400);font-size:10px;font-weight:500;\n  font-family:var(--font-sans);padding:0;margin-top:2px;\n  text-decoration:underline;transition:color .15s;\n}\n.item-remove:hover{color:var(--black);}\n.item-badge{\n  display:inline-flex;align-items:center;gap:3px;\n  background:rgba(26,63,204,.08);border-radius:4px;padding:2px 6px;\n  font-size:9px;font-weight:600;color:var(--accent);margin-bottom:6px;letter-spacing:.04em;\n}\n\n/* ── UPSELL BLOCK ── */\n.upsell-block{\n  margin:12px 16px;\n  background:var(--gray-50);border:1px solid var(--gray-100);\n  border-radius:12px;padding:12px;\n}\n.upsell-title{font-size:9px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--gray-400);margin-bottom:10px;}\n.upsell-item{display:flex;align-items:center;gap:10px;}\n.upsell-img{width:52px;height:52px;border-radius:8px;overflow:hidden;background:#fff;border:1px solid var(--gray-100);flex-shrink:0;}\n.upsell-img img{width:100%;height:100%;object-fit:cover;}\n.upsell-info{flex:1;}\n.upsell-name{font-family:var(--font-serif);font-size:14px;font-weight:300;margin-bottom:2px;line-height:1.2;}\n.upsell-sub{font-size:10px;color:var(--gray-400);}\n.upsell-price{font-size:13px;font-weight:600;color:var(--black);margin-top:2px;}\n.upsell-add{\n  background:var(--black);color:#fff;border:none;border-radius:7px;\n  padding:8px 14px;font-family:var(--font-sans);font-size:11px;font-weight:600;\n  cursor:pointer;letter-spacing:.04em;white-space:nowrap;transition:opacity .2s;\n}\n.upsell-add:hover{opacity:.85;}\n.upsell-add.added{background:var(--green);}\n\n/* ── ORDER SUMMARY ── */\n.summary-block{padding:0 16px;margin-top:8px;}\n.summary-title{font-size:9px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--gray-400);margin-bottom:12px;}\n.summary-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px;font-size:13px;}\n.summary-row.saving{color:var(--green);font-weight:600;}\n.summary-label{color:var(--gray-500);}\n.summary-val{font-weight:600;color:var(--black);}\n.summary-row.saving .summary-label{color:var(--green);}\n.summary-row.saving .summary-val{color:var(--green);}\n.summary-divider{height:1px;background:var(--gray-100);margin:12px 0;}\n.summary-total{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}\n.total-label{font-family:var(--font-serif);font-size:18px;font-weight:400;}\n.total-val{font-family:var(--font-serif);font-size:28px;font-weight:300;letter-spacing:-.02em;}\n.total-sub{font-size:10px;color:var(--gray-400);margin-bottom:16px;text-align:right;}\n\n/* ── TRUST BADGES ── */\n.trust-mini{display:flex;justify-content:space-between;gap:4px;margin-bottom:16px;}\n.trust-mini-item{flex:1;background:var(--gray-50);border:1px solid var(--gray-100);border-radius:8px;padding:8px 4px;text-align:center;}\n.trust-mini-icon{font-size:14px;margin-bottom:3px;}\n.trust-mini-text{font-size:8px;color:var(--gray-500);font-weight:500;line-height:1.3;}\n\n/* ── CHECKOUT CTA ── */\n.checkout-block{padding:0 16px;}\n.checkout-btn{\n  display:block;width:100%;background:var(--accent);color:#fff;border:none;\n  border-radius:10px;padding:16px;font-family:var(--font-sans);font-size:14px;\n  font-weight:600;letter-spacing:.04em;cursor:pointer;text-align:center;\n  text-transform:uppercase;transition:opacity .2s,transform .15s;margin-bottom:8px;\n}\n.checkout-btn:hover{opacity:.92;transform:translateY(-1px);}\n.checkout-btn:active{transform:scale(.98);}\n.checkout-sub{font-size:10px;color:var(--gray-400);text-align:center;margin-bottom:10px;line-height:1.5;}\n.payment-row{display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap;margin-bottom:4px;}\n.pay-logo{height:22px;background:var(--gray-50);border:1px solid var(--gray-100);border-radius:5px;display:flex;align-items:center;justify-content:center;padding:3px 8px;}\n.pay-logo svg{height:12px;width:auto;}\n\n/* ── GUARANTEE ── */\n.guarantee-block{\n  margin:16px 16px 0;\n  background:var(--gray-50);border:1px solid var(--gray-100);border-radius:12px;\n  padding:14px 16px;display:flex;align-items:flex-start;gap:10px;\n}\n.g-icon{font-size:18px;flex-shrink:0;margin-top:1px;}\n.g-text strong{display:block;font-size:12px;font-weight:600;margin-bottom:3px;}\n.g-text span{font-size:11px;color:var(--gray-500);line-height:1.55;}\n\n/* ── REVIEWS MINI ── */\n.reviews-mini{padding:16px 16px 0;}\n.reviews-mini-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}\n.tp-logo{font-size:12px;font-weight:700;color:#00b67a;}\n.tp-score{font-size:11px;color:var(--gray-500);}\n.review-mini-list{display:flex;flex-direction:column;gap:8px;}\n.review-mini{background:var(--gray-50);border:1px solid var(--gray-100);border-radius:10px;padding:12px 14px;}\n.rv-stars{color:#c8a85a;font-size:10px;margin-bottom:5px;}\n.rv-text{font-size:11px;color:var(--gray-500);line-height:1.6;margin-bottom:8px;}\n.rv-footer{display:flex;align-items:center;gap:6px;}\n.rv-avatar{width:22px;height:22px;border-radius:50%;background:var(--black);color:#fff;font-size:8px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}\n.rv-name{font-size:10px;font-weight:600;}\n.rv-verified{font-size:9px;color:#00b67a;}\n\n/* ── STICKY CHECKOUT ── */\n.sticky-checkout{\n  position:fixed;bottom:0;left:0;right:0;\n  background:var(--white);border-top:1px solid var(--gray-100);\n  padding:10px 16px 16px;z-index:9999;\n  box-shadow:0 -8px 30px rgba(0,0,0,.07);\n  transform:translateY(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);\n}\n.sticky-checkout.visible{transform:translateY(0);}\n.sticky-row{display:flex;align-items:center;gap:10px;}\n.sticky-total{flex:1;}\n.sticky-total-label{font-size:10px;color:var(--gray-400);}\n.sticky-total-val{font-family:var(--font-serif);font-size:24px;font-weight:300;line-height:1;}\n.sticky-btn{\n  background:var(--accent);color:#fff;border:none;border-radius:9px;\n  padding:13px 20px;font-family:var(--font-sans);font-size:12px;\n  font-weight:600;cursor:pointer;text-transform:uppercase;letter-spacing:.04em;\n  white-space:nowrap;transition:opacity .2s;flex-shrink:0;\n}\n.sticky-btn:active{opacity:.8;}\n\n/* ── EMPTY STATE ── */\n.empty-state{display:none;text-align:center;padding:60px 32px;}\n.empty-state.visible{display:block;}\n.empty-icon{font-size:48px;margin-bottom:16px;}\n.empty-title{font-family:var(--font-serif);font-size:24px;font-weight:300;margin-bottom:8px;}\n.empty-sub{font-size:13px;color:var(--gray-400);margin-bottom:24px;}\n.empty-btn{display:inline-block;background:var(--black);color:#fff;border:none;border-radius:9px;padding:13px 28px;font-family:var(--font-sans);font-size:12px;font-weight:600;cursor:pointer;text-decoration:none;letter-spacing:.04em;text-transform:uppercase;}\n\n/* ── FOOTER ── */\nfooter{background:var(--black);color:#fff;padding:24px 16px;text-align:center;margin-top:32px;}\n.footer-logo{font-family:var(--font-serif);font-size:15px;font-weight:400;letter-spacing:.08em;margin-bottom:12px;color:rgba(255,255,255,.6);}\n.footer-links{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;margin-bottom:10px;}\n.footer-links a{font-size:10px;color:rgba(255,255,255,.35);text-decoration:none;}\n.footer-copy{font-size:9px;color:rgba(255,255,255,.18);}\n</style>\n\n<div class=\"shipping-banner\" id=\"shippingBanner\">\n  <div class=\"shipping-inner\">\n    <div class=\"shipping-top\">\n      <div class=\"shipping-left\">\n        <span class=\"shipping-icon\" id=\"shippingIcon\">🚚</span>\n        <div class=\"shipping-text\" id=\"shippingText\">\n          Livraison gratuite débloquée ! <b>Réservez votre commande dans les</b>\n        </div>\n      </div>\n      <div class=\"shipping-timer\">\n        <div class=\"timer-blocks\">\n          <div class=\"t-unit\"><span class=\"t-num\" id=\"tb-m\">03</span><span class=\"t-sub\">min</span></div>\n          <span class=\"t-sep\">:</span>\n          <div class=\"t-unit\"><span class=\"t-num\" id=\"tb-s\">00</span><span class=\"t-sub\">sec</span></div>\n        </div>\n      </div>\n    </div>\n    <div class=\"progress-bar\"><div class=\"progress-fill\" id=\"progressFill\"></div></div>\n  </div>\n</div>\n\n<div class=\"cart-header\">\n  <button class=\"back-btn\" onclick=\"goBack()\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M19 12H5M12 5l-7 7 7 7\"/></svg>\n    Continuer mes achats\n  </button>\n  <div class=\"cart-title\">Mon Panier</div>\n  <div class=\"cart-count\" id=\"cartCount\">1 article</div>\n</div>\n\n<div class=\"urgency-strip\">\n  <div class=\"u-dot\"></div>\n  <div class=\"urgency-text\">⚡ Offre Flash −50% — expire à minuit. <strong>12 personnes</strong> regardent ce produit.</div>\n</div>\n\n<div class=\"cart-items\" id=\"cartItems\">\n\n  <div class=\"cart-item\" id=\"item-main\">\n    <div class=\"item-img\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\" alt=\"Smart Watch 2.0\" id=\"itemImg\">\n    </div>\n    <div class=\"item-info\">\n      <div class=\"item-brand\">IA High Tec Shop</div>\n      <div class=\"item-name\">Smart Watch 2.0</div>\n      <div class=\"item-variant\" id=\"itemVariant\">Couleur : Noir</div>\n      <div class=\"item-badge\">−50% • Offre Live</div>\n      <div class=\"item-bottom\">\n        <div class=\"item-price-wrap\">\n          <div class=\"item-price\" id=\"itemPrice\">64,90 €</div>\n          <div class=\"item-price-old\">129,90 €</div>\n        </div>\n        <div style=\"display:flex;flex-direction:column;align-items:flex-end;gap:6px;\">\n          <div class=\"item-qty\">\n            <button class=\"qty-btn\" onclick=\"changeQty(-1)\">−</button>\n            <span class=\"qty-val\" id=\"itemQty\">1</span>\n            <button class=\"qty-btn\" onclick=\"changeQty(1)\">+</button>\n          </div>\n          <button class=\"item-remove\" onclick=\"removeItem()\">Retirer</button>\n        </div>\n      </div>\n    </div>\n  </div>\n\n</div>\n\n<div class=\"upsell-block\" id=\"upsellBlock\">\n  <div class=\"upsell-title\">Souvent ajouté ensemble</div>\n  <div class=\"upsell-item\">\n    <div class=\"upsell-img\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_142202_2505abc6-1f9d-4225-8941-b8cd2f3aff86.png?v=1775399077\" alt=\"Bracelet supplémentaire\">\n    </div>\n    <div class=\"upsell-info\">\n      <div class=\"upsell-name\">Bracelet Sport Premium</div>\n      <div class=\"upsell-sub\">Compatible Smart Watch 2.0 · Silicone</div>\n      <div class=\"upsell-price\">+9,90 €</div>\n    </div>\n    <button class=\"upsell-add\" id=\"upsellBtn\" onclick=\"addUpsell()\">+ Ajouter</button>\n  </div>\n</div>\n\n<div class=\"summary-block\">\n  <div class=\"summary-title\">Récapitulatif</div>\n\n  <div class=\"summary-row\">\n    <span class=\"summary-label\">Sous-total</span>\n    <span class=\"summary-val\" id=\"subtotal\">64,90 €</span>\n  </div>\n  <div class=\"summary-row saving\" id=\"savingRow\">\n    <span class=\"summary-label\">🎉 Économie réalisée</span>\n    <span class=\"summary-val\" id=\"savingVal\">−65,00 €</span>\n  </div>\n  <div class=\"summary-row\">\n    <span class=\"summary-label\">Livraison</span>\n    <span class=\"summary-val\" style=\"color:var(--green);\">Gratuite 🎁</span>\n  </div>\n  <div class=\"summary-divider\"></div>\n  <div class=\"summary-total\">\n    <span class=\"total-label\">Total</span>\n    <span class=\"total-val\" id=\"totalVal\">64,90 €</span>\n  </div>\n  <div class=\"total-sub\">TTC · Livraison offerte</div>\n\n  <div class=\"trust-mini\">\n    <div class=\"trust-mini-item\"><div class=\"trust-mini-icon\">🛡️</div><div class=\"trust-mini-text\">Garantie<br>12 mois</div></div>\n    <div class=\"trust-mini-item\"><div class=\"trust-mini-icon\">↩️</div><div class=\"trust-mini-text\">Retour<br>60 jours</div></div>\n    <div class=\"trust-mini-item\"><div class=\"trust-mini-icon\">🔒</div><div class=\"trust-mini-text\">Paiement<br>sécurisé</div></div>\n    <div class=\"trust-mini-item\"><div class=\"trust-mini-icon\">💬</div><div class=\"trust-mini-text\">Support<br>24h/24</div></div>\n  </div>\n</div>\n\n<div class=\"checkout-block\" id=\"checkoutBlock\">\n  <button class=\"checkout-btn\" onclick=\"checkout()\">\n    Finaliser ma commande — <span id=\"ctaPrice\">64,90 €</span>\n  </button>\n  <div class=\"checkout-sub\">\n    Paiement sécurisé SSL · Livraison gratuite · Satisfait ou remboursé 60j\n  </div>\n  <div class=\"payment-row\">\n    <div class=\"pay-logo\"><svg viewBox=\"0 0 50 16\"><text x=\"0\" y=\"13\" font-family=\"Arial\" font-size=\"14\" font-weight=\"900\" fill=\"#1A1F71\">VISA</text></svg></div>\n    <div class=\"pay-logo\"><svg viewBox=\"0 0 38 24\"><circle cx=\"15\" cy=\"12\" r=\"10\" fill=\"#EB001B\"/><circle cx=\"23\" cy=\"12\" r=\"10\" fill=\"#F79E1B\"/><path d=\"M19 5.3a10 10 0 010 13.4A10 10 0 0119 5.3z\" fill=\"#FF5F00\"/></svg></div>\n    <div class=\"pay-logo\"><svg viewBox=\"0 0 60 20\"><text x=\"0\" y=\"15\" font-family=\"Arial\" font-size=\"12\" font-weight=\"700\" fill=\"#003087\">Pay</text><text x=\"22\" y=\"15\" font-family=\"Arial\" font-size=\"12\" font-weight=\"700\" fill=\"#009CDE\">Pal</text></svg></div>\n    <div class=\"pay-logo\"><svg viewBox=\"0 0 34 20\"><rect width=\"34\" height=\"20\" rx=\"3\" fill=\"#1A1F71\"/><text x=\"4\" y=\"14\" font-family=\"Arial\" font-size=\"9\" font-weight=\"900\" fill=\"#fff\">CB</text></svg></div>\n  </div>\n</div>\n\n<div class=\"guarantee-block\">\n  <div class=\"g-icon\">🛡️</div>\n  <div class=\"g-text\">\n    <strong>Achat 100% sécurisé & sans risque</strong>\n    <span>Satisfait ou remboursé sous 60 jours, sans justification. Garantie 12 mois incluse. Si vous n'êtes pas conquis, on vous rembourse intégralement — livraison comprise.</span>\n  </div>\n</div>\n\n<div class=\"reviews-mini\">\n  <div class=\"reviews-mini-header\">\n    <div class=\"tp-logo\">★ Trustpilot</div>\n    <div class=\"tp-score\">4,8/5 · 312 avis</div>\n  </div>\n  <div class=\"review-mini-list\">\n    <div class=\"review-mini\">\n      <div class=\"rv-stars\">★★★★★</div>\n      <p class=\"rv-text\">Commandé mercredi soir, reçu vendredi matin. Emballage soigné, produit conforme. L'écran est vraiment net.</p>\n      <div class=\"rv-footer\"><div class=\"rv-avatar\">MF</div><div><div class=\"rv-name\">Mathieu F.</div><div class=\"rv-verified\">✓ Avis vérifié</div></div></div>\n    </div>\n    <div class=\"review-mini\">\n      <div class=\"rv-stars\">★★★★★</div>\n      <p class=\"rv-text\">La batterie tient 5-6 jours facilement. Je n'ai plus à m'inquiéter de charger chaque soir. Je recommande les yeux fermés.</p>\n      <div class=\"rv-footer\"><div class=\"rv-avatar\">AL</div><div><div class=\"rv-name\">Antoine L.</div><div class=\"rv-verified\">✓ Avis vérifié</div></div></div>\n    </div>\n    <div class=\"review-mini\">\n      <div class=\"rv-stars\">★★★★★</div>\n      <p class=\"rv-text\">Portée tous les jours depuis 3 semaines. Pas un seul bug, pas une seule déception. Rapport qualité/prix imbattable.</p>\n      <div class=\"rv-footer\"><div class=\"rv-avatar\">SL</div><div><div class=\"rv-name\">Sophie L.</div><div class=\"rv-verified\">✓ Avis vérifié</div></div></div>\n    </div>\n  </div>\n</div>\n\n<div class=\"empty-state\" id=\"emptyState\">\n  <div class=\"empty-icon\">🛒</div>\n  <div class=\"empty-title\">Votre panier est vide</div>\n  <div class=\"empty-sub\">Découvrez notre Smart Watch 2.0 à −50%.</div>\n  <a href=\"#\" class=\"empty-btn\" onclick=\"goBack()\">Voir le produit</a>\n</div>\n\n<footer>\n  <div class=\"footer-logo\">IA High Tec Shop</div>\n  <div class=\"footer-links\">\n    <a href=\"/policies/privacy-policy\">Confidentialité</a>\n    <a href=\"/policies/refund-policy\">Remboursement</a>\n    <a href=\"/policies/terms-of-service\">CGV</a>\n    <a href=\"/policies/shipping-policy\">Livraison</a>\n    <a href=\"/pages/contact\">Contact</a>\n  </div>\n  <div class=\"footer-copy\">© 2026 IA High Tec Shop — Tous droits réservés</div>\n</footer>\n\n<div class=\"sticky-checkout\" id=\"stickyCheckout\">\n  <div class=\"sticky-row\">\n    <div class=\"sticky-total\">\n      <div class=\"sticky-total-label\">Total</div>\n      <div class=\"sticky-total-val\" id=\"stickyTotal\">64,90 €</div>\n    </div>\n    <button class=\"sticky-btn\" onclick=\"checkout()\">Payer maintenant →</button>\n  </div>\n</div>\n\n<script>\n(function(){\n\n/* ─── STATE ─── */\nvar PRICE_UNIT = 64.90;\nvar PRICE_OLD  = 129.90;\nvar UPSELL_PRICE = 9.90;\nvar qty = 1;\nvar upsellAdded = false;\nvar itemExists = true;\n\n/* Read URL params for color/qty */\n(function(){\n  try{\n    var p = new URLSearchParams(window.location.search);\n    if(p.get('color')){\n      var c = p.get('color');\n      var label = c.charAt(0).toUpperCase()+c.slice(1);\n      document.getElementById('itemVariant').textContent = 'Couleur : '+label;\n      var imgs = {\n        'noir':'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713',\n        'beige':'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715',\n        'orange':'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715'\n      };\n      if(imgs[c]) document.getElementById('itemImg').src = imgs[c];\n    }\n    if(p.get('qty')){\n      qty = Math.max(1, parseInt(p.get('qty'))||1);\n      document.getElementById('itemQty').textContent = qty;\n    }\n  }catch(e){}\n})();\n\n/* ─── TIMER (3 min) ─── */\nvar TIMER_TOTAL = 3 * 60; // seconds\nvar timerLeft = TIMER_TOTAL;\nvar timerExpired = false;\n\nfunction updateTimer(){\n  if(timerExpired) return;\n  var m = Math.floor(timerLeft/60);\n  var s = timerLeft % 60;\n  var em = document.getElementById('tb-m');\n  var es = document.getElementById('tb-s');\n  var pf = document.getElementById('progressFill');\n  if(em) em.textContent = String(m).padStart(2,'0');\n  if(es) es.textContent = String(s).padStart(2,'0');\n  if(pf){\n    var pct = (timerLeft / TIMER_TOTAL) * 100;\n    pf.style.width = pct + '%';\n    if(pct < 30) pf.style.background = '#ef4444';\n    else if(pct < 60) pf.style.background = '#f97316';\n    else pf.style.background = 'var(--accent)';\n  }\n  if(timerLeft <= 0){\n    timerExpired = true;\n    var banner = document.getElementById('shippingBanner');\n    var txt = document.getElementById('shippingText');\n    var icon = document.getElementById('shippingIcon');\n    if(txt) txt.innerHTML = 'Offre expirée — la remise −50% n\\'est plus garantie. <b>Finalisez maintenant.</b>';\n    if(icon) icon.textContent = '⚠️';\n    if(pf) pf.style.width = '0%';\n  } else {\n    timerLeft--;\n  }\n}\nupdateTimer();\nsetInterval(updateTimer, 1000);\n\n/* ─── PRICE UTILS ─── */\nfunction fmt(n){ return n.toFixed(2).replace('.',',') + ' €'; }\n\nfunction updatePrices(){\n  var sub = (PRICE_UNIT * qty) + (upsellAdded ? UPSELL_PRICE : 0);\n  var saving = (PRICE_OLD * qty) - (PRICE_UNIT * qty);\n  document.getElementById('subtotal').textContent = fmt(sub);\n  document.getElementById('savingVal').textContent = '−' + fmt(saving);\n  document.getElementById('totalVal').textContent = fmt(sub);\n  document.getElementById('ctaPrice').textContent = fmt(sub);\n  document.getElementById('stickyTotal').textContent = fmt(sub);\n  document.getElementById('itemPrice').textContent = fmt(PRICE_UNIT * qty);\n  var count = qty + (upsellAdded ? 1 : 0);\n  document.getElementById('cartCount').textContent = count + (count>1 ? ' articles' : ' article');\n}\n\n/* ─── QTY ─── */\nwindow.changeQty = function(d){\n  qty = Math.max(1, qty+d);\n  document.getElementById('itemQty').textContent = qty;\n  updatePrices();\n};\n\n/* ─── REMOVE ─── */\nwindow.removeItem = function(){\n  itemExists = false;\n  var item = document.getElementById('item-main');\n  if(item){ item.style.opacity='0'; item.style.transition='opacity .3s'; setTimeout(function(){ item.style.display='none'; checkEmpty(); },300); }\n};\n\nfunction checkEmpty(){\n  if(!itemExists && !upsellAdded){\n    document.getElementById('cartItems').style.display='none';\n    document.getElementById('upsellBlock').style.display='none';\n    document.getElementById('summary-block') && (document.getElementById('summary-block').style.display='none');\n    document.querySelector('.summary-block').style.display='none';\n    document.getElementById('checkoutBlock').style.display='none';\n    document.querySelector('.guarantee-block').style.display='none';\n    document.getElementById('emptyState').classList.add('visible');\n    document.getElementById('stickyCheckout').classList.remove('visible');\n  }\n}\n\n/* ─── UPSELL ─── */\nwindow.addUpsell = function(){\n  upsellAdded = true;\n  var btn = document.getElementById('upsellBtn');\n  if(btn){ btn.textContent='✓ Ajouté'; btn.classList.add('added'); btn.disabled=true; }\n  updatePrices();\n};\n\n/* ─── CHECKOUT ─── */\nwindow.checkout = function(){\n  window.location.href = 'https://iatechshop.myshopify.com/checkout';\n};\n\n/* ─── BACK ─── */\nwindow.goBack = function(){\n  if(document.referrer && document.referrer !== window.location.href){\n    window.history.back();\n  } else {\n    window.location.href = '/';\n  }\n};\n\n/* ─── STICKY ─── */\nvar sticky = document.getElementById('stickyCheckout');\nvar checkoutBlock = document.getElementById('checkoutBlock');\nwindow.addEventListener('scroll', function(){\n  if(!sticky||!checkoutBlock) return;\n  sticky.classList.toggle('visible', checkoutBlock.getBoundingClientRect().bottom < 0);\n},{passive:true});\n\n/* ─── INIT ─── */\nupdatePrices();\n\n})();\n</script>\n</body>\n</html>\n\n{% endif %}",
