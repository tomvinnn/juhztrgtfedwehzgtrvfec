/div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Puis-je retourner le produit ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Oui, tu as 60 jours pour le retourner si tu n’es pas satisfait.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Comment connecter la montre ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Il suffit d’installer l’application compatible puis d’appairer la montre en Bluetooth.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Est-ce qu’elle mesure le rythme cardiaque ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Oui, elle suit la fréquence cardiaque, le sommeil, le stress et d’autres données santé.</div></div>\n</div>\n\n<footer>\n  <div class=\"footer-logo\">IA High Tec Shop</div>\n  <div class=\"footer-links\">\n    <a href=\"#\">Confidentialité</a>\n    <a href=\"#\">Conditions</a>\n  </div>\n  <div class=\"footer-copy\">© 2026 IA High Tec Shop — Tous droits réservés</div>\n</footer>\n\n<div class=\"sticky-bar\" id=\"stickyBar\">\n  <div class=\"sticky-price\">\n    <div class=\"sticky-price-now\">64,90 €</div>\n    <div class=\"sticky-price-old\">129,90 €</div>\n  </div>\n  <button type=\"button\" class=\"sticky-btn\" onclick=\"addToCart()\">Ajouter au panier</button>\n</div>\n</div>\n\n<script>\n(function(){\nvar container = document.getElementById('custom-product-page');\ncontainer.style.display = 'block';\n\nvar selectedColor = 'noir';\nvar selectedVariantId = '50081100661002';\n\nvar galleries = {\n  noir: [\n    \"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\",\n    \"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260406_195736_ada11f84-b46b-41d1-bfcd-2f95a79def69.png?v=1775505554\"\n  ],\n  beige: [\n    \"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715\",\n    \"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151814_eff117f5-d9e6-4d53-9776-1ffff80aa2fd.png?v=1775402484\"\n  ],\n  orange: [\n    \"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\",\n    \"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/Capture_d_ecran_2026-04-05_a_18.06.28.png?v=1775405214\"\n  ]\n};\n\nfunction buildGallery(color){\n  var track = document.getElementById(\"galleryTrack\");\n  var dots = document.getElementById(\"galleryDots\");\n  var thumbs = document.getElementById(\"galleryThumbs\");\n  var imgs = galleries[color] || galleries.noir;\n  track.innerHTML = \"\";\n  dots.innerHTML = \"\";\n  thumbs.innerHTML = \"\";\n  imgs.forEach(function(src, i){\n    var slide = document.createElement(\"div\");\n    slide.className = \"gallery-slide\";\n    var img = document.createElement(\"img\");\n    img.src = src;\n    slide.appendChild(img);\n    track.appendChild(slide);\n\n    var dot = document.createElement(\"div\");\n    dot.className = \"g-dot\" + (i===0 ? \" active\" : \"\");\n    dot.onclick = function(){ track.scrollTo({left: i * track.offsetWidth, behavior:\"smooth\"}); };\n    dots.appendChild(dot);\n\n    var th = document.createElement(\"div\");\n    th.className = \"g-thumb\" + (i===0 ? \" active\" : \"\");\n    th.onclick = function(){ track.scrollTo({left: i * track.offsetWidth, behavior:\"smooth\"}); };\n    var timg = document.createElement(\"img\");\n    timg.src = src;\n    th.appendChild(timg);\n    thumbs.appendChild(th);\n  });\n}\n\nwindow.selectColor = function(color, label, btn){\n  selectedColor = color;\n  if(color === 'noir') selectedVariantId = '50081100661002';\n  if(color === 'beige') selectedVariantId = '50331881865482';\n  if(color === 'orange') selectedVariantId = '52829079372042';\n  document.querySelectorAll(\".c-btn\").forEach(function(b){ b.classList.remove(\"active\"); });\n  btn.classList.add(\"active\");\n  document.getElementById(\"color-name\").textContent = label;\n  buildGallery(color);\n};\n\nwindow.changeQty = function(d){\n  var qEl = document.getElementById(\"qty\");\n  var cur = parseInt(qEl.textContent, 10) || 1;\n  qEl.textContent = Math.max(1, cur + d);\n};\n\nwindow.addToCart = async function(){\n  var qty = parseInt(document.getElementById(\"qty\").textContent, 10) || 1;\n  try{\n    await fetch('/cart/add.js', {\n      method: 'POST',\n      headers: {'Content-Type':'application/json'},\n      body: JSON.stringify({\n        id: Number(selectedVariantId),\n        quantity: qty\n      })\n    });\n    window.location.href = '/cart';\n  }catch(e){\n    window.location.href = '/cart';\n  }\n};\n\nwindow.toggleFaq = function(btn){\n  btn.parentElement.classList.toggle(\"open\");\n};\n\n(function(){\n  var now = new Date();\n  var d1 = new Date(now);\n  var d3 = new Date(now); d3.setDate(now.getDate() + 4);\n  document.getElementById(\"d-date1\").textContent = d1.getDate() + \"/\" + (d1.getMonth()+1);\n  document.getElementById(\"d-date3\").textContent = d3.getDate() + \"/\" + (d3.getMonth()+1);\n})();\n\nfunction updateTimer(){\n  var now = new Date();\n  var h = 23 - now.getHours();\n  var m = 59 - now.getMinutes();\n  var s = 59 - now.getSeconds();\n  document.getElementById(\"ot-h\").textContent = String(h).padStart(2,'0');\n  document.getElementById(\"ot-m\").textContent = String(m).padStart(2,'0');\n  document.getElementById(\"ot-s\").textContent = String(s).padStart(2,'0');\n}\nsetInterval(updateTimer, 1000);\nupdateTimer();\n\nwindow.addEventListener(\"scroll\", function(){\n  var oc = document.getElementById(\"offerCard\");\n  var sb = document.getElementById(\"stickyBar\");\n  if(oc && sb) sb.classList.toggle(\"visible\", oc.getBoundingClientRect().bottom < 0);\n});\n\nvar trackR = document.getElementById(\"reviewsTrack\");\nif(trackR){\n  var reviews = [\n    {name:\"Jean D.\", initials:\"JD\", text:\"Génial ! Très belle montre, la finition est propre et la batterie tient bien.\"},\n    {name:\"Sarah M.\", initials:\"SM\", text:\"Très rapide à recevoir et la qualité est franchement au rendez-vous.\"},\n    {name:\"Nicolas P.\", initials:\"NP\", text:\"Le rapport qualité/prix est excellent, je l'utilise tous les jours.\"},\n    {name:\"Lina B.\", initials:\"LB\", text:\"Belle surprise, les fonctionnalités santé sont super utiles au quotidien.\"}\n  ];\n  trackR.innerHTML = \"\";\n  reviews.concat(reviews).forEach(function(r){\n    var card = document.createElement(\"div\");\n    card.className = \"review-card\";\n    card.innerHTML = '<div class=\"rv-stars\">★★★★★</div><p class=\"rv-text\">'+r.text+'</p><div class=\"rv-footer\"><div class=\"rv-avatar\">'+r.initials+'</div><div><div class=\"rv-name\">'+r.name+'</div><div class=\"rv-verified\">✓ Avis vérifié</div></div></div>';\n    trackR.appendChild(card);\n  });\n}\n\nbuildGallery(\"noir\");\n})();\n</script>\n</body>\n</html>\n{% endif %}",
