        "liquid": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=Inter:wght@300;400;500&display=swap');\n\n#lp-root * { box-sizing: border-box; margin: 0; padding: 0; }\n#lp-root {\n  font-family: 'Inter', sans-serif;\n  background: #0a0a0a;\n  color: #f0ece4;\n  overflow-x: hidden;\n}\n\n/* HERO */\n#lp-hero {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  text-align: center;\n  padding: 6rem 2rem 4rem;\n  position: relative;\n  background: #0a0a0a;\n}\n#lp-hero::before {\n  content: '';\n  position: absolute;\n  top: -200px; left: 50%; transform: translateX(-50%);\n  width: 800px; height: 800px;\n  background: radial-gradient(circle, rgba(255,200,80,0.08) 0%, transparent 70%);\n  pointer-events: none;\n}\n#lp-badge {\n  display: inline-block;\n  border: 1px solid rgba(255,200,80,0.4);\n  color: #ffc850;\n  font-size: 11px;\n  letter-spacing: 0.15em;\n  text-transform: uppercase;\n  padding: 6px 16px;\n  border-radius: 100px;\n  margin-bottom: 2rem;\n  animation: lp-fade 0.8s ease both;\n}\n#lp-hero h1 {\n  font-family: 'Syne', sans-serif;\n  font-weight: 800;\n  font-size: clamp(2.8rem, 8vw, 6rem);\n  line-height: 1.05;\n  letter-spacing: -0.03em;\n  max-width: 800px;\n  margin-bottom: 1.5rem;\n  animation: lp-fade 0.8s 0.1s ease both;\n}\n#lp-hero h1 span { color: #ffc850; }\n#lp-hero p {\n  font-size: clamp(1rem, 2vw, 1.2rem);\n  color: rgba(240,236,228,0.55);\n  max-width: 520px;\n  line-height: 1.7;\n  margin-bottom: 2.5rem;\n  font-weight: 300;\n  animation: lp-fade 0.8s 0.2s ease both;\n}\n.lp-btn-primary {\n  display: inline-block;\n  background: #ffc850;\n  color: #0a0a0a;\n  font-family: 'Syne', sans-serif;\n  font-weight: 700;\n  font-size: 15px;\n  letter-spacing: 0.04em;\n  padding: 16px 40px;\n  border-radius: 100px;\n  text-decoration: none;\n  transition: transform 0.15s, box-shadow 0.15s;\n  animation: lp-fade 0.8s 0.3s ease both;\n}\n.lp-btn-primary:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 8px 32px rgba(255,200,80,0.3);\n  color: #0a0a0a;\n  text-decoration: none;\n}\n.lp-btn-ghost {\n  display: inline-block;\n  border: 1px solid rgba(240,236,228,0.2);\n  color: #f0ece4;\n  font-family: 'Syne', sans-serif;\n  font-weight: 500;\n  font-size: 15px;\n  padding: 15px 36px;\n  border-radius: 100px;\n  text-decoration: none;\n  transition: border-color 0.15s, background 0.15s;\n  margin-left: 12px;\n  animation: lp-fade 0.8s 0.35s ease both;\n}\n.lp-btn-ghost:hover {\n  border-color: rgba(240,236,228,0.5);\n  background: rgba(240,236,228,0.05);\n  color: #f0ece4;\n  text-decoration: none;\n}\n#lp-hero-btns { animation: lp-fade 0.8s 0.3s ease both; }\n\n#lp-trust {\n  display: flex;\n  gap: 2rem;\n  justify-content: center;\n  flex-wrap: wrap;\n  margin-top: 3rem;\n  animation: lp-fade 0.8s 0.5s ease both;\n}\n.lp-trust-item {\n  font-size: 13px;\n  color: rgba(240,236,228,0.4);\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n.lp-trust-dot {\n  width: 6px; height: 6px;\n  border-radius: 50%;\n  background: #ffc850;\n}\n\n/* DIVIDER */\n.lp-divider {\n  border: none;\n  border-top: 1px solid rgba(240,236,228,0.08);\n  margin: 0;\n}\n\n/* STATS */\n#lp-stats {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 0;\n  background: #111;\n  border-top: 1px solid rgba(255,255,255,0.06);\n  border-bottom: 1px solid rgba(255,255,255,0.06);\n}\n.lp-stat {\n  padding: 2.5rem 2rem;\n  text-align: center;\n  border-right: 1px solid rgba(255,255,255,0.06);\n}\n.lp-stat:last-child { border-right: none; }\n.lp-stat-num {\n  font-family: 'Syne', sans-serif;\n  font-weight: 800;\n  font-size: 2.5rem;\n  color: #ffc850;\n  line-height: 1;\n  margin-bottom: 6px;\n}\n.lp-stat-label {\n  font-size: 13px;\n  color: rgba(240,236,228,0.4);\n  letter-spacing: 0.05em;\n}\n\n/* FEATURES */\n#lp-features {\n  padding: 6rem 2rem;\n  max-width: 1100px;\n  margin: 0 auto;\n}\n#lp-features h2 {\n  font-family: 'Syne', sans-serif;\n  font-weight: 800;\n  font-size: clamp(2rem, 5vw, 3.2rem);\n  letter-spacing: -0.03em;\n  margin-bottom: 0.75rem;\n  text-align: center;\n}\n#lp-features h2 span { color: #ffc850; }\n.lp-section-sub {\n  text-align: center;\n  color: rgba(240,236,228,0.45);\n  font-size: 1rem;\n  font-weight: 300;\n  max-width: 480px;\n  margin: 0 auto 3.5rem;\n  line-height: 1.7;\n}\n.lp-features-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n  gap: 20px;\n}\n.lp-feature-card {\n  background: #111;\n  border: 1px solid rgba(255,255,255,0.07);\n  border-radius: 16px;\n  padding: 2rem;\n  transition: border-color 0.2s, transform 0.2s;\n}\n.lp-feature-card:hover {\n  border-color: rgba(255,200,80,0.25);\n  transform: translateY(-3px);\n}\n.lp-feature-icon {\n  width: 44px; height: 44px;\n  background: rgba(255,200,80,0.1);\n  border-radius: 10px;\n  display: flex; align-items: center; justify-content: center;\n  font-size: 20px;\n  margin-bottom: 1.25rem;\n}\n.lp-feature-card h3 {\n  font-family: 'Syne', sans-serif;\n  font-weight: 700;\n  font-size: 1.1rem;\n  margin-bottom: 0.5rem;\n}\n.lp-feature-card p {\n  font-size: 14px;\n  color: rgba(240,236,228,0.45);\n  line-height: 1.7;\n  font-weight: 300;\n}\n\n/* PRODUCT SECTION */\n#lp-product {\n  padding: 5rem 2rem;\n  background: #0d0d0d;\n  border-top: 1px solid rgba(255,255,255,0.05);\n  border-bottom: 1px solid rgba(255,255,255,0.05);\n}\n.lp-product-inner {\n  max-width: 1000px;\n  margin: 0 auto;\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 5rem;\n  align-items: center;\n}\n.lp-product-img-wrap {\n  background: #161616;\n  border: 1px solid rgba(255,255,255,0.07);\n  border-radius: 20px;\n  aspect-ratio: 1;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 80px;\n  position: relative;\n  overflow: hidden;\n}\n.lp-product-img-wrap::after {\n  content: '';\n  position: absolute;\n  bottom: -40px; right: -40px;\n  width: 200px; height: 200px;\n  background: radial-gradient(circle, rgba(255,200,80,0.12) 0%, transparent 70%);\n}\n.lp-product-info h2 {\n  font-family: 'Syne', sans-serif;\n  font-weight: 800;\n  font-size: clamp(1.8rem, 4vw, 2.6rem);\n  letter-spacing: -0.03em;\n  line-height: 1.1;\n  margin-bottom: 1rem;\n}\n.lp-product-info h2 span { color: #ffc850; }\n.lp-product-info p {\n  font-size: 15px;\n  color: rgba(240,236,228,0.5);\n  line-height: 1.75;\n  margin-bottom: 1.5rem;\n  font-weight: 300;\n}\n.lp-checklist { list-style: none; margin-bottom: 2rem; }\n.lp-checklist li {\n  font-size: 14px;\n  color: rgba(240,236,228,0.7);\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 7px 0;\n  border-bottom: 1px solid rgba(255,255,255,0.05);\n}\n.lp-checklist li:last-child { border-bottom: none; }\n.lp-check {\n  width: 20px; height: 20px;\n  background: rgba(255,200,80,0.15);\n  border-radius: 50%;\n  display: flex; align-items: center; justify-content: center;\n  flex-shrink: 0;\n  font-size: 11px;\n  color: #ffc850;\n}\n.lp-price-row {\n  display: flex;\n  align-items: baseline;\n  gap: 12px;\n  margin-bottom: 1.5rem;\n}\n.lp-price {\n  font-family: 'Syne', sans-serif;\n  font-size: 2.2rem;\n  font-weight: 800;\n  color: #ffc850;\n}\n.lp-price-old {\n  font-size: 1.1rem;\n  color: rgba(240,236,228,0.25);\n  text-decoration: line-through;\n}\n.lp-price-save {\n  font-size: 12px;\n  background: rgba(255,200,80,0.15);\n  color: #ffc850;\n  padding: 3px 10px;\n  border-radius: 100px;\n}\n\n/* TESTIMONIALS */\n#lp-testimonials {\n  padding: 6rem 2rem;\n  max-width: 1100px;\n  margin: 0 auto;\n}\n#lp-testimonials h2 {\n  font-family: 'Syne', sans-serif;\n  font-weight: 800;\n  font-size: clamp(2rem, 5vw, 3rem);\n  letter-spacing: -0.03em;\n  text-align: center;\n  margin-bottom: 0.75rem;\n}\n.lp-testi-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n  gap: 20px;\n  margin-top: 3.5rem;\n}\n.lp-testi-card {\n  background: #111;\n  border: 1px solid rgba(255,255,255,0.07);\n  border-radius: 16px;\n  padding: 1.75rem;\n}\n.lp-stars { color: #ffc850; font-size: 14px; margin-bottom: 1rem; letter-spacing: 2px; }\n.lp-testi-text {\n  font-size: 14px;\n  color: rgba(240,236,228,0.6);\n  line-height: 1.75;\n  margin-bottom: 1.25rem;\n  font-weight: 300;\n  font-style: italic;\n}\n.lp-testi-author {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n.lp-avatar {\n  width: 36px; height: 36px;\n  border-radius: 50%;\n  background: rgba(255,200,80,0.15);\n  display: flex; align-items: center; justify-content: center;\n  font-family: 'Syne', sans-serif;\n  font-weight: 700;\n  font-size: 13px;\n  color: #ffc850;\n  flex-shrink: 0;\n}\n.lp-author-name {\n  font-size: 13px;\n  font-weight: 500;\n}\n.lp-author-role {\n  font-size: 12px;\n  color: rgba(240,236,228,0.35);\n}\n\n/* CTA FINAL */\n#lp-cta {\n  padding: 8rem 2rem;\n  text-align: center;\n  position: relative;\n  overflow: hidden;\n}\n#lp-cta::before {\n  content: '';\n  position: absolute;\n  top: 50%; left: 50%;\n  transform: translate(-50%, -50%);\n  width: 700px; height: 500px;\n  background: radial-gradient(ellipse, rgba(255,200,80,0.07) 0%, transparent 70%);\n  pointer-events: none;\n}\n#lp-cta h2 {\n  font-family: 'Syne', sans-serif;\n  font-weight: 800;\n  font-size: clamp(2.2rem, 6vw, 4rem);\n  letter-spacing: -0.03em;\n  max-width: 700px;\n  margin: 0 auto 1rem;\n  line-height: 1.05;\n}\n#lp-cta h2 span { color: #ffc850; }\n#lp-cta p {\n  font-size: 1rem;\n  color: rgba(240,236,228,0.45);\n  margin-bottom: 2.5rem;\n  font-weight: 300;\n}\n#lp-cta .lp-btn-primary { animation: none; }\n\n/* FOOTER STRIP */\n#lp-footer {\n  background: #080808;\n  border-top: 1px solid rgba(255,255,255,0.05);\n  padding: 1.5rem 2rem;\n  text-align: center;\n  font-size: 12px;\n  color: rgba(240,236,228,0.2);\n  letter-spacing: 0.05em;\n}\n\n/* ANIMATIONS */\n@keyframes lp-fade {\n  from { opacity: 0; transform: translateY(16px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n\n/* RESPONSIVE */\n@media (max-width: 700px) {\n  #lp-stats { grid-template-columns: 1fr; }\n  .lp-stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); }\n  .lp-stat:last-child { border-bottom: none; }\n  .lp-product-inner { grid-template-columns: 1fr; gap: 2.5rem; }\n  .lp-btn-ghost { margin-left: 0; margin-top: 12px; }\n  #lp-hero-btns { display: flex; flex-direction: column; align-items: center; }\n}\n</style>\n\n<div id=\"lp-root\">\n\n  <!-- HERO -->\n  <section id=\"lp-hero\">\n    <div id=\"lp-badge\">✦ Nouveau — Édition 2025</div>\n    <h1>La boutique tech<br>qui <span>change tout</span></h1>\n    <p>Des produits soigneusement sélectionnés pour les passionnés de technologie. Qualité premium, livraison rapide, satisfaction garantie.</p>\n    <div id=\"lp-hero-btns\">\n      <a href=\"https://iatechshop.myshopify.com/cart\" class=\"lp-btn-primary\">Commander maintenant</a>\n      <a href=\"https://iatechshop.myshopify.com/cart\" class=\"lp-btn-ghost\">Voir les produits</a>\n    </div>\n    <div id=\"lp-trust\">\n      <span class=\"lp-trust-item\"><span class=\"lp-trust-dot\"></span> Livraison offerte dès 50€</span>\n      <span class=\"lp-trust-item\"><span class=\"lp-trust-dot\"></span> Satisfait ou remboursé 30j</span>\n      <span class=\"lp-trust-item\"><span class=\"lp-trust-dot\"></span> Paiement 100% sécurisé</span>\n    </div>\n  </section>\n\n  <!-- STATS -->\n  <div id=\"lp-stats\">\n    <div class=\"lp-stat\">\n      <div class=\"lp-stat-num\">4 800+</div>\n      <div class=\"lp-stat-label\">clients satisfaits</div>\n    </div>\n    <div class=\"lp-stat\">\n      <div class=\"lp-stat-num\">4.9 ★</div>\n      <div class=\"lp-stat-label\">note moyenne</div>\n    </div>\n    <div class=\"lp-stat\">\n      <div class=\"lp-stat-num\">48h</div>\n      <div class=\"lp-stat-label\">délai de livraison</div>\n    </div>\n  </div>\n\n  <!-- FEATURES -->\n  <section id=\"lp-features\">\n    <h2>Pourquoi nous <span>choisir</span> ?</h2>\n    <p class=\"lp-section-sub\">Chaque détail a été pensé pour vous offrir la meilleure expérience possible.</p>\n    <div class=\"lp-features-grid\">\n      <div class=\"lp-feature-card\">\n        <div class=\"lp-feature-icon\">⚡</div>\n        <h3>Performance maximale</h3>\n        <p>Des produits tech sélectionnés pour leurs performances exceptionnelles et leur fiabilité sur le long terme.</p>\n      </div>\n      <div class=\"lp-feature-card\">\n        <div class=\"lp-feature-icon\">🛡️</div>\n        <h3>Qualité garantie</h3>\n        <p>Chaque produit est vérifié et testé avant expédition. Garantie constructeur incluse sur tous nos articles.</p>\n      </div>\n      <div class=\"lp-feature-card\">\n        <div class=\"lp-feature-icon\">🚀</div>\n        <h3>Livraison express</h3>\n        <p>Expédition sous 24h, livraison en 48h partout en France. Suivi en temps réel de votre commande.</p>\n      </div>\n      <div class=\"lp-feature-card\">\n        <div class=\"lp-feature-icon\">💬</div>\n        <h3>Support 7j/7</h3>\n        <p>Une équipe disponible chaque jour pour répondre à vos questions et vous accompagner après achat.</p>\n      </div>\n      <div class=\"lp-feature-card\">\n        <div class=\"lp-feature-icon\">🔄</div>\n        <h3>Retours faciles</h3>\n        <p>30 jours pour changer d'avis. Retour gratuit, remboursement immédiat. Sans conditions, sans questions.</p>\n      </div>\n      <div class=\"lp-feature-card\">\n        <div class=\"lp-feature-icon\">💳</div>\n        <h3>Paiement sécurisé</h3>\n        <p>Carte bancaire, PayPal, Apple Pay. Toutes les transactions sont chiffrées et sécurisées SSL.</p>\n      </div>\n    </div>\n  </section>\n\n  <!-- PRODUCT FOCUS -->\n  <section id=\"lp-product\">\n    <div class=\"lp-product-inner\">\n      <div class=\"lp-product-img-wrap\">🤖</div>\n      <div class=\"lp-product-info\">\n        <h2>Le produit<br><span>phare</span> du moment</h2>\n        <p>Notre bestseller absolu. Alliant design épuré et technologie de pointe, c'est le choix numéro un de nos clients les plus exigeants.</p>\n        <ul class=\"lp-checklist\">\n          <li><span class=\"lp-check\">✓</span> Compatible avec tous les appareils</li>\n          <li><span class=\"lp-check\">✓</span> Installation en moins de 5 minutes</li>\n          <li><span class=\"lp-check\">✓</span> Mises à jour gratuites à vie</li>\n          <li><span class=\"lp-check\">✓</span> Support technique inclus</li>\n        </ul>\n        <div class=\"lp-price-row\">\n          <span class=\"lp-price\">29,99 €</span>\n          <span class=\"lp-price-old\">59,99 €</span>\n          <span class=\"lp-price-save\">−50%</span>\n        </div>\n        <a href=\"https://iatechshop.myshopify.com/cart\" class=\"lp-btn-primary\">Ajouter au panier</a>\n      </div>\n    </div>\n  </section>\n\n  <!-- TESTIMONIALS --",
