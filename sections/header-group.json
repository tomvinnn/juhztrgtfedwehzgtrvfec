ound: var(--gray-200);\n    transition: background 0.2s, transform 0.2s;\n    cursor: pointer;\n  }\n  .gallery-dot.active { background: var(--black); transform: scale(1.3); }\n\n  .thumbs {\n    display: flex;\n    gap: 8px;\n    padding: 8px 16px 12px;\n    overflow-x: auto;\n    scrollbar-width: none;\n    background: white;\n  }\n  .thumbs::-webkit-scrollbar { display: none; }\n  .thumb {\n    width: 64px; height: 64px;\n    border-radius: 10px;\n    overflow: hidden;\n    flex-shrink: 0;\n    border: 2px solid transparent;\n    cursor: pointer;\n    background: var(--gray-100);\n    transition: border-color 0.15s;\n  }\n  .thumb.active { border-color: var(--black); }\n  .thumb img { width: 100%; height: 100%; object-fit: contain; padding: 5px; }\n\n  /* ── CONTENT ── */\n  .content { padding: 16px 16px 0; }\n  .brand { font-size: 11px; color: var(--gray-500); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 5px; font-weight: 500; }\n  .title { font-size: 24px; font-weight: 800; line-height: 1.2; margin-bottom: 6px; }\n  .title em { font-style: italic; font-weight: 300; font-size: 17px; display: block; margin-top: 2px; color: var(--gray-500); }\n  .stars-row { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }\n  .stars { color: #f4a100; font-size: 14px; }\n  .stars-count { font-size: 13px; font-weight: 600; color: var(--gray-500); }\n  .stars-count a { color: var(--gray-500); text-decoration: underline; }\n\n  /* ── COLOR BUTTONS ── */\n  .color-label { font-size: 13px; color: var(--gray-500); margin-bottom: 10px; font-weight: 500; }\n  .color-label strong { color: var(--black); font-weight: 700; }\n  .color-options { display: flex; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; }\n\n  .color-btn {\n    width: 44px; height: 44px;\n    border-radius: 50%;\n    border: 3px solid transparent;\n    cursor: pointer;\n    position: relative;\n    transition: border-color 0.2s, transform 0.15s;\n    flex-shrink: 0;\n  }\n  .color-btn:hover { transform: scale(1.08); }\n  .color-btn.active {\n    border-color: var(--black);\n    box-shadow: 0 0 0 2px white inset;\n  }\n  .color-btn[data-color=\"gris\"] { background: #b0aead; }\n  .color-btn[data-color=\"noir\"] { background: #1a1a1a; }\n  .color-btn[data-color=\"orange\"] { background: #e87722; }\n  .color-btn.active::after {\n    content: '✓';\n    position: absolute;\n    top: 50%; left: 50%;\n    transform: translate(-50%, -50%);\n    font-size: 16px;\n    font-weight: 700;\n    color: white;\n    text-shadow: 0 1px 2px rgba(0,0,0,0.4);\n  }\n  .color-btn[data-color=\"gris\"].active::after { color: #333; }\n\n  /* ── QTY ── */\n  .qty-row { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }\n  .qty-label { font-size: 13px; color: var(--gray-500); }\n  .qty-ctrl { display: flex; align-items: center; border: 1.5px solid var(--gray-200); border-radius: 10px; overflow: hidden; }\n  .qty-btn { width: 38px; height: 38px; background: none; border: none; font-size: 18px; font-weight: 700; cursor: pointer; font-family: var(--font); display: flex; align-items: center; justify-content: center; }\n  .qty-val { width: 36px; text-align: center; font-size: 15px; font-weight: 700; font-family: var(--font); }\n\n  /* ── OFFER CARD ── */\n  .offer-card {\n    background: #0a0a0a;\n    border-radius: var(--radius);\n    padding: 16px 14px;\n    margin-bottom: 14px;\n    position: relative;\n    overflow: hidden;\n  }\n  .offer-card::before {\n    content: '';\n    position: absolute;\n    top: -30px; right: -30px;\n    width: 140px; height: 140px;\n    border-radius: 50%;\n    background: rgba(229,62,62,0.15);\n  }\n  .offer-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }\n  .offer-card-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); display: flex; align-items: center; gap: 5px; }\n  .offer-card-label::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--red); animation: blink 1s infinite; }\n  .offer-card-badge { background: var(--red); color: white; font-size: 14px; font-weight: 800; border-radius: 8px; padding: 5px 12px; }\n  .offer-prices { display: flex; align-items: flex-end; gap: 10px; margin-bottom: 8px; }\n  .offer-price-now { font-size: 36px; font-weight: 800; color: white; line-height: 1; }\n  .offer-price-old { font-size: 15px; color: rgba(255,255,255,0.45); text-decoration: line-through; padding-bottom: 3px; }\n  .offer-saving { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; padding: 7px 10px; margin-bottom: 10px; }\n  .offer-saving-main { font-size: 13px; font-weight: 800; color: white; margin-bottom: 2px; }\n  .offer-saving-sub { font-size: 10px; color: rgba(255,255,255,0.55); }\n  /* TIMER COMPACT */\n  .offer-timer-row { display: flex; align-items: center; gap: 8px; }\n  .offer-timer-label { font-size: 10px; color: rgba(255,255,255,0.55); flex-shrink: 0; }\n  .offer-timer-blocks { display: flex; align-items: center; gap: 4px; }\n  .offer-timer-unit { background: rgba(255,255,255,0.1); border-radius: 6px; width: 38px; padding: 5px 3px 4px; text-align: center; }\n  .offer-timer-num { font-size: 18px; font-weight: 800; color: white; line-height: 1; display: block; }\n  .offer-timer-sub { display: block; font-size: 7px; font-weight: 500; color: rgba(255,255,255,0.45); letter-spacing: 0.08em; margin-top: 1px; text-transform: uppercase; }\n  .offer-timer-sep { font-size: 15px; font-weight: 700; color: rgba(255,255,255,0.4); margin-bottom: 2px; }\n  .offer-perks { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }\n  .offer-perk { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 6px; padding: 4px 8px; font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.75); white-space: nowrap; }\n\n  .sep { height: 1px; background: var(--gray-200); margin: 14px 0; }\n\n  /* ── BENEFITS ── */\n  .benefits { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }\n  .benefits li { display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 500; }\n  .check-icon { width: 20px; height: 20px; border-radius: 50%; background: var(--black); flex-shrink: 0; display: flex; align-items: center; justify-content: center; }\n  .check-icon svg { width: 11px; height: 11px; }\n\n  /* ── STOCK ── */\n  .stock-line { display: flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 600; color: var(--red); margin-bottom: 14px; }\n  .stock-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--red); flex-shrink: 0; animation: blink 1s infinite; }\n\n  /* ── CTA ── */\n  .cta-btn { display: block; width: 100%; background: var(--black); color: white; border: none; border-radius: var(--radius); padding: 17px; font-family: var(--font); font-size: 15px; font-weight: 700; letter-spacing: 0.04em; cursor: pointer; text-align: center; text-decoration: none; margin-bottom: 10px; text-transform: uppercase; }\n  .secure-note { display: flex; align-items: center; justify-content: center; gap: 5px; font-size: 11px; color: var(--gray-400); margin-bottom: 12px; }\n  .secure-note svg { width: 12px; height: 12px; }\n\n  /* ── PAYMENT IMAGE ── */\n  .payment-image-wrap { display: flex; justify-content: center; margin-bottom: 20px; }\n  .payment-image-wrap img { height: 32px; width: auto; object-fit: contain; }\n\n  /* ── TRUST ROW ── */\n  .trust-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; border-top: 1px solid var(--gray-200); border-bottom: 1px solid var(--gray-200); margin-bottom: 28px; }\n  .trust-item { padding: 14px 6px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 4px; border-right: 1px solid var(--gray-200); }\n  .trust-item:last-child { border-right: none; }\n  .trust-icon-sm { font-size: 20px; }\n  .trust-text { font-size: 9px; font-weight: 700; line-height: 1.3; }\n\n  /* ── FEATURES ── */\n  .features { padding: 0 16px; margin-bottom: 28px; }\n  .feature-block { margin-bottom: 24px; }\n  .feature-img { width: 100%; border-radius: var(--radius); overflow: hidden; background: var(--gray-100); aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }\n  .feature-img img { width: 100%; height: 100%; object-fit: contain; padding: 20px; }\n  .feature-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 5px; }\n  .feature-title { font-size: 18px; font-weight: 800; line-height: 1.25; margin-bottom: 7px; }\n  .feature-desc { font-size: 13px; color: var(--gray-500); line-height: 1.6; }\n\n  /* ── STATS ── */\n  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 16px; margin-bottom: 28px; }\n  .stat-card { background: var(--gray-100); border-radius: var(--radius); padding: 18px 12px; text-align: center; }\n  .stat-num { font-size: 30px; font-weight: 800; line-height: 1; margin-bottom: 4px; }\n  .stat-label { font-size: 11px; color: var(--gray-500); }\n\n  /* ── REVIEWS ── */\n  .section-label { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gray-500); margin-bottom: 5px; padding: 0 16px; }\n  .section-title { font-size: 20px; font-weight: 800; line-height: 1.2; margin-bottom: 16px; padding: 0 16px; }\n  .section-title em { font-style: italic; font-weight: 300; }\n  .reviews-scroll { display: flex; gap: 10px; overflow-x: auto; padding: 0 16px 12px; scrollbar-width: none; margin-bottom: 6px; }\n  .reviews-scroll::-webkit-scrollbar { display: none; }\n  .review-card { flex-shrink: 0; width: 210px; background: var(--gray-100); border-radius: var(--radius); padding: 13px; }\n  .review-stars { color: #f4a100; font-size: 12px; margin-bottom: 7px; }\n  .review-text { font-size: 12px; font-weight: 600; color: var(--black); line-height: 1.5; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.02em; }\n  .review-author { display: flex; align-items: center; gap: 7px; }\n  .review-avatar { width: 28px; height: 28px; border-radius: 50%; font-size: 11px; font-weight: 700; background: var(--gray-200); flex-shrink: 0; display: flex; align-items: center; justify-content: center; }\n  .review-name { font-size: 11px; font-weight: 600; }\n  .review-date { font-size: 10px; color: var(--gray-500); }\n\n  /* ── LIFESTYLE ── */\n  .lifestyle-strip { display: flex; overflow-x: auto; gap: 10px; padding: 0 16px 14px; scrollbar-width: none; margin-bottom: 22px; }\n  .lifestyle-strip::-webkit-scrollbar { display: none; }\n  .lifestyle-img { width: 160px; height: 160px; flex-shrink: 0; border-radius: var(--radius); object-fit: contain; background: var(--gray-100); padding: 12px; }\n\n  /* ── FAQ ── */\n  .faq-section-head { padding: 0 16px; margin-bottom: 10px; }\n  .faq-wrap { padding: 0 16px; margin-bottom: 32px; }\n  .faq-item { border-bottom: 1px solid var(--gray-200); }\n  .faq-q { width: 100%; background: none; border: none; text-align: left; padding: 15px 0; font-family: var(--font); font-size: 14px; font-weight: 700; color: var(--black); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }\n  .faq-icon { font-size: 18px; color: var(--gray-400); flex-shrink: 0; transition: transform 0.2s; }\n  .faq-item.open .faq-icon { transform: rotate(45deg); }\n  .faq-a { display: none; font-size: 13px; color: var(--gray-500); line-height: 1.65; padding-bottom: 15px; }\n  .faq-item.open .faq-a { display: block; }\n\n  /* ── TRUSTPILOT ── */\n  .tp-wrap { padding: 0 16px; margin-bottom: 32px; }\n  .tp-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }\n  .tp-logo { font-size: 13px; font-weight: 800; color: #00b67a; }\n  .tp-score { font-size: 13px; font-weight: 700; }\n  .tp-score span { color: var(--gray-500); font-weight: 400; }\n  .tp-global-stars { color: #00b67a; font-size: 16px; margin-bottom: 16px; }\n  .tp-card { background: var(--gray-100); border-radius: var(--radius); padding: 13px; margin-bottom: 10px; }\n  .tp-card-stars { color: #00b67a; font-size: 12px; margin-bottom: 5px; }\n  .tp-card-date { font-size: 10px; color: var(--gray-500); margin-bottom: 5px; }\n  .tp-card-text { font-size: 13px; font-weight: 500; line-height: 1.55; margin-bottom: 7px; }\n  .tp-card-name { font-size: 11px; font-weight: 700; color: var(--gray-500); }\n  .tp-verified { font-size: 10px; color: var(--gray-400); margin-top: 16px; text-align: center; }\n\n  /* ── FOOTER ── */\n  .footer { background: var(--black); color: white; padding: 22px 16px; text-align: center; }\n  .footer-logo { font-size: 13px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }\n  .footer-links { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; margin-bottom: 12px; }\n  .footer-links a { font-size: 11px; color: rgba(255,255,255,0.6); text-decoration: none; }\n  .footer-badges { display: flex; justify-content: center; gap: 12px; font-size: 11px; color: rgba(255,255,255,0.5); flex-wrap: wrap; margin-bottom: 10px; }\n  .footer-copy { font-size: 10px; color: rgba(255,255,255,0.35); }\n</style>\n</head>\n<body>\n\n<!-- ══ LIVE BANNER (tout en haut, fond noir) ══ -->\n<div class=\"live-banner\">\n  <div class=\"live-left\">\n    <div class=\"live-pill\">\n      <div class=\"live-dot\"></div>\n      <span class=\"live-pill-text\">Live</span>\n    </div>\n  </div>\n  <div class=\"live-banner-center\">\n    <div class=\"live-banner-main\">⚡ Offre Flash Spéciale Live</div>\n    <div class=\"live-banner-sub\">Ce soir uniquement · Stock limité</div>\n  </div>\n  <div class=\"live-badge\">−50%</div>\n</div>\n\n<!-- ══ HEADER (logo centré, agrandi) ══ -->\n<div class=\"header\">\n  <div class=\"header-ghost\"></div>\n  <div class=\"header-logo\">IA High Tec Shop</div>\n  <div class=\"header-icons\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.35-4.35\"/></svg>\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z\"/><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"/><path d=\"M16 10a4 4 0 01-8 0\"/></svg>\n  </div>\n</div>\n\n<!-- GALLERY SWIPE -->\n<div class=\"gallery-wrap\">\n  <div class=\"gallery-track\" id=\"galleryTrack\"></div>\n  <div class=\"gallery-dots\" id=\"galleryDots\"></div>\n  <div class=\"thumbs\" id=\"thumbs\"></div>\n</div>\n\n<!-- CONTENT -->\n<div class=\"content\">\n  <p class=\"brand\">IA High Tec Shop</p>\n  <h1 class=\"title\">Smart Watch 2.0<em>Compact, élégante, et intelligente</em></h1>\n  <div class=\"stars-row\">\n    <span class=\"stars\">★★★★★</span>\n    <span class=\"stars-count\"><a href=\"#avis-clients\">312 avis</a></span>\n  </div>\n\n  <div class=\"sep\" style=\"margin-top:2px;margin-bottom:12px;\"></div>\n  <p class=\"color-label\">Couleur : <strong id=\"color-name-top\">Gris</strong></p>\n  <div class=\"color-options\">\n    <button class=\"color-btn active\" data-color=\"gris\" onclick=\"selectColor('gris','Gris',this)\" title=\"Gris\"></button>\n    <button class=\"color-btn\" data-color=\"noir\" onclick=\"selectColor('noir','Noir',this)\" title=\"Noir\"></button>\n    <button class=\"color-btn\" data-color=\"orange\" onclick=\"selectColor('orange','Orange',this)\" title=\"Orange\"></button>\n  </div>\n  <div class=\"qty-row\">\n    <span class=\"qty-label\">Quantité</span>\n    <div class=\"qty-ctrl\">\n      <button class=\"qty-btn\" onclick=\"changeQty(-1)\">−</button>\n      <span class=\"qty-val\" id=\"qty\">1</span>\n      <button class=\"qty-btn\" onclick=\"changeQty(1)\">+</button>\n    </div>\n  </div>\n  <div class=\"sep\" style=\"margin-top:2px;\"></div>\n\n  <!-- OFFER CARD -->\n  <div class=\"offer-card\">\n    <div class=\"offer-card-top\">\n      <div class=\"offer-card-label\">Offre Flash Live</div>\n      <div class=\"offer-card-badge\">−50%</div>\n    </div>\n    <div class=\"offer-prices\">\n      <span class=\"offer-price-now\">64,90 €</span>\n      <span class=\"offer-price-old\">129,90 €</span>\n    </div>\n    <div class=\"offer-saving\">\n      <div class=\"offer-saving-main\">💰 Tu économises 65,00 € ce soir</div>\n      <div class=\"offer-saving-sub\">Prix normal : 129,90 € — Offre Live uniquement, non renouvelable</div>\n    </div>\n    <div class=\"offer-timer-row\">\n      <span class=\"offer-timer-label\">Expire dans</span>\n      <div class=\"offer-timer-blocks\">\n        <div class=\"offer-timer-unit\"><span class=\"offer-timer-num\" id=\"t-h\">01</span><span class=\"offer-timer-sub\">h</span></div>\n        <div class=\"offer-timer-sep\">:</div>\n        <div class=\"offer-timer-unit\"><span class=\"offer-timer-num\" id=\"t-min\">30</span><span class=\"offer-timer-sub\">min</span></div>\n        <div class=\"offer-timer-sep\">:</div>\n        <div class=\"offer-timer-unit\"><span class=\"offer-timer-num\" id=\"t-sec\">00</span><span class=\"offer-timer-sub\">sec</span></div>\n      </div>\n    </div>\n    <div class=\"offer-perks\">\n      <span class=\"offer-perk\">🚚 Livraison offerte</span>\n      <span class=\"offer-perk\">↩️ 60j remboursé</span>\n      <span class=\"offer-perk\">+ 3 bracelets</span>\n    </div>\n  </div>\n\n  <div class=\"sep\"></div>\n\n  <!-- BENEFITS -->\n  <ul class=\"benefits\">\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Compact et élégant — design ultra-fin</li>\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Traque ta santé en temps réel (cœur, SpO2, sommeil)</li>\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Durable et robuste — résistante à l'eau IP67</li>\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Compatible iPhone &amp; Android</li>\n    <li><div class=\"check-icon\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6l3 3 5-5\" stroke=\"white\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div>Appels &amp; SMS directement depuis le poignet</li>\n  </ul>\n\n  <div class=\"stock-line\"><div class=\"stock-dot\"></div>Stock restant : 12 Smart Watch uniquement</div>\n  <div class=\"sep\"></div>\n\n  <!-- CTA -->\n  <a href=\"#\" class=\"cta-btn\">🔒 Commander Ma Smart Watch 2.0</a>\n  <div class=\"secure-note\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0110 0v4\"/></svg>\n    Paiement 100% sécurisé · SSL\n  </div>\n  <div class=\"payment-image-wrap\">\n    <img src=\"data:image/png;base64,\" alt=\"Mastercard Visa Apple Pay Google Pay\">\n  </div>\n</div>\n\n<!-- TRUST ROW -->\n<div class=\"trust-row\">\n  <div class=\"trust-item\"><div class=\"trust-icon-sm\">🛡️</div><div class=\"trust-text\">Garantie<br>12 mois</div></div>\n  <div class=\"trust-item\"><div class=\"trust-icon-sm\">↩️</div><div class=\"trust-text\">Retour<br>60 jours</div></div>\n  <div class=\"trust-item\"><div class=\"trust-icon-sm\">🚚</div><div class=\"trust-text\">Livraison<br>gratuite</div></div>\n  <div class=\"trust-item\"><div class=\"trust-icon-sm\">💬</div><div class=\"trust-text\">Support<br>24h/24</div></div>\n</div>\n\n<!-- FEATURES -->\n<div class=\"features\">\n  <div class=\"feature-block\">\n    <div class=\"feature-img\"><img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960\" alt=\"Suivi santé\"></div>\n    <p class=\"feature-tag\">Suivi santé complet</p>\n    <h3 class=\"feature-title\">Ton corps. Sous surveillance constante.</h3>\n    <p class=\"feature-desc\">Fréquence cardiaque, saturation en oxygène (SpO2), qualité du sommeil, calories, pas — tout est mesuré en continu. La Smart Watch 2.0 t'alerte avant même que tu ne ressentes quelque chose.</p>\n  </div>\n  <div class=\"feature-block\">\n    <div class=\"feature-img\"><img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\" alt=\"Appels SMS\"></div>\n    <p class=\"feature-tag\">Connectivité totale</p>\n    <h3 class=\"feature-title\">Appels, SMS, notifs. Sans toucher ton téléphone.</h3>\n    <p class=\"feature-desc\">Réponds à tes appels et messages directement depuis ton poignet. Compatible iPhone et Android, elle te garde connecté partout, en toute discrétion.</p>\n  </div>\n  <div class=\"feature-block\">\n    <div class=\"feature-img\"><img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\" alt=\"Design robuste\"></div>\n    <p class=\"feature-tag\">Construction premium</p>\n    <h3 class=\"feature-title\">Robuste. Résistante. Faite pour durer.</h3>\n    <p class=\"feature-desc\">Résistance à l'eau IP67, verre minéral traité anti-rayures, boîtier en alliage aluminium. La Smart Watch 2.0 encaisse autant que toi.</p>\n  </div>\n</div>\n\n<!-- STATS -->\n<div class=\"stats-grid\">\n  <div class=\"stat-card\"><div class=\"stat-num\">+8 000</div><div class=\"stat-label\">clients satisfaits</div></div>\n  <div class=\"stat-card\"><div class=\"stat-num\">60j</div><div class=\"stat-label\">satisfait ou remboursé</div></div>\n  <div class=\"stat-card\"><div class=\"stat-num\">IP67</div><div class=\"stat-label\">résistance à l'eau</div></div>\n  <div class=\"stat-card\"><div class=\"stat-num\">98%</div><div class=\"stat-label\">clients satisfaits</div></div>\n</div>\n\n<!-- REVIEWS -->\n<div class=\"section-label\">Ils en parlent mieux que nous…</div>\n<div class=\"section-title\">Vos avis parlent <em>d'eux-mêmes.</em></div>\n<div class=\"reviews-scroll\">\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">La qualité est au rendez-vous. Je m'attendais pas à ça pour ce prix.</div><div class=\"review-author\"><div class=\"review-avatar\">TM</div><div><div class=\"review-name\">Thomas M.</div><div class=\"review-date\">Il y a 2 jours</div></div></div></div>\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">Reçu en 3 jours, livraison soignée. La montre est vraiment belle en vrai.</div><div class=\"review-author\"><div class=\"review-avatar\">SL</div><div><div class=\"review-name\">Sophie L.</div><div class=\"review-date\">Il y a 4 jours</div></div></div></div>\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">Le suivi du sommeil est bluffant. Je la porte même la nuit tellement elle est légère.</div><div class=\"review-author\"><div class=\"review-avatar\">KR</div><div><div class=\"review-name\">Kevin R.</div><div class=\"review-date\">Il y a 1 semaine</div></div></div></div>\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">J'ai acheté pour mon mari, il l'a plus quittée depuis. Cadeau parfait.</div><div class=\"review-author\"><div class=\"review-avatar\">MD</div><div><div class=\"review-name\">Marie D.</div><div class=\"review-date\">Il y a 10 jours</div></div></div></div>\n  <div class=\"review-card\"><div class=\"review-stars\">★★★★★</div><div class=\"review-text\">Appels et SMS directement depuis la montre, ça change la vie au sport.</div><div class=\"review-author\"><div class=\"review-avatar\">JB</div><div><div class=\"review-name\">Julien B.</div><div class=\"review-date\">Il y a 2 semaines</div></div></div></div>\n</div>\n\n<!-- LIFESTYLE -->\n<div class=\"lifestyle-strip\">\n  <img class=\"lifestyle-img\" src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960\" alt=\"\">\n  <img class=\"lifestyle-img\" src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\" alt=\"\">\n  <img class=\"lifestyle-img\" src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\" alt=\"\">\n</div>\n\n<!-- 2e CTA -->\n<div style=\"padding:0 16px;margin-bottom:32px;\">\n  <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;\">\n    <div>\n      <div style=\"font-size:28px;font-weight:800;\">64,90 €</div>\n      <div style=\"font-size:13px;color:var(--gray-400);text-decoration:line-through;\">129,90 €</div>\n    </div>\n    <div style=\"text-align:right;\">\n      <div style=\"font-size:11px;color:var(--gray-500);margin-bottom:4px;\">★★★★★ 312 avis</div>\n      <div style=\"font-size:11px;color:var(--red);font-weight:700;\">Stock : 12 restantes</div>\n    </div>\n  </div>\n  <a href=\"#\" class=\"cta-btn\">🔒 Commander Ma Smart Watch 2.0</a>\n  <div class=\"secure-note\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0110 0v4\"/></svg>\n    Paiement 100% sécurisé · Livraison offerte\n  </div>\n</div>\n\n<!-- FAQ -->\n<div class=\"faq-section-head\">\n  <p class=\"feature-tag\" style=\"margin-bottom:5px;\">Questions fréquentes</p>\n  <h2 style=\"font-size:20px;font-weight:800;line-height:1.2;\">Tout ce que vous devez savoir <em style=\"font-weight:300;font-style:italic;\">avant de commander</em></h2>\n</div>\n<div class=\"faq-wrap\" id=\"avis-clients\">\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">La Smart Watch 2.0 est-elle compatible avec mon téléphone ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Oui. Compatible avec tous les iPhone (iOS 9+) et smartphones Android (5.0+). Connexion Bluetooth stable, synchronisation en quelques secondes via l'application gratuite.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Est-ce que je peux vraiment passer des appels depuis la montre ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Absolument. Microphone et haut-parleur intégrés. Quand ton téléphone est à portée Bluetooth, tu peux décrocher, parler et raccrocher directement depuis ton poignet.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Quelle est l'autonomie de la batterie ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Entre 5 et 7 jours en utilisation normale. Avec le suivi santé actif en continu, comptez 3 à 4 jours. Recharge complète en moins de 2 heures via le chargeur magnétique inclus.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Elle résiste à l'eau ? Je peux la porter sous la douche ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Oui, certifiée IP67 — supporte une immersion jusqu'à 1 mètre pendant 30 minutes. Sous la douche et par temps de pluie, aucun problème. On déconseille en revanche la piscine ou la mer.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Quelle est la politique de retour ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">60 jours pour la retourner sans aucune justification. Remboursement 100% intégral frais de livraison inclus. En cas de produit défectueux à réception : remplacement immédiat sans retour préalable.</div></div>\n  <div class=\"faq-item\"><button class=\"faq-q\" onclick=\"toggleFaq(this)\">Le prix −50% va-t-il remonter après le live ?<span class=\"faq-icon\">+</span></button><div class=\"faq-a\">Oui. Le prix de <strong>64,90 €</strong> (au lieu de 129,90 €) est exclusivement réservé aux spectateurs du live. Une fois le timer écoulé, la remise ne peut plus être appliquée rétroactivement.</div></div>\n</div>\n\n<!-- TRUSTPILOT -->\n<div class=\"tp-wrap\">\n  <div class=\"tp-header\"><div class=\"tp-logo\">Trustpilot</div><div class=\"tp-score\">4,8 <span>/ 5</span></div></div>\n  <div class=\"tp-global-stars\">★★★★★</div>\n  <p style=\"font-size:11px;color:var(--gray-500);margin-bottom:18px;\">Basé sur <a href=\"#\" style=\"color:var(--gray-500);\">312 avis vérifiés</a></p>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 1 jour</div><div class=\"tp-card-text\">Je n'espérais pas une telle qualité à ce prix. Dès que je l'ai sortie du colis j'ai été bluffé. L'écran est net, la montre est légère et les fonctions de santé fonctionnent vraiment.</div><div class=\"tp-card-name\">Lucas M.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 2 jours</div><div class=\"tp-card-text\">Offert à ma fille pour son anniversaire. Elle l'adore. La couleur orange est magnifique et la livraison a été ultra rapide. Je recommande sans hésiter.</div><div class=\"tp-card-name\">Isabelle P.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 3 jours</div><div class=\"tp-card-text\">Le suivi du sommeil est top. Et pouvoir répondre aux appels depuis mon poignet à la salle de sport, ça change vraiment la vie. Aucun regret.</div><div class=\"tp-card-name\">Romain C.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 5 jours</div><div class=\"tp-card-text\">Commandé un mercredi soir, reçu le vendredi matin. Emballage soigné, produit conforme aux photos. La montre est solide, le bracelet est confortable. Très satisfait.</div><div class=\"tp-card-name\">Mathieu F.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 1 semaine</div><div class=\"tp-card-text\">Ça fait un mois que je la porte tous les jours. Pas une seule fois elle a eu un bug.</div><div class=\"tp-card-name\">Antoine L.</div></div>\n  <div class=\"tp-card\"><div class=\"tp-card-stars\">★★★★★</div><div class=\"tp-card-date\">Il y a 2 semaines</div><div class=\"tp-card-text\">J'ai remplacé une montre deux fois plus chère. La Smart Watch 2.0 fait exactement la même chose. SAV au top, ils ont répondu à mon message en 20 minutes.</div><div class=\"tp-card-name\">Pierre-Antoine K.</div></div>\n  <p class=\"tp-verified\">Avis collectés et vérifiés par Trustpilot</p>\n</div>\n\n<!-- FOOTER -->\n<div class=\"footer\">\n  <div class=\"footer-logo\">IA High Tec Shop</div>\n  <div class=\"footer-links\">\n    <a href=\"#\">Confidentialité</a><a href=\"#\">Remboursement</a><a href=\"#\">CGV</a><a href=\"#\">Livraison</a><a href=\"#\">Contact</a>\n  </div>\n  <div class=\"footer-badges\">\n    <span>🔒 Paiement sécurisé</span><span>↩️ 60j remboursé</span><span>🇫🇷 Support FR</span>\n  </div>\n  <div class=\"footer-copy\">© 2026 IA High Tec Shop — Tous droits réservés</div>\n</div>\n\n<script>\n  const galleryData = {\n    gris: [\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/pixelcut-export_44_8d6b7a85-4d5f-495b-b87b-6e4a75563bb6.webp?v=1732348960', alt: 'Smart Watch Gris' },\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715', alt: 'Smart Watch Gris détail' }\n    ],\n    noir: [\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/O1CN017e2Cmp2Dtzw4Yz7qK__2207705038668-0-cib_0a846c84-0535-4e84-9d6a-76f57b54b198.webp?v=1732348989', alt: 'Smart Watch Noir' },\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713', alt: 'Smart Watch Noir détail' }\n    ],\n    orange: [\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/O1CN017e2Cmp2Dtzw4Yz7qK__2207705038668-0-cib_0a846c84-0535-4e84-9d6a-76f57b54b198.webp?v=1732348989', alt: 'Smart Watch Orange' },\n      { src: 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715', alt: 'Smart Watch Orange détail' }\n    ]\n  };\n\n  let currentColor = 'gris';\n  let currentSlide = 0;\n\n  function buildGallery(color) {\n    const imgs = galleryData[color];\n    const track = document.getElementById('galleryTrack');\n    const dots = document.getElementById('galleryDots');\n    const thumbs = document.getElementById('thumbs');\n    track.innerHTML = '';\n    imgs.forEach((img) => {\n      const slide = document.createElement('div');\n      slide.className = 'gallery-slide';\n      const im = document.createElement('img');\n      im.src = img.src; im.alt = img.alt;\n      slide.appendChild(im); track.appendChild(slide);\n    });\n    dots.innerHTML = '';\n    imgs.forEach((_, i) => {\n      const dot = document.createElement('div');\n      dot.className = 'gallery-dot' + (i === 0 ? ' active' : '');\n      dot.onclick = () => goToSlide(i);\n      dots.appendChild(dot);\n    });\n    thumbs.innerHTML = '';\n    imgs.forEach((img, i) => {\n      const div = document.createElement('div');\n      div.className = 'thumb' + (i === 0 ? ' active' : '');\n      div.onclick = () => goToSlide(i);\n      const im = document.createElement('img');\n      im.src = img.src; im.alt = img.alt;\n      div.appendChild(im); thumbs.appendChild(div);\n    });\n    currentSlide = 0;\n    track.onscroll = () => {\n      const idx = Math.round(track.scrollLeft / track.offsetWidth);\n      if (idx !== currentSlide) { currentSlide = idx; updateGalleryUI(); }\n    };\n  }\n\n  function goToSlide(idx) {\n    const track = document.getElementById('galleryTrack');\n    track.scrollTo({ left: idx * track.offsetWidth, behavior: 'smooth' });\n    currentSlide = idx; updateGalleryUI();\n  }\n\n  function updateGalleryUI() {\n    document.querySelectorAll('.gallery-dot').forEach((d, i) => d.classList.toggle('active', i === currentSlide));\n    document.querySelectorAll('.thumb').forEach((t, i) => t.classList.toggle('active', i === currentSlide));\n  }\n\n  function selectColor(color, label, btn) {\n    document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('active'));\n    btn.classList.add('active');\n    document.getElementById('color-name-top').textContent = label;\n    currentColor = color;\n    buildGallery(color);\n  }\n\n  buildGallery('gris');\n\n  let total = 1 * 3600 + 30 * 60;\n  function updateTimer() {\n    const h = Math.floor(total / 3600);\n    const m = Math.floor((total % 3600) / 60);\n    const s = total % 60;\n    document.getElementById('t-h').textContent = String(h).padStart(2,'0');\n    document.getElementById('t-min').textContent = String(m).padStart(2,'0');\n    document.getElementById('t-sec').textContent = String(s).padStart(2,'0');\n    if (total > 0) total--; else total = 1 * 3600 + 30 * 60;\n  }\n  updateTimer(); setInterval(updateTimer, 1000);\n\n  let qty = 1;\n  function changeQty(d) { qty = Math.max(1, qty + d); document.getElementById('qty').textContent = qty; }\n\n  function toggleFaq(btn) { btn.parentElement.classList.toggle('open'); }\n</script>\n</body>\n</html>",
