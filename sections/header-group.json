ack);box-shadow:0 0 0 2px #fff inset;}\n\n/* ─── OFFER CARD ─── */\n.offer-card{background:var(--black);border-radius:15px;padding:20px;margin-bottom:20px;color:#fff;}\n.price-now{font-family:var(--font-serif);font-size:48px;line-height:1;}\n.price-old{text-decoration:line-through;color:rgba(255,255,255,0.4);font-size:16px;}\n.cta-btn{\n  display:block;width:100%;background:var(--accent);color:#fff;border:none;\n  border-radius:10px;padding:18px;font-size:14px;font-weight:700;\n  text-transform:uppercase;cursor:pointer;margin-top:15px;\n}\n\n/* ─── TRUST & FEATURES ─── */\n.trust-row{display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid var(--gray-100);padding:15px 0;}\n.trust-item{text-align:center;font-size:9px;color:var(--gray-500);}\n\n/* ─── STICKY BAR ─── */\n.sticky-bar{\n  position:fixed;bottom:0;left:0;right:0;background:#fff;\n  border-top:1px solid var(--gray-100);padding:12px 16px;z-index:9999;\n  display:flex;align-items:center;justify-content:space-between;\n  transform:translateY(100%);transition:transform .3s;\n}\n.sticky-bar.visible{transform:translateY(0);}\n.sticky-btn{background:var(--accent);color:#fff;border:none;border-radius:8px;padding:12px 20px;font-weight:600;cursor:pointer;}\n\n/* ─── POPUP ─── */\n.purchase-popup{\n  position:fixed;bottom:100px;left:16px;background:#fff;padding:10px;\n  border-radius:10px;box-shadow:0 5px 15px rgba(0,0,0,0.1);display:flex;\n  align-items:center;gap:10px;transform:translateX(-150%);transition: .5s;z-index:1000;\n}\n.purchase-popup.show{transform:translateX(0);}\n.popup-img{width:40px;height:40px;border-radius:5px;}\n</style>\n</head>\n<body>\n\n<div class=\"live-bar\">\n  <div class=\"live-left\"><div class=\"live-dot\"></div><span class=\"live-pill\">Live</span><span class=\"live-text\">Offre Spectateur</span></div>\n  <div class=\"live-badge\">−50%</div>\n</div>\n\n<div class=\"delivery-strip\">\n  <div class=\"delivery-steps\">\n    <div class=\"delivery-line\"></div>\n    <div class=\"