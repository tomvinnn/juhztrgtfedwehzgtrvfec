size:18px;font-weight:700;\">64,90 €</div><div style=\"font-size:11px;text-decoration:line-through;color:#999;\">129,90 €</div></div>\n  <button class=\"sticky-btn\" onclick=\"addToCart()\">Commander</button>\n</div>\n\n<div class=\"purchase-popup\" id=\"purchasePopup\">\n  <img class=\"popup-img\" id=\"popupImg\" src=\"\">\n  <div class=\"popup-text\"><strong id=\"popupName\"></strong> <span>vient de commander</span></div>\n</div>\n\n<script>\n(function(){\n\nwindow.addToCart = function() {\n  window.location.href = \"/cart\";\n};\n\nvar gallery = {\n  \"noir\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713\",alt:\"Noir 1\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_142202_2505abc6-1f9d-4225-8941-b8cd2f3aff86.png?v=1775399077\",alt:\"Noir 2\"}\n  ],\n  \"beige\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715\",alt:\"Beige 1\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_151814_eff117f5-d9e6-4d53-9776-1ffff80aa2fd.png?v=1775402484\",alt:\"Beige 2\"}\n  ],\n  \"orange\": [\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715\",alt:\"Orange 1\"},\n    {src:\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/Capture_d_ecran_2026-04-05_a_18.06.28.png?v=1775405214\",alt:\"Orange 2\"}\n  ]\n};\n\nfunction buildGallery(color) {\n  var imgs = gallery[color] || gallery[\"noir\"];\n  var track = document.getElementById(\"galleryTrack\");\n  var dots = document.getElementById(\"galleryDots\");\n  var thumbs = document.getElementById(\"galleryThumbs\");\n  if(!track) return;\n  track.innerHTML = \"\"; dots.innerHTML = \"\"; thumbs.innerHTML = \"\";\n  imgs.forEach(function(img, i) {\n    var slide = document.createElement(\"div\"); slide.className = \"gallery-slide\";\n    slide.innerHTML = '<img src=\"'+img.src+'\">';\n    track.appendChild(slide);\n    var dot = document.createElement(\"div\"); dot.className = \"g-dot\"+(i===0?\" active\":\"\");\n    dot.onclick = function(){ track.scrollTo({left: i * track.offsetWidth, behavior:\"smooth\"}); };\n    dots.appendChild(dot);\n    var th = document.createElement(\"div\"); th.className = \"g-thumb\"+(i===0?\" active\":\"\");\n    th.innerHTML = '<img src=\"'+img.src+'\">';\n    th.onclick = function(){ track.scrollTo({left: i * track.offsetWidth, behavior:\"smooth\"}); };\n    thumbs.appendChild(th);\n  });\n}\n\nwindow.selectColor = function(color, label, btn) {\n  document.querySelectorAll(\".c-btn\").forEach(b => b.classList.remove(\"active\"));\n  btn.classList.add(\"active\");\n  document.getElementById(\"color-name\").textContent = label;\n  buildGallery(color);\n};\n\nvar now = new Date();\ndocument.getElementById(\"d-date1\").textContent = now.getDate() + \"/\" + (now.getMonth()+1);\nvar d3 = new Date(); d3.setDate(now.getDate() + 4);\ndocument.getElementById(\"d-date3\").textContent = d3.getDate() + \"/\" + (d3.getMonth()+1);\n\nwindow.addEventListener(\"scroll\", function(){\n  var bar = document.getElementById(\"stickyBar\");\n  var card = document.getElementById(\"offerCard\");\n  if(card && bar) {\n    if(card.getBoundingClientRect().bottom < 0) bar.classList.add(\"visible\");\n    else bar.classList.remove(\"visible\");\n  }\n});\n\nvar names = [\"Thomas\", \"Marie\", \"Lucas\", \"Julie\", \"Enzo\"];\nsetInterval(function(){\n  var p = document.getElementById(\"purchasePopup\");\n  if(p) {\n    document.getElementById(\"popupName\").textContent = names[Math.floor(Math.random()*names.length)];\n    document.getElementById(\"popupImg\").src = gallery.noir[0].src;\n    p.classList.add(\"show\");\n    setTimeout(() => p.classList.remove(\"show\"), 4000);\n  }\n}, 15000);\n\nbuildGallery(\"noir\");\n})();\n</script>\n</body>\n</html>\n\n{% endif %}",
