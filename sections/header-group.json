ass=\"lp-badge\">Compatible iPhone / Android</div>\n        </div>\n\n        <div class=\"lp-stats\" id=\"preuves\">\n          <div class=\"lp-stat\"><strong>8k+</strong><span>clients</span></div>\n          <div class=\"lp-stat\"><strong>4,8/5</strong><span>avis</span></div>\n          <div class=\"lp-stat\"><strong>60j</strong><span>retour</span></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var el = document.getElementById('home-product-landing');\n  var p = window.location.pathname;\n  var isHome = (p === '/' || p === '/index' || p === '/index.html');\n  if (isHome) el.style.display = 'block';\n  else el.remove();\n})();\n</script>",
