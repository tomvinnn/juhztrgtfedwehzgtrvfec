        "liquid": "<div id=\"ci-widget\" style=\"padding: 1.5rem 0;\">\n\n  <h3 style=\"font-size: 18px; font-weight: 500; margin-bottom: 1.5rem;\">Simulateur d'intérêts composés</h3>\n\n  <div class=\"ci-row\">\n    <span class=\"ci-label\">Capital initial</span>\n    <input type=\"range\" id=\"ci-principal\" min=\"1000\" max=\"50000\" step=\"1000\" value=\"10000\">\n    <span class=\"ci-val\" id=\"ci-pOut\">10 000 €</span>\n  </div>\n  <div class=\"ci-row\">\n    <span class=\"ci-label\">Taux annuel</span>\n    <input type=\"range\" id=\"ci-rate\" min=\"1\" max=\"15\" step=\"0.5\" value=\"5\">\n    <span class=\"ci-val\" id=\"ci-rOut\">5 %</span>\n  </div>\n  <div class=\"ci-row\">\n    <span class=\"ci-label\">Durée</span>\n    <input type=\"range\" id=\"ci-years\" min=\"1\" max=\"50\" step=\"1\" value=\"20\">\n    <span class=\"ci-val\" id=\"ci-yOut\">20 ans</span>\n  </div>\n  <div class=\"ci-row\">\n    <span class=\"ci-label\">Versement mensuel</span>\n    <input type=\"range\" id=\"ci-monthly\" min=\"0\" max=\"1000\" step=\"50\" value=\"0\">\n    <span class=\"ci-val\" id=\"ci-mOut\">0 €</span>\n  </div>\n\n  <div class=\"ci-grid\">\n    <div class=\"ci-metric\">\n      <div class=\"ci-metric-label\">Valeur finale</div>\n      <div class=\"ci-metric-value\" id=\"ci-finalVal\">—</div>\n      <div class=\"ci-metric-sub\" id=\"ci-finalSub\"></div>\n    </div>\n    <div class=\"ci-metric\">\n      <div class=\"ci-metric-label\">Intérêts générés</div>\n      <div class=\"ci-metric-value\" id=\"ci-interestVal\">—</div>\n      <div class=\"ci-metric-sub\" id=\"ci-interestPct\"></div>\n    </div>\n  </div>\n\n  <div class=\"ci-legend\">\n    <span><span class=\"ci-swatch\" style=\"background:#378ADD;\"></span>Capital versé</span>\n    <span><span class=\"ci-swatch\" style=\"background:#1D9E75;\"></span>Intérêts composés</span>\n  </div>\n\n  <div style=\"position: relative; width: 100%; height: 260px;\">\n    <canvas id=\"ciChart\"></canvas>\n  </div>\n\n</div>\n\n<style>\n  #ci-widget { font-family: inherit; }\n  #ci-widget .ci-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 1.25rem 0; }\n  #ci-widget .ci-metric { background: #f5f5f5; border-radius: 8px; padding: 1rem; }\n  #ci-widget .ci-metric-label { font-size: 13px; color: #666; margin-bottom: 4px; }\n  #ci-widget .ci-metric-value { font-size: 22px; font-weight: 500; color: #111; }\n  #ci-widget .ci-metric-sub { font-size: 12px; color: #888; margin-top: 2px; }\n  #ci-widget .ci-row { display: flex; align-items: center; gap: 12px; margin-bottom: 1rem; }\n  #ci-widget .ci-label { font-size: 13px; color: #666; width: 140px; flex-shrink: 0; }\n  #ci-widget .ci-val { font-size: 13px; font-weight: 500; color: #111; min-width: 60px; text-align: right; }\n  #ci-widget .ci-row input[type=range] { flex: 1; accent-color: #378ADD; }\n  #ci-widget .ci-legend { display: flex; gap: 16px; margin-bottom: 8px; font-size: 12px; color: #666; flex-wrap: wrap; }\n  #ci-widget .ci-swatch { width: 10px; height: 10px; border-radius: 2px; display: inline-block; margin-right: 4px; }\n</style>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js\"></script>\n<script>\n(function() {\n  var fmt = function(v) {\n    return v.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });\n  };\n\n  function compute(P, r, years, m) {\n    var monthly = r / 100 / 12;\n    var data = [];\n    var balance = P;\n    for (var y = 0; y <= years; y++) {\n      data.push(Math.round(balance));\n      for (var mo = 0; mo < 12; mo++) {\n        balance = balance * (1 + monthly) + m;\n      }\n    }\n    return data;\n  }\n\n  function principalCurve(P, years, m) {\n    var data = [];\n    for (var y = 0; y <= years; y++) {\n      data.push(Math.round(P + m * 12 * y));\n    }\n    return data;\n  }\n\n  function getLabels(years) {\n    return Array.from({ length: years + 1 }, function(_, i) {\n      return i === 0 ? 'Maintenant' : i + ' an' + (i > 1 ? 's' : '');\n    });\n  }\n\n  var chart = new Chart(document.getElementById('ciChart'), {\n    type: 'line',\n    data: {\n      labels: getLabels(20),\n      datasets: [\n        {\n          label: 'Capital versé',\n          data: [],\n          borderColor: '#378ADD',\n          backgroundColor: 'rgba(55,138,221,0.12)',\n          fill: true,\n          tension: 0.3,\n          pointRadius: 0,\n          borderWidth: 2\n        },\n        {\n          label: 'Valeur totale',\n          data: [],\n          borderColor: '#1D9E75',\n          backgroundColor: 'rgba(29,158,117,0.12)',\n          fill: true,\n          tension: 0.3,\n          pointRadius: 0,\n          borderWidth: 2\n        }\n      ]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: false,\n      interaction: { intersect: false, mode: 'index' },\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          callbacks: {\n            label: function(ctx) { return ' ' + ctx.dataset.label + ' : ' + fmt(ctx.raw); }\n          }\n        }\n      },\n      scales: {\n        x: { ticks: { autoSkip: true, maxTicksLimit: 10, color: '#888' }, grid: { display: false } },\n        y: { ticks: { callback: function(v) { return fmt(v); }, color: '#888' }, grid: { color: 'rgba(128,128,128,0.1)' } }\n      }\n    }\n  });\n\n  function update() {\n    var P = +document.getElementById('ci-principal').value;\n    var r = +document.getElementById('ci-rate').value;\n    var y = +document.getElementById('ci-years').value;\n    var m = +document.getElementById('ci-monthly').value;\n\n    document.getElementById('ci-pOut').textContent = fmt(P);\n    document.getElementById('ci-rOut').textContent = r.toFixed(1) + ' %';\n    document.getElementById('ci-yOut').textContent = y + ' an' + (y > 1 ? 's' : '');\n    document.getElementById('ci-mOut').textContent = fmt(m);\n\n    var totalData = compute(P, r, y, m);\n    var capData = principalCurve(P, y, m);\n    var finalTotal = totalData[totalData.length - 1];\n    var totalCap = capData[capData.length - 1];\n    var interests = finalTotal - totalCap;\n\n    document.getElementById('ci-finalVal').textContent = fmt(finalTotal);\n    document.getElementById('ci-finalSub').textContent = 'contre ' + fmt(totalCap) + ' versés';\n    document.getElementById('ci-interestVal').textContent = fmt(interests);\n    document.getElementById('ci-interestPct').textContent = '× ' + (finalTotal / totalCap).toFixed(1) + ' votre mise';\n\n    chart.data.labels = getLabels(y);\n    chart.data.datasets[0].data = capData;\n    chart.data.datasets[1].data = totalData;\n    chart.update('none');\n  }\n\n  ['ci-principal','ci-rate','ci-years','ci-monthly'].forEach(function(id) {\n    document.getElementById(id).addEventListener('input', update);\n  });\n  update();\n})();\n</script>",
