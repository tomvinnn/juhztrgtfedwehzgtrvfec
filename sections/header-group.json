        "liquid": "{% if request.page_type == 'index' or request.page_type == 'product' %}\n<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Smart Watch 2.0 — IA High Tec Shop</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n#custom-product-page { display: none; }\n*{box-sizing:border-box;margin:0;padding:0;}\n:root{\n  --black:#080808;\n  --white:#fafafa;\n  --gray-50:#f5f5f5;\n  --gray-100:#ebebeb;\n  --gray-200:#d4d4d4;\n  --gray-400:#999;\n  --gray-500:#666;\n  --accent:#1a3fcc;\n  --blue:#1a3fcc;\n  --font-serif:'Cormorant Garamond',Georgia,serif;\n  --font-sans:'DM Sans',sans-serif;\n  --r:10px;\n}\nhtml,body{margin:0;padding:0;width:100%;overflow-x:hidden;}\nbody{font-family:var(--font-sans);background:var(--white);color:var(--black);padding-bottom:80px;}\n#shopify-section-header, #shopify-section-footer, .shopify-section-header, .shopify-section-footer { display: none !important; }\n\n.top-nav{\n  position:sticky;\n  top:0;\n  z-index:300;\n  display:flex;\n  align-items:center;\n  justify-content:space-between;\n  gap:10px;\n  padding:10px 14px;\n  background:#fff;\n  border-bottom:1px solid var(--gray-100);\n}\n.top-nav-links{\n  display:flex;\n  align-items:center;\n  gap:16px;\n  flex:1;\n  justify-content:center;\n}\n.top-nav-links a{\n  font-size:12px;\n  color:var(--black);\n  text-decoration:none;\n  font-weight:500;\n}\n.nav-icon-btn{\n  width:38px;\n  height:38px;\n  border-radius:10px;\n  border:1px solid var(--gray-100);\n  background:#fff;\n  color:var(--black);\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  text-decoration:none;\n  font-size:18px;\n  flex-shrink:0;\n}\n\n.live-bar{\n  background:var(--black);color:var(--white);\n  display:flex;align-items:center;justify-content:space-between;\n  padding:9px 16px;position:sticky;top:58px;z-index:200;\n  border-bottom:1px solid #1a1a1a;\n  width:100vw;margin-left:calc(-50vw + 50%);\n}\n.live-left{display:flex;align-items:center;gap:8px;}\n.live-dot{width:6px;height:6px;border-radius:50%;background:#fff;animation:blink 1s infinite;}\n@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.2;}}\n.live-pill{font-size:9px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,0.5);}\n.live-text{font-size:11px;font-weight:500;color:rgba(255,255,255,0.75);}\n.live-badge{font-size:11px;font-weight:700;letter-spacing:.06em;background:var(--accent);color:#fff;border-radius:5px;padding:3px 9px;}\n\n.delivery-strip{\n  background:#f8f8f8;border-bottom:1px solid var(--gray-100);\n  padding:14px 16px;\n}\n.delivery-title{font-size:9px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--gray-400);margin-bottom:12px;text-align:center;}\n.delivery-steps{display:flex;align-items:flex-start;justify-content:center;position:relative;gap:0;}\n.delivery-line{position:absolute;top:18px;left:calc(50% - 110px);right:calc(50% - 110px);height:2px;background:var(--blue);z-index:0;}\n.d-step{display:flex;flex-direction:column;align-items:center;flex:1;max-width:120px;position:relative;z-index:1;}\n.d-circle{width:36px;height:36px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;font-size:15px;margin-bottom:7px;flex-shrink:0;}\n.d-date{font-size:11px;font-weight:700;color:var(--black);margin-bottom:2px;}\n.d-label{font-size:9px;color:var(--gray-400);font-weight:500;}\n\n.gallery{position:relative;background:#f0f0f0;}\n.gallery-track{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;}\n.gallery-track::-webkit-scrollbar{display:none;}\n.gallery-slide{flex:0 0 100%;scroll-snap-align:start;aspect-ratio:1/1;overflow:hidden;}\n.gallery-slide img{width:100%;height:100%;object-fit:cover;object-position:center;display:block;}\n.gallery-dots{display:flex;justify-content:center;gap:5px;padding:8px 0 6px;background:#fff;}\n.g-dot{width:5px;height:5px;border-radius:50%;background:var(--gray-200);cursor:pointer;transition:all .2s;}\n.g-dot.active{background:var(--black);transform:scale(1.4);}\n.gallery-thumbs{display:flex;gap:6px;padding:6px 14px 12px;overflow-x:auto;scrollbar-width:none;background:#fff;}\n.gallery-thumbs::-webkit-scrollbar{display:none;}\n.g-thumb{width:56px;height:56px;border-radius:8px;overflow:hidden;flex-shrink:0;border:1.5px solid transparent;cursor:pointer;background:var(--gray-50);transition:border-color .15s;}\n.g-thumb.active{border-color:var(--black);}\n.g-thumb img{width:100%;height:100%;object-fit:cover;display:block;}\n\n.content{padding:20px 16px 0;}\n.brand{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--gray-400);margin-bottom:6px;font-weight:500;}\n.product-title{font-family:var(--font-serif);font-size:28px;font-weight:300;line-height:1.15;margin-bottom:4px;letter-spacing:-.01em;}\n.product-sub{font-size:12px;color:var(--gray-400);font-weight:400;margin-bottom:12px;line-height:1.5;}\n.stars-row{display:flex;align-items:center;gap:7px;margin-bottom:16px;}\n.stars{color:#c8a85a;font-size:12px;letter-spacing:1px;}\n.stars-txt{font-size:11px;color:var(--gray-400);}\n.stars-txt a{color:var(--gray-400);text-decoration:underline;}\n.sep{height:1px;background:var(--gray-100);margin:14px 0;}\n\n.color-label{font-size:11px;color:var(--gray-400);margin-bottom:9px;font-weight:500;}\n.color-label b{color:var(--black);font-weight:600;}\n.color-buy-row{\n  display:flex;\n  align-items:flex-end;\n  justify-content:space-between;\n  gap:12px;\n  margin-bottom:16px;\n}\n.color-opts{display:flex;gap:9px;}\n.c-btn{\n  width:36px;height:36px;border-radius:50%;border:2px solid transparent;\n  cursor:pointer;position:relative;transition:all .2s;outline:none;flex-shrink:0;\n}\n.c-btn:hover{transform:scale(1.1);}\n.c-btn.active{border-color:var(--black);box-shadow:0 0 0 2px #fff inset;}\n.c-btn.active::after{content:'✓';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:13px;font-weight:700;color:#fff;text-shadow:0 1px 3px rgba(0,0,0,0.5);}\n\n.mini-cta-btn{\n  background:var(--accent);\n  color:#fff;\n  border:none;\n  border-radius:9px;\n  padding:12px 16px;\n  font-family:var(--font-sans);\n  font-size:12px;\n  font-weight:600;\n  cursor:pointer;\n  text-transform:uppercase;\n  letter-spacing:.04em;\n  white-space:nowrap;\n  min-width:120px;\n}\n.mini-cta-btn:hover{opacity:.92;transform:translateY(-1px);}\n.mini-cta-btn:active{transform:scale(.98);}\n\n.qty-row{display:flex;align-items:center;gap:12px;margin-bottom:16px;}\n.qty-label{font-size:11px;color:var(--gray-400);}\n.qty-ctrl{display:flex;align-items:center;border:1px solid var(--gray-200);border-radius:8px;overflow:hidden;}\n.qty-btn{width:34px;height:34px;background:none;border:none;font-size:16px;font-weight:500;cursor:pointer;font-family:var(--font-sans);color:var(--black);display:flex;align-items:center;justify-content:center;}\n.qty-val{width:32px;text-align:center;font-size:13px;font-weight:600;}\n\n.offer-card{\n  background:var(--black);border-radius:12px;padding:18px 16px;\n  margin-bottom:14px;position:relative;overflow:hidden;\n}\n.offer-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}\n.offer-tag{font-size:9px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,0.4);display:flex;align-items:center;gap:5px;}\n.offer-tag::before{content:'';width:5px;height:5px;border-radius:50%;background:#fff;animation:blink 1s infinite;}\n.offer-pct{font-size:12px;font-weight:700;background:var(--accent);color:#fff;border-radius:5px;padding:3px 9px;letter-spacing:.04em;}\n.offer-prices{display:flex;align-items:flex-end;gap:10px;margin-bottom:10px;}\n.price-now{font-family:var(--font-serif);font-size:42px;font-weight:400;color:#fff;line-height:1;letter-spacing:-.02em;}\n.price-old{font-size:14px;color:rgba(255,255,255,0.3);text-decoration:line-through;padding-bottom:6px;}\n.offer-saving{\n  background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);\n  border-radius:8px;padding:9px 12px;margin-bottom:14px;\n  font-size:12px;color:rgba(255,255,255,0.6);line-height:1.5;\n}\n.offer-saving b{color:#4ade80;font-weight:600;}\n.offer-divider{height:1px;background:rgba(255,255,255,0.08);margin-bottom:14px;}\n\n.cta-btn{\n  display:block;width:100%;background:var(--accent);color:#fff;border:none;\n  border-radius:9px;padding:15px;font-family:var(--font-sans);font-size:13px;\n  font-weight:600;letter-spacing:.04em;cursor:pointer;text-align:center;\n  text-transform:uppercase;transition:opacity .2s,transform .15s;\n}\n.cta-btn:hover{opacity:.92;transform:translateY(-1px);}\n.cta-btn:active{transform:scale(.98);}\n\n.secure-note{display:flex;align-items:center;justify-content:center;gap:5px;font-size:10px;color:var(--gray-400);margin-top:10px;}\n.secure-note svg{width:10px;height:10px;}\n.payment-row{display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap;margin-top:10px;padding-bottom:4px;}\n.pay-logo{height:24px;background:var(--gray-50);border:1px solid var(--gray-100);border-radius:5px;display:flex;align-items:center;justify-content:center;padding:3px 8px;}\n.pay-logo svg{height:14px;width:auto;}\n\n.trust-row{display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid var(--gray-100);border-bottom:1px solid var(--gray-100);}\n.trust-item{padding:14px 4px;text-align:center;border-right:1px solid var(--gray-100);}\n.trust-item:last-child{border-right:none;}\n.trust-icon{font-size:16px;margin-bottom:4px;}\n.trust-text{font-size:9px;font-weight:500;line-height:1.4;color:var(--gray-500);}\n\n.benefits-section{padding:32px 16px 0;}\n.section-label{font-size:9px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--gray-400);margin-bottom:5px;}\n.section-title{font-family:var(--font-serif);font-size:24px;font-weight:300;line-height:1.2;margin-bottom:20px;letter-spacing:-.01em;}\n.benefits-list{display:flex;flex-direction:column;gap:1px;background:var(--gray-100);border-radius:12px;overflow:hidden;margin-bottom:32px;}\n.benefit-item{background:#fff;padding:14px 16px;display:flex;align-items:flex-start;gap:12px;}\n.b-icon{width:32px;height:32px;background:var(--gray-50);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px;}\n.b-text strong{display:block;font-size:13px;font-weight:600;margin-bottom:2px;}\n.b-text span{font-size:12px;color:var(--gray-500);line-height:1.5;}\n\n.features{padding:0 16px 32px;}\n.feature-block{margin-bottom:28px;}\n.feature-img{width:100%;border-radius:10px;overflow:hidden;background:var(--gray-50);aspect-ratio:4/3;margin-bottom:12px;}\n.feature-img img{width:100%;height:100%;object-fit:cover;display:block;}\n.feature-tag{font-size:9px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--gray-400);margin-bottom:4px;}\n.feature-title{font-family:var(--font-serif);font-size:20px;font-weight:300;line-height:1.2;margin-bottom:6px;}\n.feature-desc{font-size:12px;color:var(--gray-500);line-height:1.65;}\n\n.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:0 16px 32px;}\n.stat-card{background:var(--gray-50);border-radius:10px;padding:18px 12px;text-align:center;border:1px solid var(--gray-100);}\n.stat-num{font-family:var(--font-serif);font-size:32px;font-weight:400;line-height:1;margin-bottom:4px;}\n.stat-label{font-size:10px;color:var(--gray-400);}\n\n.reviews-section{margin-bottom:32px;}\n.reviews-header{display:flex;align-items:center;justify-content:space-between;padding:0 16px;margin-bottom:4px;}\n.tp-logo{font-size:13px;font-weight:700;color:#00b67a;letter-spacing:-.01em;}\n.tp-score{font-size:12px;color:var(--gray-500);}\n.reviews-scroll-outer{overflow:hidden;width:100%;}\n.reviews-track{display:flex;gap:10px;width:max-content;animation:scrollLeft 50s linear infinite;padding:12px 16px;}\n.reviews-track:hover{animation-play-state:paused;}\n@keyframes scrollLeft{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}\n.review-card{flex-shrink:0;width:220px;background:#fff;border:1px solid var(--gray-100);border-radius:10px;padding:14px;}\n.rv-stars{color:#c8a85a;font-size:11px;margin-bottom:8px;}\n.rv-text{font-size:11px;color:var(--gray-500);line-height:1.6;margin-bottom:10px;}\n.rv-footer{display:flex;align-items:center;gap:7px;}\n.rv-avatar{width:26px;height:26px;border-radius:50%;background:var(--black);color:#fff;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}\n.rv-name{font-size:10px;font-weight:600;}\n.rv-verified{font-size:9px;color:#00b67a;}\n\n.faq-section{padding:0 16px;margin-bottom:40px;}\n.faq-item{border-bottom:1px solid var(--gray-100);}\n.faq-q{width:100%;background:none;border:none;text-align:left;padding:14px 0;font-family:var(--font-sans);font-size:13px;font-weight:500;color:var(--black);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:12px;}\n.faq-icon{font-size:16px;color:var(--gray-400);flex-shrink:0;transition:transform .2s;}\n.faq-item.open .faq-icon{transform:rotate(45deg);}\n.faq-a{display:none;font-size:12px;color:var(--gray-500);line-height:1.65;padding-bottom:14px;}\n.faq-item.open .faq-a{display:block;}\n\n.cta2-block{padding:0 16px 0;margin-bottom:40px;}\n.cta2-inner{background:var(--gray-50);border:1px solid var(--gray-100);border-radius:12px;padding:16px;margin-bottom:12px;}\n.cta2-row{display:flex;align-items:center;justify-content:space-between;}\n.cta2-price-now{font-family:var(--font-serif);font-size:32px;font-weight:400;}\n.cta2-price-old{font-size:12px;color:var(--gray-400);text-decoration:line-through;}\n.cta2-right{text-align:right;}\n.cta2-stars{color:#c8a85a;font-size:11px;}\n.cta2-reviews{font-size:10px;color:var(--gray-400);margin-top:2px;}\n.cta2-stock{font-size:10px;color:var(--accent);font-weight:600;margin-top:3px;}\n\nfooter{background:var(--black);color:#fff;padding:28px 16px;text-align:center;}\n.footer-logo{font-family:var(--font-serif);font-size:16px;font-weight:400;letter-spacing:.08em;margin-bottom:16px;color:rgba(255,255,255,.7);}\n.footer-links{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;margin-bottom:14px;}\n.footer-links a{font-size:10px;color:rgba(255,255,255,.4);text-decoration:none;}\n.footer-copy{font-size:9px;color:rgba(255,255,255,.2);}\n\n.sticky-bar{\n  position:fixed;bottom:0;left:0;right:0;background:var(--white);\n  border-top:1px solid var(--gray-100);padding:10px 16px;z-index:9999;\n  display:flex;align-items:center;gap:10px;\n  box-shadow:0 -4px 20px rgba(0,0,0,.06);\n  transform:translateY(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);\n}\n.sticky-bar.visible{transform:translateY(0);}\n.sticky-btn{background:#1a3fcc;color:#fff;border:none;border-radius:8px;padding:11px 18px;font-family:var(--font-sans);font-size:12px;font-weight:600;cursor:pointer;text-transform:uppercase;letter-spacing:.04em;white-space:nowrap;transition:opacity .2s;}\n\n.offer-timer{display:flex;align-items:center;gap:10px;margin-bottom:14px;}\n.offer-timer-label{font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.4);flex-shrink:0;}\n.offer-timer-blocks{display:flex;align-items:center;gap:4px;}\n.ot-unit{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);border-radius:6px;min-width:34px;padding:5px 4px;text-align:center;}\n.ot-num{font-family:var(--font-serif);font-size:17px;font-weight:400;color:#fff;line-height:1;display:block;}\n.ot-sub{display:block;font-size:6px;letter-spacing:.1em;color:rgba(255,255,255,.3);text-transform:uppercase;margin-top:2px;}\n.ot-sep{font-size:14px;color:rgba(255,255,255,.3);padding-bottom:4px;}\n\n.purchase-popup{\n  position:fixed;bottom:90px;left:16px;z-index:10000;\n  background:#fff;border:1px solid var(--gray-100);border-radius:12px;\n  padding:10px 12px;display:flex;align-items:center;gap:10px;\n  box-shadow:0 4px 20px rgba(0,0,0,.12);max-width:260px;\n  transform:translateX(-120%);transition:transform .4s cubic-bezier(.34,1.56,.64,1);\n}\n.purchase-popup.show{transform:translateX(0);}\n.popup-img{width:44px;height:44px;border-radius:8px;object-fit:cover;flex-shrink:0;}\n.popup-text strong{display:block;font-size:11px;font-weight:600;color:var(--black);}\n.popup-text span{font-size:10px;color:var(--gray-400);}\n.popup-dot{width:5px;height:5px;border-radius:50%;background:#22c55e;flex-shrink:0;margin-left:auto;animation:blink 1s infinite;}\n.stock-line{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:500;color:var(--accent);margin-bottom:14px;}\n.stock-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;animation:blink 1s infinite;}\n</style>\n</head>\n<body>\n\n<div id=\"custom-product-page\">\n\n<div class=\"top-nav\">\n  <button class=\"nav-icon-btn\" type=\"button\" aria-label=\"Menu\">☰</button>\n  <div class=\"top-nav-links\">\n    <a href=\"/\">Accueil</a>\n    <a href=\"/collections/all\">Produit</a>\n    <a href=\"/pages/contact\">Contact</a>\n  </div>\n  <a class=\"nav-icon-btn\" href=\"/cart\" aria-label=\"Panier\">🛒</a>\n</div>\n\n<div class=\"live-bar\">\n  <div class=\"live-left\">\n    <div class=\"live-dot\"></div>\n    <span class=\"live-pill\">Live</span>\n    <span class=\"live-text\">Offre Flash — ce soir uniquement</span>\n  </div>\n  <div class=\"live-badge\">−50%</div>\n</div>\n\n<div class=\"delivery-strip\">\n  <div class=\"delivery-title\">Livraison estimée</div>\n  <div class=\"delivery-steps\">\n    <div class=\"delivery-line\"></div>\n    <div class=\"d-step\">\n      <div class=\"d-circle\">🛒</div>\n      <div class=\"d-date\" id=\"d-date1\"></div>\n      <div class=\"d-label\">Commandée</div>\n    </div>\n    <div class=\"d-step\">\n      <div class=\"d-circle\">🚚</div>\n      <div class=\"d-date\" id=\"d-date2\"></div>\n      <div class=\"d-label\">Expédiée</div>\n    </div>\n    <div class=\"d-step\">\n      <div class=\"d-circle\">🎁</div>\n      <div class=\"d-date\" id=\"d-date3\"></div>\n      <div class=\"d-label\">Livrée</div>\n    </div>\n  </div>\n</div>\n\n<div class=\"gallery\">\n  <div class=\"gallery-track\" id=\"galleryTrack\"></div>\n  <div class=\"gallery-dots\" id=\"galleryDots\"></div>\n  <div class=\"gallery-thumbs\" id=\"galleryThumbs\"></div>\n</div>\n\n<div class=\"content\">\n  <p class=\"brand\">IA High Tec Shop</p>\n  <h1 class=\"product-title\">Smart Watch 2.0</h1>\n  <p class=\"product-sub\">Santé. Connectivité. Performance.<br>Tout au poignet.</p>\n  <div class=\"stars-row\">\n    <span class=\"stars\">★★★★★</span>\n    <span class=\"stars-txt\"><a href=\"#avis\">312 avis vérifiés</a></span>\n  </div>\n  <div class=\"sep\" style=\"margin:0 0 14px;\"></div>\n\n  <div class=\"color-buy-row\">\n    <div>\n      <p class=\"color-label\">Couleur : <b id=\"color-name\">Noir</b></p>\n      <div class=\"color-opts\">\n        <button class=\"c-btn active\" onclick=\"selectColor('noir','Noir',this)\" title=\"Noir\" style=\"background:#1a1a1a;\"></button>\n        <button class=\"c-btn\" onclick=\"selectColor('beige','Beige',this)\" title=\"Beige\" style=\"background:#d4c5a9;\"></button>\n        <button class=\"c-btn\" onclick=\"selectColor('orange','Orange',this)\" title=\"Orange\" style=\"background:#e87722;\"></button>\n      </div>\n    </div>\n\n    <button type=\"button\" class=\"mini-cta-btn\" onclick=\"addToCart()\">Commander</button>\n  </div>\n\n  <div class=\"qty-row\">\n    <span class=\"qty-label\">Quantité</span>\n    <div class=\"qty-ctrl\">\n      <button class=\"qty-btn\" onclick=\"changeQty(-1)\">−</button>\n      <span class=\"qty-val\" id=\"qty\">1</span>\n      <button class=\"qty-btn\" onclick=\"changeQty(1)\">+</button>\n    </div>\n