        "liquid": "<style>\n@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;700;800&family=Inter:wght@300;400;500&display=swap');\n\n#lp-root * { box-sizing: border-box; margin: 0; padding: 0; }\n#lp-root {\n  font-family: 'Inter', sans-serif;\n  background: #0a0a0a;\n  color: #f0ece4;\n  overflow-x: hidden;\n}\n\n/* HERO */\n#lp-hero {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  text-align: center;\n  padding: 6rem 2rem 4rem;\n  position: relative;\n  background: #0a0a0a;\n}\n#lp-hero::before {\n  content: '';\n  position: absolute;\n  top: -200px; left: 50%; transform: translateX(-50%);\n  width: 800px; height: 800px;\n  background: radial-gradient(circle, rgba(255,200,80,0.08) 0%, transparent 70%);\n  pointer-events: none;\n}\n#lp-badge {\n  display: inline-block;\n  border: 1px solid rgba(255,200,80,0.4);\n  color: #ffc850;\n  font-size: 11px;\n  letter-spacing: 0.15em;\n  text-transform: uppercase;\n  padding: 6px 16px;\n  border-radius: 100px;\n  margin-bottom: 2rem;\n  animation: lp-fade 0.8s ease both;\n}\n#lp-hero h1 {\n  font-family: 'Syne', sans-serif;\n  font-weight: 800;\n  font-size: clamp(2.8rem, 8vw, 6rem);\n  line-height: 1.05;\n  letter-spacing: -0.03em;\n  max-width: 800px;\n  margin-bottom: 1.5rem;\n  animation: lp-fade 0.8s 0.1s ease both;\n}\n#lp-hero h1 span { color: #ffc850; }\n#lp-hero p {\n  font-size: clamp(1rem, 2vw, 1.2rem);\n  color: rgba(240,236,228,0.55);\n  max-width: 520px;\n  line-height: 1.7;\n  margin-bottom: 2.5rem;\n  font-weight: 300;\n  animation: lp-fade 0.8s 0.2s ease both;\n}\n.lp-btn-primary {\n  display: inline-block;\n  background: #ffc850;\n  color: #0a0a0a;\n  font-family: 'Syne', sans-serif;\n  font-weight: 700;\n  font-size: 15px;\n  letter-spacing: 0.04em;\n  padding: 16px 40px;\n  border-radius: 100px;\n  text-decoration: none;\n  transition: transform 0.15s, box-shadow 0.15s;\n  animation: lp-fade 0.8s 0.3s ease 