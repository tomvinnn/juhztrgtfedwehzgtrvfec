        "liquid": "<div id=\"ia-final-cart-v3\">\n  <style>\n    /* VARIABLES & FONTS */\n    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500;700&display=swap');\n    \n    #ia-final-cart-v3 {\n      --black: #080808; --white: #fafafa; --gray-50: #f5f5f5; --gray-100: #ebebeb;\n      --gray-200: #d4d4d4; --gray-400: #999; --gray-500: #666; --accent: #1a3fcc;\n      --green: #22c55e; --font-serif: 'Cormorant Garamond', Georgia, serif;\n      --font-sans: 'DM Sans', sans-serif;\n      font-family: var(--font-sans); background: var(--white); color: var(--black);\n      margin: 0; padding-bottom: 120px;\n    }\n\n    /* Masquer le thème pour le look application mobile */\n    header, footer, .shopify-section-header, .shopify-section-footer { display: none !important; }\n\n    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }\n\n    /* ── BARRE DE LIVRAISON & CHRONO ── */\n    .shipping-banner { background: var(--black); color: #fff; padding: 12px 16px; position: sticky; top: 0; z-index: 200; border-bottom: 1px solid #1a1a1a; }\n    .shipping-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }\n    .shipping-left { display: flex; align-items: center; gap: 7px; font-size: 11px; font-weight: 500; }\n    .shipping-timer { display: flex; align-items: center; gap: 4px; }\n    .t-unit { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.12); border-radius: 4px; min-width: 28px; padding: 4px 2px; text-align: center; }\n    .t-num { font-family: var(--font-serif); font-size: 13px; color: #fff; display: block; line-height: 1; }\n    .t-sub { font-size: 5px; text-transform: uppercase; opacity: 0.4; display: block; margin-top: 1px; }\n    .progress-bar { height: 2px; background: rgba(255,255,255,0.15); border-radius: 1px; overflow: hidden; }\n    .progress-fill { height: 100%; background: var(--accent); width: 100%; transition: width 1s linear; }\n\n    /* ── HEADER NAVIGATION ── */\n    .cart-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid var(--gray-100); }\n    .back-btn { font-size: 11px; color: var(--gray-400); text-decoration: none; font-weight: 500; }\n    .cart-title { font-family: var(--font-serif); font-size: 20px; font-weight: 300; }\n    .cart-count { font-size: 11px; color: var(--gray-400); font-weight: 500; }\n\n    /* ── BANDEAU URGENCE ── */\n    .urgency-strip { background: rgba(26,63,204,0.06); padding: 10px 16px; display: flex; align-items: center; gap: 7px; border-bottom: 1px solid rgba(26,63,204,0.1); }\n    .u-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: blink 1s infinite; }\n    .u-text { font-size: 11px; font-weight: 600; color: var(--accent); }\n\n    /* ── PRODUITS (DYNAMIQUES) ── */\n    .cart-items { padding: 0 16px; }\n    .cart-item { display: flex; gap: 14px; padding: 18px 0; border-bottom: 1px solid var(--gray-100); }\n    .item-img { width: 85px; height: 85px; border-radius: 12px; overflow: hidden; border: 1px solid var(--gray-100); flex-shrink: 0; background: #fff; }\n    .item-img img { width: 100%; height: 100%; object-fit: cover; }\n    .item-info { flex: 1; min-width: 0; }\n    .item-brand { font-size: 9px; letter-spacing: .12em; text-transform: uppercase; color: var(--gray-400); margin-bottom: 2px; }\n    .item-name { font-family: var(--font-serif); font-size: 18px; font-weight: 300; line-height: 1.2; margin-bottom: 4px; }\n    .item-variant { font-size: 11px; color: var(--gray-500); margin-bottom: 8px; }\n    .item-badge { display: inline-flex; align-items: center; background: rgba(26,63,204,0.08); border-radius: 4px; padding: 3px 7px; font-size: 9px; font-weight: 700; color: var(--accent); margin-bottom: 10px; }\n    .item-bottom { display: flex; align-items: center; justify-content: space-between; }\n    .item-price { font-family: var(--font-serif); font-size: 21px; font-weight: 400; }\n    .item-qty-control { display: flex; align-items: center; border: 1px solid var(--gray-200); border-radius: 8px; overflow: hidden; height: 32px; }\n    .qty-btn { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; text-decoration: none; color: #000; font-size: 18px; background: #fff; }\n    .qty-val { width: 30px; text-align: center; font-size: 12px; font-weight: 700; }\n\n    /* ── UPSELL ── */\n    .upsell-section { margin: 15px 16px; background: var(--gray-50); border: 1px solid var(--gray-100); border-radius: 14px; padding: 15px; }\n    .upsell-head { font-size: 10px; font-weight: 800; text-transform: uppercase; color: var(--gray-400); margin-bottom: 12px; letter-spacing: 1px; }\n    .upsell-card { display: flex; align-items: center; gap: 12px; }\n    .upsell-img { width: 55px; height: 55px; border-radius: 10px; border: 1px solid var(--gray-100); background: #fff; overflow: hidden; }\n    .upsell-img img { width:100%; height:100%; object-fit:cover; }\n    .upsell-add-btn { background: var(--black); color: #fff; border: none; border-radius: 8px; padding: 9px 16px; font-size: 11px; font-weight: 700; cursor: pointer; }\n\n    /* ── RÉCAPITULATIF ── */\n    .summary-section { padding: 20px 16px; }\n    .summary-row { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 14px; }\n    .summary-total { display: flex; justify-content: space-between; margin-top: 15px; padding-top: 15px; border-top: 2px solid var(--gray-100); }\n    .total-price-val { font-family: var(--font-serif); font-size: 30px; font-weight: 400; }\n\n    /* ── RÉASSURANCE ── */\n    .trust-grid { display: flex; justify-content: space-between; gap: 5px; margin: 20px 0; }\n    .trust-item { flex: 1; background: var(--gray-50); border: 1px solid var(--gray-100); border-radius: 10px; padding: 10px 5px; text-align: center; }\n    .trust-icon { font-size: 16px; margin-bottom: 4px; display: block; }\n    .trust-txt { font-size: 8px; font-weight: 700; color: var(--gray-500); line-height: 1.2; text-transform: uppercase; }\n\n    /* ── BOUTON PAIEMENT ── */\n    .checkout-main-btn { display: block; width: 100%; background: var(--accent); color: #fff; border: none; border-radius: 12px; padding: 19px; font-size: 15px; font-weight: 700; text-transform: uppercase; text-align: center; text-decoration: none; cursor: pointer; box-shadow: 0 4px 15px rgba(26,63,204,0.2); }\n    .pay-icons { display: flex; justify-content: center; gap: 8px; margin-top: 15px; opacity: 0.6; }\n\n    /* ── TRUSTPILOT ── */\n    .tp-section { padding: 20px 16px; border-top: 1px solid var(--gray-100); margin-top: 25px; }\n    .tp-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }\n    .tp-star-box { background: #fff; border: 1px solid var(--gray-100); padding: 14px; border-radius: 12px; }\n\n    /* ── STICKY BAR ── */\n    #ia-sticky-cart { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1px solid var(--gray-100); padding: 15px 16px 25px; display: none; z-index: 1000; box-shadow: 0 -10px 30px rgba(0,0,0,0.05); }\n  </style>\n\n  <form action=\"/cart\" method=\"post\">\n    <div class=\"shipping-banner\">\n      <div class=\"shipping-top\">\n        <div class=\"shipping-left\">🚚 Livraison gratuite débloquée !</div>\n        <div class=\"shipping-timer\">\n          <div class=\"t-unit\"><span class=\"t-num\" id=\"ia-min\">03</span><span class=\"t-sub\">min</span></div>\n          <div class=\"t-unit\"><span class=\"t-num\" id=\"ia-sec\">00</span><span class=\"t-sub\">sec</span></div>\n        </div>\n      </div>\n      <div class=\"progress-bar\"><div class=\"progress-fill\" id=\"ia-progress\"></div></div>\n    </div>\n\n    <div class=\"cart-header\">\n      <a href=\"/\" class=\"back-btn\">← Retour</a>\n      <div class=\"cart-title\">Mon Panier</div>\n      <div class=\"cart-count\">{{ cart.item_count }} articles</div>\n    </div>\n\n    <div class=\"urgency-strip\">\n      <div class=\"u-dot\"></div>\n      <div class=\"u-text\">⚡ Offre Flash -50% — expire bientôt. (12 personnes intéressées)</div>\n    </div>\n\n    <div class=\"cart-items\">\n      {% for item in cart.items %}\n        <div class=\"cart-item\">\n          <div class=\"item-img\">\n            <img src=\"{{ item.image | img_url: '600x600' }}\" alt=\"{{ item.title }}\">\n          </div>\n          <div class=\"item-info\">\n            <div class=\"item-brand\">{{ item.vendor }}</div>\n            <div class=\"item-name\">{{ item.product.title }}</div>\n            <div class=\"item-variant\">Couleur sélectionnée : <b>{{ item.variant.title }}</b></div>\n            <div class=\"item-badge\">−50% • Offre Live</div>\n            <div class=\"item-bottom\">\n              <div class=\"item-price\">{{ item.final_price | money }}</div>\n              <div class=\"item-qty-control\">\n                <a href=\"/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}\" class=\"qty-btn\">−</a>\n                <span class=\"qty-val\">{{ item.quantity }}</span>\n                <a href=\"/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}\" class=\"qty-btn\">+</a>\n              </div>\n            </div>\n            <a href=\"/cart/change?line={{ forloop.index }}&quantity=0\" style=\"font-size:10px; color:#999; margin-top:8px; display:block;\">Supprimer</a>\n          </div>\n        </div>\n      {% endfor %}\n    </div>\n\n    <div class=\"upsell-section\">\n      <div class=\"upsell-head\">Souvent acheté ensemble</div>\n      <div class=\"upsell-card\">\n        <div class=\"upsell-img\"><img src=\"https://cdn.shopify.com/s/files/1/0850/9571/0986/files/hf_20260405_142202_2505abc6-1f9d-4225-8941-b8cd2f3aff86.png?v=1775399077\"></div>\n        <div style=\"flex:1;\">\n          <div style=\"font-size:13px; font-weight:600;\">Bracelet Sport Premium</div>\n          <div style=\"font-size:12px; color:var(--accent); font-weight:bold;\">+9,90 €</div>\n        </div>\n        <button type=\"button\" class=\"upsell-add-btn\">+ Ajouter</button>\n      </div>\n    </div>\n\n    <div class=\"summary-section\" id=\"ia-sum-anchor\">\n      <div class=\"summary-row\"><span>Sous-total</span><span>{{ cart.total_price | money }}</span></div>\n      <div class=\"summary-row\" style=\"color:var(--green); font-weight:700;\"><span>Économie réalisée</span><span>-50%</span></div>\n      <div class=\"summary-row\"><span>Livraison</span><span style=\"color:var(--green);\">Gratuite 🎁</span></div>\n      \n      <div class=\"trust-grid\">\n        <div class=\"trust-item\"><span class=\"trust-icon\">🛡️</span><span class=\"trust-txt\">Garantie<br>12 mois</span></div>\n        <div class=\"trust-item\"><span class=\"trust-icon\">↩️</span><span class=\"trust-txt\">Retour<br>60 jours</span></div>\n        <div class=\"trust-item\"><span class=\"trust-icon\">🔒</span><span class=\"trust-txt\">Paiement<br>Sécurisé</span></div>\n      </div>\n\n      <div class=\"summary-total\">\n        <span style=\"font-size:18px; font-weight:bold;\">Total</span>\n        <span class=\"total-price-val\">{{ cart.total_price | money }}</span>\n      </div>\n      \n      <button type=\"submit\" name=\"checkout\" class=\"checkout-main-btn\" style=\"margin-top:20px;\">Passer à la caisse — {{ cart.total_price | money }}</button>\n      \n      <div class=\"pay-icons\">\n        <span style=\"font-size:10px; font-weight:bold;\">VISA • MASTERCARD • PAYPAL • AMEX</span>\n      </div>\n    </div>\n\n    <div class=\"tp-section\">\n      <div class=\"tp-header\">\n        <span style=\"color:#00b67a; font-weight:bold;\">★ Trustpilot</span>\n        <span style=\"font-size:11px; color:#888;\">Note : 4.8/5</span>\n      </div>\n      <div class=\"tp-star-box\">\n        <div style=\"color:#c8a85a; font-size:11px; margin-bottom:6px;\">★★★★★</div>\n        <p style=\"font-size:12px; line-height:1.5; color:#444; font-style:italic;\">\"Superbe montre ! J'ai pris la version orange et elle claque vraiment. Livraison rapide.\"</p>\n        <div style=\"font-size:10px; font-weight:bold; margin-top:10px;\">Marc-Antoine K. (Acheteur vérifié)</div>\n      </div>\n    </div>\n  </form>\n\n  <div id=\"ia-sticky-cart\">\n    <div style=\"display:flex; justify-content:space-between; align-items:center; width:100%;\">\n      <div>\n        <div style=\"font-size:10px; color:#888; text-transform:uppercase;\">Total</div>\n        <div style=\"font-family:var(--font-serif); font-size:24px; font-weight:bold;\">{{ cart.total_price | money }}</div>\n      </div>\n      <a href=\"/checkout\" class=\"checkout-main-btn\" style=\"width:auto; padding:12px 25px; font-size:12px; margin:0;\">Payer →</a>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function() {\n    // CHRONO 3 MIN\n    let time = 180;\n    const minEl = document.getElementById('ia-min');\n    const secEl = document.getElementById('ia-sec');\n    const progEl = document.getElementById('ia-progress');\n    \n    const countdown = setInterval(() => {\n      if (time <= 0) { clearInterval(countdown); return; }\n      time--;\n      if(minEl) minEl.innerText = String(Math.floor(time/60)).padStart(2, '0');\n      if(secEl) secEl.innerText = String(time%60).padStart(2, '0');\n      if(progEl) progEl.style.width = (time/180)*100 + '%';\n    }, 1000);\n\n    // STICKY BAR AU SCROLL\n    window.addEventListener('scroll', function() {\n      const anchor = document.getElementById('ia-sum-anchor');\n      const sticky = document.getElementById('ia-sticky-cart');\n      if(anchor && sticky) {\n        const rect = anchor.getBoundingClientRect();\n        sticky.style.display = rect.bottom < 0 ? 'flex' : 'none';\n      }\n    });\n  })();\n</script>",
