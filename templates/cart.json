        "liquid": "<div id=\"ia-custom-cart-wrapper\">\n<style>\n/* ── TON STYLE ORIGINAL COMPLET ── */\n#ia-custom-cart-wrapper {\n  --black:#080808; --white:#fafafa; --gray-50:#f5f5f5; --gray-100:#ebebeb;\n  --gray-200:#d4d4d4; --gray-400:#999; --gray-500:#666; --accent:#1a3fcc;\n  --green:#22c55e; --font-serif:'Cormorant Garamond',Georgia,serif;\n  --font-sans:'DM Sans',sans-serif;\n  font-family: var(--font-sans); background: var(--white); color: var(--black);\n  margin: 0; padding-bottom: 120px;\n}\n\n/* On masque le header/footer du thème pour garder ton look App */\nheader, footer, .shopify-section-header, .shopify-section-footer { display: none !important; }\n\n@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.2;}}\n@keyframes fadeUp{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}\n\n.shipping-banner{ background:var(--black); color:#fff; padding:10px 16px; position:sticky; top:0; z-index:200; border-bottom:1px solid #1a1a1a; }\n.shipping-top{ display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }\n.shipping-text{ font-size:11px; font-weight:500; }\n.shipping-timer{ display:flex; align-items:center; gap:5px; }\n.t-unit{ background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.12); border-radius:4px; min-width:26px; padding:3px 2px; text-align:center; }\n.t-num{ font-family:var(--font-serif); font-size:13px; color:#fff; line-height:1; display:block; }\n.t-sub{ display:block; font-size:5px; text-transform:uppercase; opacity:0.3; }\n.progress-bar{ height:2px; background:rgba(255,255,255,.1); border-radius:1px; overflow:hidden; }\n.progress-fill{ height:100%; background:var(--accent); width:100%; transition: width 1s linear; }\n\n.cart-header{ display:flex; align-items:center; justify-content:space-between; padding:14px 16px; border-bottom:1px solid var(--gray-100); }\n.back-btn{ display:flex; align-items:center; gap:5px; font-size:11px; color:var(--gray-400); text-decoration:none; background:none; border:none; cursor:pointer; }\n.cart-title{ font-family:var(--font-serif); font-size:20px; font-weight:300; }\n.cart-count{ font-size:11px; color:var(--gray-400); }\n\n.urgency-strip{ background:rgba(26,63,204,.06); padding:9px 16px; display:flex; align-items:center; gap:7px; border-bottom:1px solid rgba(26,63,204,.1); }\n.u-dot{ width:5px; height:5px; border-radius:50%; background:var(--accent); animation:blink 1s infinite; }\n.urgency-text{ font-size:11px; font-weight:500; color:var(--accent); }\n\n.cart-items{ padding:0 16px; }\n.cart-item{ display:flex; gap:12px; padding:16px 0; border-bottom:1px solid var(--gray-100); animation:fadeUp .3s ease; }\n.item-img{ width:80px; height:80px; border-radius:10px; overflow:hidden; border:1px solid var(--gray-100); flex-shrink:0; }\n.item-img img{ width:100%; height:100%; object-fit:cover; display:block; }\n.item-info{ flex:1; }\n.item-brand{ font-size:9px; text-transform:uppercase; color:var(--gray-400); margin-bottom:3px; }\n.item-name{ font-family:var(--font-serif); font-size:17px; font-weight:300; line-height:1.2; }\n.item-variant{ font-size:11px; color:var(--gray-400); margin-bottom:8px; }\n.item-badge{ display:inline-flex; background:rgba(26,63,204,.08); border-radius:4px; padding:2px 6px; font-size:9px; font-weight:600; color:var(--accent); margin-bottom:6px; }\n.item-bottom{ display:flex; align-items:center; justify-content:space-between; }\n.item-price{ font-family:var(--font-serif); font-size:20px; }\n.item-qty{ display:flex; align-items:center; border:1px solid var(--gray-200); border-radius:7px; overflow:hidden; }\n.qty-btn{ width:30px; height:30px; background:none; border:none; cursor:pointer; font-size:15px; }\n.qty-val{ width:28px; text-align:center; font-size:12px; font-weight:600; }\n\n.summary-block{ padding:20px 16px 0; }\n.summary-row{ display:flex; justify-content:space-between; margin-bottom:9px; font-size:13px; }\n.summary-row.saving{ color:var(--green); font-weight:600; }\n.summary-total{ display:flex; justify-content:space-between; align-items:center; margin-top:15px; padding-top:15px; border-top:1px solid var(--gray-100); }\n.total-label{ font-family:var(--font-serif); font-size:18px; }\n.total-val{ font-family:var(--font-serif); font-size:28px; font-weight:300; }\n\n.trust-mini{ display:flex; justify-content:space-between; gap:4px; margin:20px 0; }\n.trust-mini-item{ flex:1; background:var(--gray-50); border:1px solid var(--gray-100); border-radius:8px; padding:8px 4px; text-align:center; }\n.trust-mini-text{ font-size:8px; color:var(--gray-500); font-weight:500; line-height:1.3; }\n\n.checkout-btn{ display:block; width:100%; background:var(--accent); color:#fff; border:none; border-radius:10px; padding:16px; font-size:14px; font-weight:600; text-transform:uppercase; cursor:pointer; text-align:center; text-decoration:none; }\n.payment-row{ display:flex; justify-content:center; gap:8px; margin-top:15px; opacity:0.6; }\n\n.guarantee-block{ margin:16px; background:var(--gray-50); border:1px solid var(--gray-100); border-radius:12px; padding:14px; display:flex; gap:10px; }\n.g-text strong{ display:block; font-size:12px; margin-bottom:3px; }\n.g-text span{ font-size:11px; color:var(--gray-500); line-height:1.5; }\n\n.sticky-checkout{ position:fixed; bottom:0; left:0; right:0; background:#fff; border-top:1px solid var(--gray-100); padding:12px 16px 24px; z-index:999; display:none; justify-content:space-between; align-items:center; box-shadow:0 -8px 30px rgba(0,0,0,.07); }\n</style>\n\n<form action=\"/cart\" method=\"post\" id=\"cartForm\">\n  <div class=\"shipping-banner\">\n    <div class=\"shipping-top\">\n      <div class=\"shipping-text\">🚚 Livraison gratuite débloquée ! <b>Réservez dans :</b></div>\n      <div class=\"shipping-timer\">\n        <div class=\"t-unit\"><span class=\"t-num\" id=\"min-val\">03</span><span class=\"t-sub\">min</span></div>\n        <div class=\"t-unit\"><span class=\"t-num\" id=\"sec-val\">00</span><span class=\"t-sub\">sec</span></div>\n      </div>\n    </div>\n    <div class=\"progress-bar\"><div class=\"progress-fill\" id=\"p-fill\"></div></div>\n  </div>\n\n  <div class=\"cart-header\">\n    <a href=\"/\" class=\"back-btn\">← Continuer mes achats</a>\n    <div class=\"cart-title\">Mon Panier</div>\n    <div class=\"cart-count\">{{ cart.item_count }} article(s)</div>\n  </div>\n\n  <div class=\"urgency-strip\">\n    <div class=\"u-dot\"></div>\n    <div class=\"urgency-text\">⚡ Offre Flash −50% — expire à minuit. 12 personnes regardent.</div>\n  </div>\n\n  <div class=\"cart-items\">\n    {% for item in cart.items %}\n      <div class=\"cart-item\">\n        <div class=\"item-img\">\n          <img src=\"{{ item.image | img_url: '400x400' }}\" alt=\"{{ item.title }}\">\n        </div>\n        <div class=\"item-info\">\n          <div class=\"item-brand\">{{ item.vendor }}</div>\n          <div class=\"item-name\">{{ item.product.title }}</div>\n          <div class=\"item-variant\">Couleur : <b>{{ item.variant.title }}</b></div>\n          <div class=\"item-badge\">−50% • Offre Live</div>\n          <div class=\"item-bottom\">\n            <div class=\"item-price\">{{ item.final_price | money }}</div>\n            <div class=\"item-qty\">\n              <a href=\"/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}\" style=\"text-decoration:none; color:black; width:30px; text-align:center;\">−</a>\n              <span class=\"qty-val\">{{ item.quantity }}</span>\n              <a href=\"/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}\" style=\"text-decoration:none; color:black; width:30px; text-align:center;\">+</a>\n            </div>\n          </div>\n          <a href=\"/cart/change?line={{ forloop.index }}&quantity=0\" style=\"font-size:10px; color:var(--gray-400); text-decoration:underline; margin-top:8px; display:block;\">Retirer</a>\n        </div>\n      </div>\n    {% endfor %}\n  </div>\n\n  <div class=\"summary-block\" id=\"summary-anchor\">\n    <div class=\"summary-row\"><span>Sous-total</span><span>{{ cart.total_price | money }}</span></div>\n    <div class=\"summary-row saving\"><span>🎉 Économie réalisée</span><span>−50%</span></div>\n    <div class=\"summary-row\"><span>Livraison</span><span style=\"color:var(--green);\">Gratuite 🎁</span></div>\n    \n    <div class=\"summary-total\">\n      <span class=\"total-label\">Total</span>\n      <span class=\"total-val\">{{ cart.total_price | money }}</span>\n    </div>\n\n    <div class=\"trust-mini\">\n      <div class=\"trust-mini-item\">🛡️<br><span class=\"trust-mini-text\">Garantie 12 mois</span></div>\n      <div class=\"trust-mini-item\">↩️<br><span class=\"trust-mini-text\">Retour 60 jours</span></div>\n      <div class=\"trust-mini-item\">🔒<br><span class=\"trust-mini-text\">Paiement Sécurisé</span></div>\n    </div>\n\n    <button type=\"submit\" name=\"checkout\" class=\"checkout-btn\">Finaliser ma commande — {{ cart.total_price | money }}</button>\n    <div class=\"payment-row\">VISA • MASTERCARD • PAYPAL • AMEX</div>\n  </div>\n\n  <div class=\"guarantee-block\">\n    <div class=\"g-text\">\n      <strong>Achat 100% sécurisé & sans risque</strong>\n      <span>Satisfait ou remboursé sous 60 jours. Garantie 12 mois incluse.</span>\n    </div>\n  </div>\n</form>\n\n<div class=\"sticky-checkout\" id=\"sticky-bar\">\n  <div>\n    <div style=\"font-size:10px; color:var(--gray-400);\">Total</div>\n    <div class=\"total-val\" style=\"font-size:24px;\">{{ cart.total_price | money }}</div>\n  </div>\n  <a href=\"/checkout\" class=\"checkout-btn\" style=\"width:auto; padding:12px 20px; font-size:12px;\">Payer maintenant →</a>\n</div>\n\n<script>\n(function(){\n  // Timer 3:00\n  let t = 180;\n  setInterval(() => {\n    if(t > 0) {\n      t--;\n      document.getElementById('min-val').innerText = String(Math.floor(t/60)).padStart(2,'0');\n      document.getElementById('sec-val').innerText = String(t%60).padStart(2,'0');\n      document.getElementById('p-fill').style.width = (t/180)*100 + '%';\n    }\n  }, 1000);\n\n  // Sticky scroll logic\n  window.addEventListener('scroll', () => {\n    const anchor = document.getElementById('summary-anchor');\n    const sticky = document.getElementById('sticky-bar');\n    if(anchor && sticky) {\n      sticky.style.display = anchor.getBoundingClientRect().bottom < 0 ? 'flex' : 'none';\n    }\n  });\n})();\n</script>",
