t:500;line-height:1.3;}\n\n/* ── CHECKOUT CTA ── */\n.checkout-block{padding:0 16px;}\n.checkout-btn{\n  display:block;width:100%;background:var(--accent);color:#fff;border:none;\n  border-radius:10px;padding:16px;font-family:var(--font-sans);font-size:14px;\n  font-weight:600;letter-spacing:.04em;cursor:pointer;text-align:center;\n  text-transform:uppercase;margin-bottom:8px;\n}\n.checkout-sub{font-size:10px;color:var(--gray-400);text-align:center;margin-bottom:10px;line-height:1.5;}\n.payment-row{display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap;margin-bottom:4px;}\n.pay-logo{height:22px;background:var(--gray-50);border:1px solid var(--gray-100);border-radius:5px;display:flex;align-items:center;justify-content:center;padding:3px 8px;}\n.pay-logo svg{height:12px;width:auto;}\n\n/* ── GUARANTEE ── */\n.guarantee-block{\n  margin:16px 16px 0;\n  background:var(--gray-50);border:1px solid var(--gray-100);border-radius:12px;\n  padding:14px 16px;display:flex;align-items:flex-start;gap:10px;\n}\n.g-icon{font-size:18px;flex-shrink:0;margin-top:1px;}\n.g-text strong{display:block;font-size:12px;font-weight:600;margin-bottom:3px;}\n.g-text span{font-size:11px;color:var(--gray-500);line-height:1.55;}\n\n/* ── REVIEWS MINI ── */\n.reviews-mini{padding:16px 16px 0;}\n.reviews-mini-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}\n.tp-logo{font-size:12px;font-weight:700;color:#00b67a;}\n.tp-score{font-size:11px;color:var(--gray-500);}\n.review-mini-list{display:flex;flex-direction:column;gap:8px;}\n.review-mini{background:var(--gray-50);border:1px solid var(--gray-100);border-radius:10px;padding:12px 14px;}\n.rv-stars{color:#c8a85a;font-size:10px;margin-bottom:5px;}\n.rv-text{font-size:11px;color:var(--gray-500);line-height:1.6;margin-bottom:8px;}\n.rv-footer{display:flex;align-items:center;gap:6px;}\n.rv-avatar{width:22px;height:22px;border-radius:50%;background:var(--black);color:#fff;font-size:8px;font-wei