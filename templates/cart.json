a-trust-mini {\n  display: flex;\n  justify-content: space-between;\n  gap: 4px;\n  margin-bottom: 16px;\n}\n.ia-trust-mini-item {\n  flex: 1;\n  background: var(--gray-50);\n  border: 1px solid var(--gray-100);\n  border-radius: 8px;\n  padding: 8px 4px;\n  text-align: center;\n}\n.ia-trust-mini-icon { font-size: 14px; margin-bottom: 3px; }\n.ia-trust-mini-text {\n  font-size: 8px;\n  color: var(--gray-500);\n  font-weight: 500;\n  line-height: 1.3;\n}\n\n/* ── CHECKOUT CTA ── */\n.ia-checkout-block { padding: 0 16px; }\n.ia-checkout-btn {\n  display: block;\n  width: 100%;\n  background: var(--accent);\n  color: #fff;\n  border: none;\n  border-radius: 10px;\n  padding: 16px;\n  font-family: var(--font-sans);\n  font-size: 14px;\n  font-weight: 600;\n  letter-spacing: 0.04em;\n  cursor: pointer;\n  text-align: center;\n  text-transform: uppercase;\n  transition: opacity 0.2s, transform 0.15s;\n  margin-bottom: 8px;\n}\n.ia-checkout-btn:hover { opacity: 0.92; transform: translateY(-1px); }\n.ia-checkout-btn:active { transform: scale(0.98); }\n.ia-checkout-sub {\n  font-size: 10px;\n  color: var(--gray-400);\n  text-align: center;\n  margin-bottom: 10px;\n  line-height: 1.5;\n}\n.ia-payment-row {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 6px;\n  flex-wrap: wrap;\n  margin-bottom: 4px;\n}\n.ia-pay-logo {\n  height: 22px;\n  background: var(--gray-50);\n  border: 1px solid var(--gray-100);\n  border-radius: 5px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  padding: 3px 8px;\n}\n.ia-pay-logo svg { height: 12px; width: auto; }\n\n/* ── GUARANTEE ── */\n.ia-guarantee-block {\n  margin: 16px 16px 0;\n  background: var(--gray-50);\n  border: 1px solid var(--gray-100);\n  border-radius: 12px;\n  padding: 14px 16px;\n  display: flex;\n  align-items: flex-start;\n  gap: 10px;\n}\n.ia-g-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }\n.ia-g-text strong {\n  display: block;\n  font-size: 12px;\n  font-weight: 600;\n  margin-bottom: 3px;\n}\n.ia-g-text span {\n  font-size: 11px;\n  color: var(--gray-500);\n  line-height: 1.55;\n}\n\n/* ── REVIEWS MINI ── */\n.ia-reviews-mini { padding: 16px 16px 0; }\n.ia-reviews-mini-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 10px;\n}\n.ia-tp-logo { font-size: 12px; font-weight: 700; color: #00b67a; }\n.ia-tp-score { font-size: 11px; color: var(--gray-500); }\n.ia-review-mini-list { display: flex; flex-direction: column; gap: 8px; }\n.ia-review-mini {\n  background: var(--gray-50);\n  border: 1px solid var(--gray-100);\n  border-radius: 10px;\n  padding: 12px 14px;\n}\n.ia-rv-stars { color: #c8a85a; font-size: 10px; margin-bottom: 5px; }\n.ia-rv-text {\n  font-size: 11px;\n  color: var(--gray-500);\n  line-height: 1.6;\n  margin-bottom: 8px;\n}\n.ia-rv-footer { display: flex; align-items: center; gap: 6px; }\n.ia-rv-avatar {\n  width: 22px;\n  height: 22px;\n  border-radius: 50%;\n  background: var(--black);\n  color: #fff;\n  font-size: 8px;\n  font-weight: 700;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n.ia-rv-name { font-size: 10px; font-weight: 600; }\n.ia-rv-verified { font-size: 9px; color: #00b67a; }\n\n/* ── EMPTY STATE ── */\n.ia-empty-state { display: none; text-align: center; padding: 60px 32px; }\n.ia-empty-state.visible { display: block; }\n.ia-empty-icon { font-size: 48px; margin-bottom: 16px; }\n.ia-empty-title {\n  font-family: var(--font-serif);\n  font-size: 24px;\n  font-weight: 300;\n  margin-bottom: 8px;\n}\n.ia-empty-sub { font-size: 13px; color: var(--gray-400); margin-bottom: 24px; }\n.ia-empty-btn {\n  display: inline-block;\n  background: var(--black);\n  color: #fff;\n  border: none;\n  border-radius: 9px;\n  padding: 13px 28px;\n  font-family: var(--font-sans);\n  font-size: 12px;\n  font-weight: 600;\n  cursor: pointer;\n  text-decoration: none;\n  letter-spacing: 0.04em;\n  text-transform: uppercase;\n}\n\n/* ── STICKY CHECKOUT ── */\n.ia-sticky-checkout {\n  position: fixed;\n  bottom: 0; left: 0; right: 0;\n  background: var(--white);\n  border-top: 1px solid var(--gray-100);\n  padding: 10px 16px 16px;\n  z-index: 9999;\n  box-shadow: 0 -8px 30px rgba(0,0,0,0.07);\n  transform: translateY(100%);\n  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);\n}\n.ia-sticky-checkout.visible { transform: translateY(0); }\n.ia-sticky-row { display: flex; align-items: center; gap: 10px; }\n.ia-sticky-total { flex: 1; }\n.ia-sticky-total-label { font-size: 10px; color: var(--gray-400); }\n.ia-sticky-total-val {\n  font-family: var(--font-serif);\n  font-size: 24px;\n  font-weight: 300;\n  line-height: 1;\n}\n.ia-sticky-btn {\n  background: var(--accent);\n  color: #fff;\n  border: none;\n  border-radius: 9px;\n  padding: 13px 20px;\n  font-family: var(--font-sans);\n  font-size: 12px;\n  font-weight: 600;\n  cursor: pointer;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  white-space: nowrap;\n  transition: opacity 0.2s;\n  flex-shrink: 0;\n}\n.ia-sticky-btn:active { opacity: 0.8; }\n\n/* ── FOOTER ── */\n.ia-cart-footer {\n  background: var(--black);\n  color: #fff;\n  padding: 24px 16px;\n  text-align: center;\n  margin-top: 32px;\n}\n.ia-footer-logo {\n  font-family: var(--font-serif);\n  font-size: 15px;\n  font-weight: 400;\n  letter-spacing: 0.08em;\n  margin-bottom: 12px;\n  color: rgba(255,255,255,0.6);\n}\n.ia-footer-links {\n  display: flex;\n  justify-content: center;\n  gap: 14px;\n  flex-wrap: wrap;\n  margin-bottom: 10px;\n}\n.ia-footer-links a {\n  font-size: 10px;\n  color: rgba(255,255,255,0.35);\n  text-decoration: none;\n}\n.ia-footer-copy { font-size: 9px; color: rgba(255,255,255,0.18); }\n</style>\n\n<!-- ══════════════════════════ HTML ══════════════════════════ -->\n<div id=\"ia-cart-wrapper\">\n\n  <!-- FREE SHIPPING BANNER -->\n  <div id=\"ia-shipping-banner\">\n    <div class=\"ia-shipping-inner\">\n      <div class=\"ia-ship