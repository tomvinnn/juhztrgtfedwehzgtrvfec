        "liquid": "{% if request.page_type == 'cart' %}\n\n<!-- ═══════════════════════════════════════════════════════════════\n     CART PAGE — IA High Tec Shop\n     Fichier : theme.liquid (ou layout/theme.liquid)\n     Condition : s'affiche UNIQUEMENT sur /cart\n═══════════════════════════════════════════════════════════════ -->\n\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap\" rel=\"stylesheet\">\n\n<style>\n/* ── RESET ── */\n#ia-cart-wrapper * {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n#ia-cart-wrapper {\n  --black: #080808;\n  --white: #fafafa;\n  --gray-50: #f5f5f5;\n  --gray-100: #ebebeb;\n  --gray-200: #d4d4d4;\n  --gray-400: #999;\n  --gray-500: #666;\n  --accent: #1a3fcc;\n  --green: #22c55e;\n  --font-serif: 'Cormorant Garamond', Georgia, serif;\n  --font-sans: 'DM Sans', sans-serif;\n  font-family: var(--font-sans);\n  background: var(--white);\n  color: var(--black);\n  padding-bottom: 120px;\n}\n\n/* ── ANIMATIONS ── */\n@keyframes ia-blink {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.2; }\n}\n@keyframes ia-fadeUp {\n  from { opacity: 0; transform: translateY(8px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n\n/* ── FREE SHIPPING BANNER ── */\n#ia-shipping-banner {\n  background: var(--black);\n  color: #fff;\n  padding: 0 16px;\n  position: sticky;\n  top: 0;\n  z-index: 200;\n  border-bottom: 1px solid #1a1a1a;\n}\n.ia-shipping-inner {\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n  padding: 10px 0 0;\n}\n.ia-shipping-top {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 8px;\n}\n.ia-shipping-left {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n.ia-shipping-icon {\n  font-size: 16px;\n  flex-shrink: 0;\n}\n.ia-shipping-text {\n  font-size: 13px;\n  font-weight: 500;\n  color: #ffffff;\n  line-height: 1.35;\n  font-family: var(--font-sans);\n}\n.ia-shipping-text b {\n  color: #ffffff;\n  font-weight: 700;\n}\n.ia-timer-blocks {\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  flex-shrink: 0;\n}\n.ia-t-unit {\n  background: rgba(255,255,255,0.12);\n  border: 1px solid rgba(255,255,255,0.18);\n  border-radius: 5px;\n  min-width: 30px;\n  padding: 4px 3px;\n  text-align: center;\n}\n.ia-t-num {\n  font-family: var(--font-sans);\n  font-size: 15px;\n  font-weight: 600;\n  color: #fff;\n  line-height: 1;\n  display: block;\n}\n.ia-t-sub {\n  display: block;\n  font-size: 9px;\n  letter-spacing: 0.08em;\n  color: rgba(255,255,255,0.5);\n  text-transform: uppercase;\n  margin-top: 1px;\n}\n.ia-t-sep {\n  font-size: 13px;\n  color: rgba(255,255,255,0.4);\n  padding-bottom: 3px;\n  font-weight: 700;\n}\n.ia-progress-bar {\n  height: 2px;\n  background: rgba(255,255,255,0.1);\n  border-radius: 1px;\n  overflow: hidden;\n  margin-bottom: 0;\n}\n.ia-progress-fill {\n  height: 100%;\n  background: var(--green);\n  border-radius: 1px;\n  width: 100%;\n  transition: width 1s linear;\n}\n\n/* ── HEADER NAV ── */\n.ia-cart-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 14px 16px;\n  border-bottom: 1px solid var(--gray-100);\n}\n.ia-back-btn {\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  font-size: 11px;\n  font-weight: 500;\n  color: var(--gray-400);\n  text-decoration: none;\n  background: none;\n  border: none;\n  cursor: pointer;\n  font-family: var(--font-sans);\n}\n.ia-back-btn svg { width: 14px; height: 14px; }\n.ia-cart-title {\n  font-family: var(--font-serif);\n  font-size: 20px;\n  font-weight: 300;\n  letter-spacing: -0.01em;\n}\n.ia-cart-count {\n  font-size: 11px;\n  color: var(--gray-400);\n  font-weight: 500;\n}\n\n/* ── URGENCY STRIP ── */\n.ia-urgency-strip {\n  background: rgba(26,63,204,0.06);\n  border-bottom: 1px solid rgba(26,63,204,0.1);\n  padding: 9px 16px;\n  display: flex;\n  align-items: center;\n  gap: 7px