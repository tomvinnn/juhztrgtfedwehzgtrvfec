location.search);\nif(p.get('color')){\n  var c = p.get('color');\n  document.getElementById('itemVariant').textContent = 'Couleur : ' + c.charAt(0).toUpperCase()+c.slice(1);\n  var imgs = {'noir':'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713','beige':'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715','orange':'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715'};\n  if(imgs[c]) document.getElementById('itemImg').src = imgs[c];\n}\n\nfunction updatePrices(){\n  var sub = (PRICE_UNIT * qty) + (upsellAdded ? UPSELL_PRICE : 0);\n  var sav = (PRICE_OLD * qty) - (PRICE_UNIT * qty);\n  var txt = sub.toFixed(2).replace('.',',') + ' €';\n  document.getElementById('subtotal').textContent = txt;\n  document.getElementById('totalVal').textContent = txt;\n  document.getElementById('ctaPrice').textContent = txt;\n  document.getElementById('stickyTotal').textContent = txt;\n  document.getElementById('itemPrice').textContent = (PRICE_UNIT * qty).toFixed(2).replace('.',',') + ' €';\n  document.getElementById('savingVal').textContent = '-' + sav.toFixed(2).replace('.',',') + ' €';\n}\n\nwindow.changeQty = function(d){ qty = Math.max(1, qty+d); document.getElementById('itemQty').textContent = qty; updatePrices(); };\nwindow.removeItem = function(){ itemExists = false; document.getElementById('main-cart-container').style.display='none'; document.getElementById('emptyState').classList.add('visible'); };\nwindow.addUpsell = function(){ upsellAdded = true; document.getElementById('upsellBtn').textContent='✓ Ajouté'; updatePrices(); };\nwindow.checkout = function(){ window.location.href = '/checkout'; };\nwindow.goBack = function(){ window.history.back(); };\n\n// Timer\nvar time = 180;\nsetInterval(function(){\n  if(time > 0){\n    time--;\n    document.getElementById('tb-m').textContent = String(Math.