total-sub\">TTC &middot; Livraison offerte</div>\n\n    <!-- Trust mini -->\n    <div class=\"ia-trust-mini\">\n      <div class=\"ia-trust-mini-item\">\n        <div class=\"ia-trust-mini-icon\">🛡️</div>\n        <div class=\"ia-trust-mini-text\">Garantie<br>12 mois</div>\n      </div>\n      <div class=\"ia-trust-mini-item\">\n        <div class=\"ia-trust-mini-icon\">↩️</div>\n        <div class=\"ia-trust-mini-text\">Retour<br>60 jours</div>\n      </div>\n      <div class=\"ia-trust-mini-item\">\n        <div class=\"ia-trust-mini-icon\">🔒</div>\n        <div class=\"ia-trust-mini-text\">Paiement<br>sécurisé</div>\n      </div>\n      <div class=\"ia-trust-mini-item\">\n        <div class=\"ia-trust-mini-icon\">💬</div>\n        <div class=\"ia-trust-mini-text\">Support<br>24h/24</div>\n      </div>\n    </div>\n  </div>\n\n  <!-- CHECKOUT CTA -->\n  <div class=\"ia-checkout-block\" id=\"ia-checkoutBlock\">\n    <button class=\"ia-checkout-btn\" onclick=\"iaCheckout()\">\n      Finaliser ma commande —\n      <span id=\"ia-ctaPrice\">64,90 &euro;</span>\n    </button>\n    <div class=\"ia-checkout-sub\">\n      Paiement sécurisé SSL &middot; Livraison gratuite &middot;\n      Satisfait ou remboursé 60j\n    </div>\n    <div class=\"ia-payment-row\">\n      <div class=\"ia-pay-logo\">\n        <svg viewBox=\"0 0 50 16\">\n          <text x=\"0\" y=\"13\" font-family=\"Arial\" font-size=\"14\"\n            font-weight=\"900\" fill=\"#1A1F71\">VISA</text>\n        </svg>\n      </div>\n      <div class=\"ia-pay-logo\">\n        <svg viewBox=\"0 0 38 24\">\n          <circle cx=\"15\" cy=\"12\" r=\"10\" fill=\"#EB001B\"/>\n          <circle cx=\"23\" cy=\"12\" r=\"10\" fill=\"#F79E1B\"/>\n          <path d=\"M19 5.3a10 10 0 010 13.4A10 10 0 0119 5.3z\" fill=\"#FF5F00\"/>\n        </svg>\n      </div>\n      <div class=\"ia-pay-logo\">\n        <svg viewBox=\"0 0 60 20\">\n          <text x=\"0\" y=\"15\" font-family=\"Arial\" font-size=\"12\"\n            font-weight=\"700\" fill=\"#003087\">Pay</text>\n          <text x=\"22\" y=\"15\" font-family=\"Arial\" font-size=\"12\"\n            font-weight=\"700\" fill=\"#009CDE\">Pal</text>\n        </svg>\n      </div>\n      <div class=\"ia-pay-logo\">\n        <svg viewBox=\"0 0 34 20\">\n          <rect width=\"34\" height=\"20\" rx=\"3\" fill=\"#1A1F71\"/>\n          <text x=\"4\" y=\"14\" font-family=\"Arial\" font-size=\"9\"\n            font-weight=\"900\" fill=\"#fff\">CB</text>\n        </svg>\n      </div>\n    </div>\n  </div>\n\n  <!-- GUARANTEE -->\n  <div class=\"ia-guarantee-block\">\n    <div class=\"ia-g-icon\">🛡️</div>\n    <div class=\"ia-g-text\">\n      <strong>Achat 100% sécurisé &amp; sans risque</strong>\n      <span>Satisfait ou remboursé sous 60 jours, sans justification.\n        Garantie 12 mois incluse. Si vous n'êtes pas conquis, on vous\n        rembourse intégralement — livraison comprise.</span>\n    </div>\n  </div>\n\n  <!-- REVIEWS MINI -->\n  <div class=\"ia-reviews-mini\">\n    <div class=\"ia-reviews-mini-header\">\n      <div class=\"ia-tp-logo\">★ Trustpilot</div>\n      <div class=\"ia-tp-score\">4,8/5 &middot; 312 avis</div>\n    </div>\n    <div class=\"ia-review-mini-list\">\n      <div class=\"ia-review-mini\">\n        <div class=\"ia-rv-stars\">★★★★★</div>\n        <p class=\"ia-rv-text\">Commandé mercredi soir, reçu vendredi matin. Emballage soigné, produit conforme. L'écran est vraiment net.</p>\n        <div class=\"ia-rv-footer\">\n          <div class=\"ia-rv-avatar\">MF</div>\n          <div>\n            <div class=\"ia-rv-name\">Mathieu F.</div>\n            <div class=\"ia-rv-verified\">✓ Avis vérifié</div>\n          </div>\n        </div>\n      </div>\n      <div class=\"ia-review-mini\">\n        <div class=\"ia-rv-stars\">★★★★★</div>\n        <p class=\"ia-rv-text\">La batterie tient 5-6 jours facilement. Je n'ai plus à m'inquiéter de charger chaque soir. Je recommande les yeux fermés.</p>\n        <div class=\"ia-rv-footer\">\n          <div class=\"ia-rv-avatar\">AL</div>\n          <div>\n            <div class=\"ia-rv-name\">Antoine L.</div>\n            <div class=\"ia-rv-verified\">✓ Avis vérifié</div>\n          </div>\n        </div>\n      </div>\n      <div class=\"ia-review-mini\">\n        <div class=\"ia-rv-stars\">★★★★★</div>\n        <p class=\"ia-rv-text\">Portée tous les jours depuis 3 semaines. Pas un seul bug, pas une seule déception. Rapport qualité/prix imbattable.</p>\n        <div class=\"ia-rv-footer\">\n          <div class=\"ia-rv-avatar\">SL</div>\n          <div>\n            <div class=\"ia-rv-name\">Sophie L.</div>\n            <div class=\"ia-rv-verified\">✓ Avis vérifié</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- EMPTY STATE -->\n  <div class=\"ia-empty-state\" id=\"ia-emptyState\">\n    <div class=\"ia-empty-icon\">🛒</div>\n    <div class=\"ia-empty-title\">Votre panier est vide</div>\n    <div class=\"ia-empty-sub\">Découvrez notre Smart Watch 2.0 à &minus;50%.</div>\n    <a href=\"/\" class=\"ia-empty-btn\">Voir le produit</a>\n  </div>\n\n  <!-- FOOTER -->\n  <div class=\"ia-cart-footer\">\n    <div class=\"ia-footer-logo\">IA High Tec Shop</div>\n    <div class=\"ia-footer-links\">\n      <a href=\"/policies/privacy-policy\">Confidentialité</a>\n      <a href=\"/policies/refund-policy\">Remboursement</a>\n      <a href=\"/policies/terms-of-service\">CGV</a>\n      <a href=\"/policies/shipping-policy\">Livraison</a>\n      <a href=\"/pages/contact\">Contact</a>\n    </div>\n    <div class=\"ia-footer-copy\">&copy; 2026 IA High Tec Shop — Tous droits réservés</div>\n  </div>\n\n  <!-- STICKY CHECKOUT -->\n  <div class=\"ia-sticky-checkout\" id=\"ia-stickyCheckout\">\n    <div class=\"ia-sticky-row\">\n      <div class=\"ia-sticky-total\">\n        <div class=\"ia-sticky-total-label\">Total</div>\n        <div class=\"ia-sticky-total-val\" id=\"ia-stickyTotal\">64,90 &euro;</div>\n      </div>\n      <button class=\"ia-sticky-btn\" onclick=\"iaCheckout()\">Payer maintenant →</button>\n    </div>\n  </div>\n\n</div><!-- /#ia-cart-wrapper -->\n\n<!-- ══════════════════════════ JS ══════════════════════════ -->\n<script>\n(function(){\n  var PRICE_UNIT  = 64.90;\n  var PRICE_OLD   = 129.90;\n  var qty         = 1;\n  var itemExists  = true;\n\n  /* URL params */\n  (function(){\n    try {\n      var p = new URLSearchParams(window.location.search);\n      if (p.get('color')) {\n        var c = p.get('color');\n        var label = c.charAt(0).toUpperCase() + c.slice(1);\n        document.getElementById('ia-itemVariant').textContent = 'Couleur : ' + label;\n        var imgs = {\n          'noir':   'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_2.jpg?v=1775248713',\n          'beige':  'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43_1.jpg?v=1775248715',\n          'orange': 'https://cdn.shopify.com/s/files/1/0850/9571/0986/files/WhatsApp_Image_2026-04-03_at_22.37.43.jpg?v=1775248715'\n        };\n        if (imgs[c]) document.getElementById('ia-itemImg').src = imgs[c];\n      }\n      if (p.get('qty')) {\n        qty = Math.max(1, parseInt(p.get('qty')) || 1);\n        document.getElementById('ia-itemQty').textContent = qty;\n      }\n    } catch(e) {}\n  })();\n\n  /* ── TIMER (3 min) ── */\n  var TIMER_TOTAL = 3 * 60;\n  var timerLeft   = TIMER_TOTAL;\n  var timerDone   = false;\n\n  function updateTimer() {\n    if (timerDone) return;\n    var m  = Math.floor(timerLeft / 60);\n    var s  = timerLeft % 60;\n    var em = document.getElementById('ia-tb-m');\n    var es = document.getElementById('ia-tb-s');\n    var pf = document.getElementById('ia-progressFill');\n    if (em) em.textContent = String(m).padStart(2, '0');\n    if (es) es.textContent = String(s).padStart(2, '0');\n    if (pf) {\n      var pct = (timerLeft / TIMER_TOTAL) * 100;\n      pf.style.width = pct + '%';\n      if      (pct < 30) pf.style.background = '#ef4444';\n      else if (pct < 60) pf.style.background = '#f97316';\n      else               pf.style.background = '#22c55e';\n    }\n    if (timerLeft <= 0) {\n      timerDone = true;\n      var txt = document.getElementById('ia-shippingText');\n      if (txt) txt.innerHTML = 'Offre expirée — la remise &minus;50% n\\'est plus garantie. <b>Finalisez maintenant.</b>';\n      if (pf)  pf.style.width = '0%';\n    } else {\n      timerLeft--;\n    }\n  }\n  updateTimer();\n  setInterval(updateTimer, 1000);\n\n  /* ── PRICE UTILS ── */\n  function fmt(n) {\n    return n.toFixed(2).replace('.', ',') + ' €';\n  }\n\n  function updatePrices() {\n    var sub    = PRICE_UNIT * qty;\n    var saving = (PRICE_OLD - PRICE_UNIT) * qty;\n    document.getElementById('ia-subtotal').textContent    = fmt(sub);\n    document.getElementById('ia-savingVal').textContent   = '−' + fmt(saving);\n    document.getElementById('ia-totalVal').textContent    = fmt(sub);\n    document.getElementById('ia-ctaPrice').textContent    = fmt(sub);\n    document.getElementById('ia-stickyTotal').textContent = fmt(sub);\n    document.getElementById('ia-itemPrice').textContent   = fmt(PRICE_UNIT * qty);\n    var count = qty;\n    document.getElementById('ia-cartCount').textContent   =\n      count + (count > 1 ? ' articles' : ' article');\n  }\n\n  /* ── QTY ── */\n  window.iaChangeQty = function(d) {\n    qty = Math.max(1, qty + d);\n    document.getElementById('ia-itemQty').textContent = qty;\n    updatePrices();\n  };\n\n  /* ── REMOVE ── */\n  window.iaRemoveItem = function() {\n    itemExists = false;\n    var item = document.getElementById('ia-item-main');\n    if (item) {\n      item.style.opacity    = '0';\n      item.style.transition = 'opacity .3s';\n      setTimeout(function() {\n        item.style.display = 'none';\n        checkEmpty();\n      }, 300);\n    }\n  };\n\n  function checkEmpty() {\n    if (!itemExists) {\n      var els = ['ia-cartItems', 'ia-checkoutBlock'];\n      els.forEach(function(id) {\n        var el = document.getElementById(id);\n        if (el) el.style.display = 'none';\n      });\n      var sumEl = document.querySelector('.ia-summary-block');\n      var gEl   = document.querySelector('.ia-guarantee-block');\n      if (sumEl) sumEl.style.display = 'none';\n      if (gEl)   gEl.style.display   = 'none';\n      document.getElementById('ia-emptyState').classList.add('visible');\n      document.getElementById('ia-stickyCheckout').classList.remove('visible');\n    }\n  }\n\n  /* ── CHECKOUT ── */\n  window.iaCheckout = function() {\n    window.location.href = 'https://iatechshop.myshopify.com/checkout';\n  };\n\n  /* ── BACK ── */\n  window.iaGoBack = function() {\n    if (document.referrer && document.referrer !== window.location.href) {\n      window.history.back();\n    } else {\n      window.location.href = '/';\n    }\n  };\n\n  /* ── STICKY ── */\n  var sticky        = document.getElementById('ia-stickyCheckout');\n  var checkoutBlock = document.getElementById('ia-checkoutBlock');\n  window.addEventListener('scroll', function() {\n    if (!sticky || !checkoutBlock) return;\n    sticky.classList.toggle(\n      'visible',\n      checkoutBlock.getBoundingClientRect().bottom < 0\n    );\n  }, { passive: true });\n\n  /* ── INIT ── */\n  updatePrices();\n\n})();\n<\\/script>\n\n{% endif %}",
